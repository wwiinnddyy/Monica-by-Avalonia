<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="using:FluentAvalonia.UI.Controls"
        xmlns:ic="using:FluentIcons.Avalonia"
        xmlns:local="using:Monica.App"
        xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
        xmlns:models="using:Monica.Core.Models"
        xmlns:vm="using:Monica.App.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="Monica.App.MainWindow"
        x:Name="Root"
        Title="Monica"
        Icon="/Assets/AppIcon.ico"
        Width="1000"
        Height="650"
        MinWidth="800"
        MinHeight="500">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2B2B2B" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9D9D9D" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.noteTab">
            <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        </Style>
        <Style Selector="Border.noteTab.active">
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Button.noteTabButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,24" Background="{DynamicResource LayerFillColorDefaultBrush}">
        <Grid Grid.Row="0">
            <Grid IsVisible="{Binding !IsUnlocked}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel Width="360" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ic:FluentIcon Icon="LockClosed" FontSize="48" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding LoginTitle}" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding LoginDescription}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Border IsVisible="{Binding HasLegacyVaultImportPrompt}" Padding="12" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding L.LegacyVaultDetected}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LegacyVaultImportPromptText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <TextBox PasswordChar="*" PlaceholderText="{Binding L.MasterPasswordWatermark}" Text="{Binding MasterPassword}" />
                    <TextBox IsVisible="{Binding !IsVaultInitialized}" PasswordChar="*" PlaceholderText="{Binding L.ConfirmMasterPasswordWatermark}" Text="{Binding ConfirmMasterPassword}" />
                    <Button Command="{Binding UnlockCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="Key" FontSize="20" />
                            <TextBlock Text="{Binding LoginButtonText}" />
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" />
                </StackPanel>
            </Grid>

            <fa:FANavigationView IsVisible="{Binding IsUnlocked}"
                                 PaneDisplayMode="Left"
                                 IsPaneOpen="False"
                                 IsBackButtonVisible="False"
                                 IsSettingsVisible="False"
                                 OpenPaneLength="240"
                                 SelectionChanged="NavigationView_OnSelectionChanged">
                <fa:FANavigationView.MenuItems>
                    <fa:FANavigationViewItem Content="{Binding L.Passwords}" Tag="Passwords">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Permissions" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.SecureNotes}" Tag="Notes">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="ProtectedDocument" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Totp}" Tag="Totp">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Clock" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Cards}" Tag="Cards">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="ContactInfo" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Generator}" Tag="Generator">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Edit" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Archive}" Tag="Archive">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Library" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.RecycleBin}" Tag="RecycleBin">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Delete" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.SecurityAnalysis}" Tag="SecurityAnalysis">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Permissions" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Timeline}" Tag="Timeline">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Clock" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.MdbxVaults}" Tag="Mdbx">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Folder" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                </fa:FANavigationView.MenuItems>

                <fa:FANavigationView.FooterMenuItems>
                    <fa:FANavigationViewItem Content="{Binding L.DatabaseManagement}" Tag="DatabaseManagement">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Library" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.SyncAndBackup}" Tag="Sync">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Sync" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Settings}" Tag="Settings">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Setting" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                </fa:FANavigationView.FooterMenuItems>

                <Grid Margin="18" RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,18" IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsContentHeaderVisible}}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedSectionTitle}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Classes="IconButton" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}">
                                <ic:FluentIcon Icon="ArrowClockwise" FontSize="20" />
                            </Button>
                            <Button Classes="IconButton" Command="{Binding ExportDataCommand}" ToolTip.Tip="{Binding L.Export}">
                                <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsPasswords}}" RowDefinitions="Auto,Auto,Auto,Auto,*">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,0,16" ColumnSpacing="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding L.PasswordManager}" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding PasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Margin="24,0" PlaceholderText="{Binding L.Search}" Text="{Binding SearchText}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="2"
                                          Width="190"
                                          ItemsSource="{Binding PasswordSortOptions}"
                                          SelectedValue="{Binding SelectedPasswordSort}"
                                          SelectedValueBinding="{Binding Value}"
                                          VerticalAlignment="Center"
                                          ToolTip.Tip="{Binding L.SortPasswords}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                            <TextBlock Text="{Binding Label}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="3" Command="{Binding FavoriteSelectedPasswordsCommand}" IsVisible="{Binding HasSelectedPasswords}" VerticalAlignment="Center" ToolTip.Tip="{Binding L.BatchFavorite}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="Star" FontSize="20" />
                                        <TextBlock Text="{Binding SelectedPasswordCountText}" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="4" Command="{Binding MoveSelectedPasswordsToCategoryCommand}" IsVisible="{Binding HasSelectedPasswords}" VerticalAlignment="Center" ToolTip.Tip="{Binding L.MoveToFolder}">
                                    <ic:FluentIcon Icon="Folder" FontSize="20" />
                                </Button>
                                <Button Grid.Column="5" Command="{Binding ArchiveSelectedPasswordsCommand}" IsVisible="{Binding HasSelectedPasswords}" VerticalAlignment="Center" ToolTip.Tip="{Binding L.BatchArchive}">
                                    <ic:FluentIcon Icon="Archive" FontSize="20" />
                                </Button>
                                <Button Grid.Column="6" Command="{Binding DeleteSelectedPasswordsCommand}" IsVisible="{Binding HasSelectedPasswords}" VerticalAlignment="Center" ToolTip.Tip="{Binding L.BatchDelete}">
                                    <ic:FluentIcon Icon="Delete" FontSize="20" />
                                </Button>
                                <Button Grid.Column="7" Command="{Binding StackSelectedPasswordsCommand}" IsVisible="{Binding CanStackSelectedPasswords}" VerticalAlignment="Center" ToolTip.Tip="{Binding L.StackSelectedPasswords}">
                                    <ic:FluentIcon Icon="Link" FontSize="20" />
                                </Button>
                                <Button Grid.Column="8" Command="{Binding AddPasswordCommand}" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="Add" FontSize="20" />
                                        <TextBlock Text="{Binding L.AddPassword}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,12">
                                <ComboBox ItemsSource="{Binding PasswordFolderFilters}"
                                          SelectedItem="{Binding SelectedPasswordFolderFilter}"
                                          Width="220"
                                          HorizontalAlignment="Left">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PasswordFolderFilterChoice">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBlock Text="{Binding Name}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Count}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBox Grid.Column="1" Text="{Binding NewFolderName}" PlaceholderText="{Binding L.NewFolder}" />
                                <Button Grid.Column="2" Command="{Binding CreatePasswordFolderCommand}" ToolTip.Tip="{Binding L.CreateFolder}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="FolderAdd" FontSize="18" />
                                        <TextBlock Text="{Binding L.CreateFolder}" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="3" Command="{Binding RenameSelectedPasswordFolderCommand}" IsEnabled="{Binding CanManageSelectedPasswordFolder}" ToolTip.Tip="{Binding L.RenameFolder}">
                                    <ic:FluentIcon Icon="Edit" FontSize="18" />
                                </Button>
                                <Button Grid.Column="4" Command="{Binding DeleteSelectedPasswordFolderCommand}" IsEnabled="{Binding CanManageSelectedPasswordFolder}" ToolTip.Tip="{Binding L.DeleteFolder}">
                                    <ic:FluentIcon Icon="Delete" FontSize="18" />
                                </Button>
                                <Button Grid.Column="5" Command="{Binding MoveSelectedPasswordsToCategoryCommand}" IsVisible="{Binding HasSelectedPasswords}" ToolTip.Tip="{Binding L.MoveToFolder}">
                                    <ic:FluentIcon Icon="Folder" FontSize="18" />
                                </Button>
                            </Grid>

                            <Grid Grid.Row="2" IsVisible="{Binding HasPasswordQuickAccessItems}" ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,12">
                                <Border Padding="12" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ic:FluentIcon Icon="History" FontSize="18" />
                                            <TextBlock Text="{Binding L.QuickAccessRecent}" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding RecentPasswordQuickAccessItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PasswordQuickAccessItem">
                                                    <Button Command="{Binding #Root.DataContext.OpenQuickAccessPasswordCommand}" CommandParameter="{Binding}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,0,0,6">
                                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                            <Border Width="34" Height="34" CornerRadius="17" Background="#2F7DFF">
                                                                <TextBlock Text="{Binding Entry.AvatarText}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Entry.Title}" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Subtitle}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2" Text="{Binding LastOpenedText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Padding="12" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ic:FluentIcon Icon="TopSpeed" FontSize="18" />
                                            <TextBlock Text="{Binding L.QuickAccessFrequent}" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding FrequentPasswordQuickAccessItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PasswordQuickAccessItem">
                                                    <Button Command="{Binding #Root.DataContext.OpenQuickAccessPasswordCommand}" CommandParameter="{Binding}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,0,0,6">
                                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                            <Border Width="34" Height="34" CornerRadius="17" Background="#5B5FC7">
                                                                <TextBlock Text="{Binding Entry.AvatarText}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Entry.Title}" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Subtitle}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <Border Grid.Column="2" Padding="8,3" CornerRadius="8" Background="{DynamicResource AccentFillColorDefaultBrush}" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding OpenCount}" Foreground="White" FontSize="12" />
                                                            </Border>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ToggleButton IsChecked="{Binding QuickFilterFavorite}" ToolTip.Tip="{Binding L.QuickFilterFavorite}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="Star" FontSize="16" />
                                            <TextBlock Text="{Binding L.QuickFilterFavorite}" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton IsChecked="{Binding QuickFilter2Fa}" ToolTip.Tip="{Binding L.QuickFilter2Fa}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="Key" FontSize="16" />
                                            <TextBlock Text="{Binding L.QuickFilter2Fa}" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton IsChecked="{Binding QuickFilterNotes}" ToolTip.Tip="{Binding L.QuickFilterNotes}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="Note" FontSize="16" />
                                            <TextBlock Text="{Binding L.QuickFilterNotes}" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton IsChecked="{Binding QuickFilterPasskey}" ToolTip.Tip="{Binding L.QuickFilterPasskey}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="Fingerprint" FontSize="16" />
                                            <TextBlock Text="{Binding L.QuickFilterPasskey}" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton IsChecked="{Binding QuickFilterBoundNote}" ToolTip.Tip="{Binding L.QuickFilterBoundNote}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="Document" FontSize="16" />
                                            <TextBlock Text="{Binding L.QuickFilterBoundNote}" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton IsChecked="{Binding QuickFilterUncategorized}" ToolTip.Tip="{Binding L.QuickFilterUncategorized}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="Folder" FontSize="16" />
                                            <TextBlock Text="{Binding L.QuickFilterUncategorized}" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton IsChecked="{Binding QuickFilterLocalOnly}" ToolTip.Tip="{Binding L.QuickFilterLocalOnly}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="Desktop" FontSize="16" />
                                            <TextBlock Text="{Binding L.QuickFilterLocalOnly}" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton IsChecked="{Binding QuickFilterAttachments}" ToolTip.Tip="{Binding L.QuickFilterAttachments}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="Attach" FontSize="16" />
                                            <TextBlock Text="{Binding L.QuickFilterAttachments}" />
                                        </StackPanel>
                                    </ToggleButton>
                                </StackPanel>
                            </ScrollViewer>

                            <Grid Grid.Row="4" ColumnDefinitions="380,*" ColumnSpacing="14">
                                <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource CardBackgroundBrush}">
                                    <ListBox ItemsSource="{Binding FilteredPasswords}"
                                             SelectedItem="{Binding SelectedPassword}"
                                             SelectionMode="Single"
                                             Padding="6"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:PasswordEntry">
                                                <Border Margin="0,0,0,6" Padding="10" CornerRadius="6" Background="{DynamicResource LayerFillColorSubtleBrush}">
                                                    <Grid ColumnDefinitions="Auto,Auto,*" MinHeight="52">
                                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="19" Background="#2F7DFF">
                                                            <TextBlock Text="{Binding AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                <ic:FluentIcon Icon="Star" FontSize="14" IsVisible="{Binding IsFavorite}" />
                                                                <ic:FluentIcon Icon="Attach" FontSize="14" IsVisible="{Binding HasAttachments}" />
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Username}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                <TextBlock Text="{Binding Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" IsVisible="{Binding HasAuthenticator}">
                                                                    <TextBlock Text="{Binding TotpCode}" FontFamily="Consolas" FontWeight="SemiBold" FontSize="12" />
                                                                    <TextBlock Text="{Binding TotpTimeRemaining}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <Border Grid.Column="1" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                    <Grid>
                                        <StackPanel IsVisible="{Binding #Root.DataContext.HasSelectedPasswordDetails, Converter={x:Static local:BoolConverters.Not}}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                                            <ic:FluentIcon Icon="Info" FontSize="32" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding L.PasswordDetails}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding PasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                        </StackPanel>
                                        <local:PasswordDetailDialog DataContext="{Binding SelectedPasswordDetails}" IsVisible="{Binding #Root.DataContext.HasSelectedPasswordDetails}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsArchive}}" RowDefinitions="Auto,*">
                            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding L.Archive}" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ArchivedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Margin="24,0" PlaceholderText="{Binding L.Search}" Text="{Binding SearchText}" VerticalAlignment="Center" />
                            </Grid>

                            <ListBox Grid.Row="1" ItemsSource="{Binding FilteredArchivedPasswords}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:PasswordEntry">
                                        <Border Margin="0,0,0,8" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                            <Grid ColumnDefinitions="Auto,*,Auto" MinHeight="54">
                                                <Border Width="48" Height="48" CornerRadius="24" Background="#5B5FC7">
                                                    <TextBlock Text="{Binding AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Username}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Text="{Binding Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding ArchivedAt, StringFormat='{}{0:g}'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <Button Command="{Binding #Root.DataContext.ShowPasswordDetailsCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.PasswordDetails}">
                                                        <ic:FluentIcon Icon="Info" FontSize="18" />
                                                    </Button>
                                                    <Button Command="{Binding #Root.DataContext.UnarchivePasswordCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.UnarchivePassword}">
                                                        <ic:FluentIcon Icon="ArrowUndo" FontSize="18" />
                                                    </Button>
                                                    <Button Command="{Binding #Root.DataContext.DeletePasswordCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.MoveToRecycleBin}">
                                                        <ic:FluentIcon Icon="Delete" FontSize="18" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsRecycleBin}}" RowDefinitions="Auto,*">
                            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding L.DeletedPasswords}" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding DeletedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Margin="24,0" PlaceholderText="{Binding L.Search}" Text="{Binding SearchText}" VerticalAlignment="Center" />
                            </Grid>

                            <ListBox Grid.Row="1" ItemsSource="{Binding FilteredDeletedPasswords}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:PasswordEntry">
                                        <Border Margin="0,0,0,8" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                            <Grid ColumnDefinitions="Auto,*,Auto" MinHeight="54">
                                                <Border Width="48" Height="48" CornerRadius="24" Background="#737373">
                                                    <TextBlock Text="{Binding AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Username}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Text="{Binding Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding DeletedAt, StringFormat='{}{0:g}'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <Button Command="{Binding #Root.DataContext.ShowPasswordDetailsCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.PasswordDetails}">
                                                        <ic:FluentIcon Icon="Info" FontSize="18" />
                                                    </Button>
                                                    <Button Command="{Binding #Root.DataContext.RestorePasswordCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.RestorePassword}">
                                                        <ic:FluentIcon Icon="ArrowUndo" FontSize="18" />
                                                    </Button>
                                                    <Button Command="{Binding #Root.DataContext.DeletePasswordPermanentlyCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.DeletePermanently}">
                                                        <ic:FluentIcon Icon="DeleteDismiss" FontSize="18" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsTimeline}}" RowDefinitions="Auto,*">
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="{Binding L.Timeline}" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TimelineCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <ListBox Grid.Row="1" ItemsSource="{Binding TimelineEntries}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TimelineEntry">
                                        <Border Margin="0,0,0,8" Padding="14" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <ic:FluentIcon Icon="Clock" FontSize="22" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding TimestampText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsSecurityAnalysis}}" RowDefinitions="Auto,Auto,*">
                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding L.SecurityAnalysis}" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding L.SecurityAnalysisSubtitle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding CompromisedPasswordStatus}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1" Command="{Binding CheckCompromisedPasswordsCommand}" IsEnabled="{Binding !IsCheckingCompromisedPasswords}" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="Shield" FontSize="20" />
                                        <TextBlock Text="{Binding L.CheckCompromisedPasswords}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding SecuritySummaryItems}" Margin="0,0,0,16">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SecuritySummaryItem">
                                        <Border Margin="0,0,8,0" Padding="14" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{Binding Value}" FontSize="24" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Grid.Row="2" RowDefinitions="Auto,*">
                                <TextBlock Text="{Binding SecurityIssueCountText}" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <ListBox Grid.Row="1" ItemsSource="{Binding SecurityIssueItems}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SecurityIssueItem">
                                            <Border Margin="0,0,0,8" Padding="14" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                                    <ic:FluentIcon Icon="Key" FontSize="22" VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Category}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                        <TextBlock Text="{Binding Severity}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                        <Button Command="{Binding #Root.DataContext.ShowPasswordDetailsCommand}" CommandParameter="{Binding Entry}" ToolTip.Tip="{Binding #Root.DataContext.L.PasswordDetails}">
                                                            <ic:FluentIcon Icon="Info" FontSize="18" />
                                                        </Button>
                                                        <Button Command="{Binding #Root.DataContext.EditPasswordCommand}" CommandParameter="{Binding Entry}" ToolTip.Tip="{Binding #Root.DataContext.L.EditPassword}">
                                                            <ic:FluentIcon Icon="Edit" FontSize="18" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsTotp}}" RowDefinitions="Auto,*">
                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding L.TwoStepVerification}" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding TotpCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding L.TotpPageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                </StackPanel>
                                <Button Grid.Column="1" Command="{Binding AddTotpCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="Add" FontSize="20" />
                                        <TextBlock Text="{Binding L.AddAuthenticator}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Grid Grid.Row="1">
                                <ListBox ItemsSource="{Binding TotpItems}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:SecureItem">
                                            <Border Margin="0,0,0,8" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{Binding #Root.DataContext.L.Copy}" Command="{Binding #Root.DataContext.CopyTotpCommand}" CommandParameter="{Binding}">
                                                            <MenuItem.Icon>
                                                                <ic:FluentIcon Icon="Copy" FontSize="16" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Header="{Binding #Root.DataContext.L.Edit}" Command="{Binding #Root.DataContext.EditTotpCommand}" CommandParameter="{Binding}">
                                                            <MenuItem.Icon>
                                                                <ic:FluentIcon Icon="Edit" FontSize="16" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Header="{Binding #Root.DataContext.L.Favorite}" Command="{Binding #Root.DataContext.ToggleTotpFavoriteCommand}" CommandParameter="{Binding}">
                                                            <MenuItem.Icon>
                                                                <ic:FluentIcon Icon="Star" FontSize="16" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <MenuItem Header="{Binding #Root.DataContext.L.Select}" Command="{Binding #Root.DataContext.ToggleTotpSelectionCommand}" CommandParameter="{Binding}">
                                                            <MenuItem.Icon>
                                                                <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <Separator />
                                                        <MenuItem Header="{Binding #Root.DataContext.L.Delete}" Command="{Binding #Root.DataContext.DeleteTotpCommand}" CommandParameter="{Binding}">
                                                            <MenuItem.Icon>
                                                                <ic:FluentIcon Icon="Delete" FontSize="16" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" MinHeight="58">
                                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                                    <Grid Grid.Column="1" Width="52" Height="52" VerticalAlignment="Center">
                                                        <ProgressBar Width="52" Height="8" Value="{Binding TotpProgress}" Minimum="0" Maximum="100" VerticalAlignment="Bottom" />
                                                        <Border Width="46" Height="46" CornerRadius="23" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                                            <ic:FluentIcon Icon="Key" FontSize="20" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </Grid>
                                                    <StackPanel Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                            <ic:FluentIcon Icon="Star" FontSize="16" Foreground="{DynamicResource SystemFillColorCautionBrush}" IsVisible="{Binding IsFavorite}" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Notes}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="3" Text="{Binding TotpCode}" FontSize="28" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                                                    <TextBlock Grid.Column="4" Text="{Binding TotpTimeRemaining}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                        <Button Command="{Binding #Root.DataContext.CopyTotpCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.CopyCode}">
                                                            <ic:FluentIcon Icon="Copy" FontSize="18" />
                                                        </Button>
                                                        <Button Command="{Binding #Root.DataContext.EditTotpCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.Edit}">
                                                            <ic:FluentIcon Icon="Edit" FontSize="18" />
                                                        </Button>
                                                        <Button Command="{Binding #Root.DataContext.ToggleTotpFavoriteCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.Favorite}">
                                                            <ic:FluentIcon Icon="Star" FontSize="18" />
                                                        </Button>
                                                        <Button Command="{Binding #Root.DataContext.DeleteTotpCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.Delete}">
                                                            <ic:FluentIcon Icon="Delete" FontSize="18" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Padding="16,12"
                                        CornerRadius="12"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,24"
                                        IsVisible="{Binding HasSelectedTotpItems}">
                                    <StackPanel Orientation="Horizontal" Spacing="14">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                                            <TextBlock Text="{Binding SelectedTotpCountText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <Border Width="1" Height="24" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                                        <Button Command="{Binding FavoriteSelectedTotpCommand}" ToolTip.Tip="{Binding L.BatchFavorite}">
                                            <ic:FluentIcon Icon="Star" FontSize="18" />
                                        </Button>
                                        <Button Command="{Binding DeleteSelectedTotpCommand}" ToolTip.Tip="{Binding L.BatchDelete}">
                                            <ic:FluentIcon Icon="Delete" FontSize="18" />
                                        </Button>
                                        <Border Width="1" Height="24" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                                        <Button Command="{Binding ClearTotpSelectionCommand}" Content="{Binding L.Cancel}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsCards}}" RowDefinitions="Auto,*">
                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding L.Wallet}" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding WalletCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding L.WalletPageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                </StackPanel>
                                <Button Grid.Column="1" Command="{Binding AddWalletItemCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="Add" FontSize="20" />
                                        <TextBlock Text="{Binding L.AddItem}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Grid Grid.Row="1" ColumnDefinitions="2*,3*" ColumnSpacing="16">
                                <Grid>
                                    <ListBox ItemsSource="{Binding WalletItems}" SelectedItem="{Binding SelectedWalletItem}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:SecureItem">
                                                <Border Margin="0,0,0,8" Padding="16" CornerRadius="8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.PasswordDetails}" Command="{Binding #Root.DataContext.ShowWalletDetailsCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Info" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Edit}" Command="{Binding #Root.DataContext.EditWalletItemCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Edit" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Select}" Command="{Binding #Root.DataContext.ToggleWalletSelectionCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator />
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Delete}" Command="{Binding #Root.DataContext.DeleteWalletItemCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Delete" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" MinHeight="56">
                                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                                        <Border Grid.Column="1" Width="48" Height="48" CornerRadius="8" Background="{DynamicResource AccentFillColorDefaultBrush}">
                                                            <ic:FluentIcon Icon="WalletCreditCard" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <StackPanel Grid.Column="2" Margin="14,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding Notes}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                            <Button Command="{Binding #Root.DataContext.ShowWalletDetailsCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.PasswordDetails}">
                                                                <ic:FluentIcon Icon="Info" FontSize="18" />
                                                            </Button>
                                                            <Button Command="{Binding #Root.DataContext.EditWalletItemCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.Edit}">
                                                                <ic:FluentIcon Icon="Edit" FontSize="18" />
                                                            </Button>
                                                            <Button Command="{Binding #Root.DataContext.DeleteWalletItemCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.Delete}">
                                                                <ic:FluentIcon Icon="Delete" FontSize="18" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Border Padding="16,12"
                                            CornerRadius="12"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1"
                                            Background="{DynamicResource CardBackgroundBrush}"
                                            VerticalAlignment="Bottom"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,24"
                                            IsVisible="{Binding HasSelectedWalletItems}">
                                        <StackPanel Orientation="Horizontal" Spacing="14">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                                                <TextBlock Text="{Binding SelectedWalletCountText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <Border Width="1" Height="24" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                                            <Button Command="{Binding DeleteSelectedWalletItemsCommand}" ToolTip.Tip="{Binding L.BatchDelete}">
                                                <ic:FluentIcon Icon="Delete" FontSize="18" />
                                            </Button>
                                            <Border Width="1" Height="24" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                                            <Button Command="{Binding ClearWalletSelectionCommand}" Content="{Binding L.Cancel}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Grid.Column="1" Padding="18" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                    <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding HasSelectedWalletItem}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                            <Border Width="56" Height="56" CornerRadius="10" Background="{DynamicResource AccentFillColorDefaultBrush}">
                                                <ic:FluentIcon Icon="WalletCreditCard" FontSize="26" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SelectedWalletDetails.Title}" FontSize="22" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding SelectedWalletDetails.KindText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Command="{Binding EditWalletItemCommand}" CommandParameter="{Binding SelectedWalletItem}" ToolTip.Tip="{Binding L.Edit}">
                                                <ic:FluentIcon Icon="Edit" FontSize="18" />
                                            </Button>
                                        </Grid>

                                        <ScrollViewer Grid.Row="1" Margin="0,18,0,0">
                                            <StackPanel Spacing="16">
                                                <Border Padding="20" CornerRadius="12" Background="#172F7DFF" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" MaxWidth="420" HorizontalAlignment="Left">
                                                    <Grid RowDefinitions="Auto,*,Auto" MinHeight="170">
                                                        <TextBlock Text="{Binding SelectedWalletDetails.KindText}" FontWeight="SemiBold" />
                                                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="4">
                                                            <TextBlock Text="{Binding SelectedWalletDetails.PrimaryText}" FontSize="24" FontFamily="Consolas" FontWeight="Bold" />
                                                            <TextBlock Text="{Binding SelectedWalletDetails.SecondaryText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Row="2" Text="{Binding SelectedWalletDetails.ExpiryText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </Grid>
                                                </Border>

                                                <ItemsControl ItemsSource="{Binding SelectedWalletDetails.Fields}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:WalletFieldDisplayItem">
                                                            <Grid ColumnDefinitions="130,*" Margin="0,0,0,8">
                                                                <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="{Binding L.DocumentPhotos}" FontWeight="SemiBold" />
                                                    <ItemsControl ItemsSource="{Binding SelectedWalletDetails.ImagePaths}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Padding="10" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Margin="0,0,0,8">
                                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Text="{Binding L.NoDocumentPhotos}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" IsVisible="{Binding !SelectedWalletDetails.HasImages}" />
                                                </StackPanel>

                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding L.Notes}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SelectedWalletDetails.Notes}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
                                            <Button Command="{Binding DeleteWalletItemCommand}" CommandParameter="{Binding SelectedWalletItem}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <ic:FluentIcon Icon="Delete" FontSize="18" />
                                                    <TextBlock Text="{Binding L.Delete}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <ScrollViewer IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsSettings}}">
                            <StackPanel Spacing="16" MaxWidth="900">
                                <TextBlock Text="{Binding L.SettingsSubtitle}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <fa:FASettingsExpander Header="{Binding L.General}" Description="{Binding L.GeneralSettingsDescription}" IsExpanded="True">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Setting" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.Language}" Description="{Binding L.LanguageDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="220" ItemsSource="{Binding LanguageOptions}" SelectedValue="{Binding SettingsLanguage}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.Theme}" Description="{Binding L.ThemeDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="220" ItemsSource="{Binding ThemeOptions}" SelectedValue="{Binding SettingsTheme}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.StartupView}" Description="{Binding L.StartupViewDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="220" ItemsSource="{Binding StartupSectionOptions}" SelectedValue="{Binding StartupSection}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.Security}" Description="{Binding L.SecuritySettingsDescription}" IsExpanded="True">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Permissions" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.AutoLock}" Description="{Binding L.AutoLockDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding AutoLockEnabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.AutoLockAfter}" Description="{Binding L.AutoLockAfterDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="180" ItemsSource="{Binding AutoLockMinuteOptions}" SelectedValue="{Binding AutoLockMinutes}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.ClearClipboard}" Description="{Binding L.ClearClipboardDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding ClearClipboardEnabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.ClearClipboardAfter}" Description="{Binding L.ClearClipboardAfterDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="180" ItemsSource="{Binding ClipboardSecondOptions}" SelectedValue="{Binding ClipboardClearSeconds}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.RequirePasswordBeforeExport}" Description="{Binding L.RequirePasswordBeforeExportDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding RequirePasswordBeforeExport}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding ChangeMasterPasswordTitle}" Description="{Binding ChangeMasterPasswordDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Spacing="8" Margin="16,0,0,0" MaxWidth="420">
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding CurrentMasterPasswordText}" Text="{Binding CurrentMasterPassword}" IsEnabled="{Binding !IsChangingMasterPassword}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding NewMasterPasswordText}" Text="{Binding NewMasterPassword}" IsEnabled="{Binding !IsChangingMasterPassword}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding ConfirmNewMasterPasswordText}" Text="{Binding ConfirmNewMasterPassword}" IsEnabled="{Binding !IsChangingMasterPassword}" />
                                                    <Button Command="{Binding ChangeMasterPasswordCommand}" IsEnabled="{Binding !IsChangingMasterPassword}" HorizontalAlignment="Right">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Key" FontSize="18" />
                                                            <TextBlock Text="{Binding ChangeMasterPasswordActionText}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding SecurityRecoveryTitle}" Description="{Binding SecurityRecoveryDescription}" IsExpanded="False">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="ProtectedDocument" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding SecurityRecoveryEnabledText}" Description="{Binding SecurityRecoveryStatusText}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding SecurityRecoveryEnabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding SecurityQuestion1Text}" Description="{Binding SecurityRecoveryDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Spacing="8" Margin="16,0,0,0" MaxWidth="420">
                                                    <ComboBox Width="360" ItemsSource="{Binding SecurityQuestionOptions}" SelectedValue="{Binding SecurityQuestion1Id}" SelectedValueBinding="{Binding Value}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:SettingsChoice">
                                                                <TextBlock Text="{Binding Label}" TextWrapping="Wrap" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBox IsVisible="{Binding IsSecurityQuestion1Custom}" PlaceholderText="{Binding CustomSecurityQuestionText}" Text="{Binding SecurityQuestion1CustomText}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding SecurityQuestionAnswerText}" Text="{Binding SecurityQuestion1Answer}" />
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding SecurityQuestion2Text}" Description="{Binding SecurityRecoveryDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Spacing="8" Margin="16,0,0,0" MaxWidth="420">
                                                    <ComboBox Width="360" ItemsSource="{Binding SecurityQuestionOptions}" SelectedValue="{Binding SecurityQuestion2Id}" SelectedValueBinding="{Binding Value}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:SettingsChoice">
                                                                <TextBlock Text="{Binding Label}" TextWrapping="Wrap" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBox IsVisible="{Binding IsSecurityQuestion2Custom}" PlaceholderText="{Binding CustomSecurityQuestionText}" Text="{Binding SecurityQuestion2CustomText}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding SecurityQuestionAnswerText}" Text="{Binding SecurityQuestion2Answer}" />
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding SaveSecurityQuestionsText}" Description="{Binding SecurityRecoveryStatusText}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <Button Command="{Binding SaveSecurityQuestionsCommand}">
                                                    <TextBlock Text="{Binding SaveSecurityQuestionsText}" />
                                                </Button>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding ResetMasterPasswordTitle}" Description="{Binding ResetMasterPasswordDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Spacing="8" Margin="16,0,0,0" MaxWidth="460">
                                                    <TextBlock Text="{Binding SecurityRecoveryQuestion1PromptText}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding SecurityQuestionAnswerText}" Text="{Binding SecurityRecoveryAnswer1}" IsEnabled="{Binding CanRunResetMasterPassword}" />
                                                    <TextBlock Text="{Binding SecurityRecoveryQuestion2PromptText}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding SecurityQuestionAnswerText}" Text="{Binding SecurityRecoveryAnswer2}" IsEnabled="{Binding CanRunResetMasterPassword}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding NewMasterPasswordText}" Text="{Binding RecoveryNewMasterPassword}" IsEnabled="{Binding CanRunResetMasterPassword}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding ConfirmNewMasterPasswordText}" Text="{Binding RecoveryConfirmNewMasterPassword}" IsEnabled="{Binding CanRunResetMasterPassword}" />
                                                    <Button Command="{Binding ResetMasterPasswordWithSecurityQuestionsCommand}" IsEnabled="{Binding CanRunResetMasterPassword}" HorizontalAlignment="Right">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Key" FontSize="18" />
                                                            <TextBlock Text="{Binding ResetMasterPasswordActionText}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.DataManagement}" Description="{Binding L.DataManagementDescription}" IsExpanded="False">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Save" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.ImportData}" Description="{Binding L.ImportDataDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FilePickerIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="240" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <Button Command="{Binding ImportMonicaJsonFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Folder" FontSize="18" />
                                                            <TextBlock Text="{Binding L.ImportMonicaJson}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding ImportPasswordCsvFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Folder" FontSize="18" />
                                                            <TextBlock Text="{Binding L.ImportPasswordCsv}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding ImportAegisJsonFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Folder" FontSize="18" />
                                                            <TextBlock Text="{Binding L.ImportAegisJson}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding ImportTotpCsvFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Folder" FontSize="18" />
                                                            <TextBlock Text="{Binding L.ImportTotpCsv}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.ExportData}" Description="{Binding L.ExportDataDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FilePickerIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="240" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <Button Command="{Binding SaveMonicaJsonExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Save" FontSize="18" />
                                                            <TextBlock Text="{Binding L.SaveJsonExport}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding SavePasswordCsvExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Save" FontSize="18" />
                                                            <TextBlock Text="{Binding L.SaveCsvExport}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding SaveTotpCsvExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Save" FontSize="18" />
                                                            <TextBlock Text="{Binding L.SaveTotpCsvExport}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding SaveAegisJsonExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Save" FontSize="18" />
                                                            <TextBlock Text="{Binding L.SaveAegisExport}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.WebDav}" Description="{Binding L.RemoteSyncDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <Button Command="{Binding SelectSectionCommand}" CommandParameter="Sync" Margin="16,0,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                                        <TextBlock Text="{Binding L.SyncAndBackup}" />
                                                    </StackPanel>
                                                </Button>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.Desktop}" Description="{Binding L.DesktopSettingsDescription}" IsExpanded="True">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="ContactInfo" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.MinimizeToTray}" Description="{Binding L.MinimizeToTrayDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TrayIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="260" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <ToggleSwitch IsChecked="{Binding MinimizeToTray}" IsEnabled="{Binding CanUseTrayIntegration}" ToolTip.Tip="{Binding TrayIntegrationStatusText}" />
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.QuickSearch}" Description="{Binding L.QuickSearchDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding QuickSearchEnabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.QuickSearchHotkey}" Description="{Binding L.QuickSearchHotkeyDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding GlobalHotkeyIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="260" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <TextBox Width="220" Text="{Binding QuickSearchHotkey}" IsEnabled="{Binding CanUseGlobalHotkeyIntegration}" ToolTip.Tip="{Binding GlobalHotkeyIntegrationStatusText}" />
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.BrowserIntegration}" Description="{Binding L.BrowserIntegrationDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding BrowserBridgeIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="260" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <ToggleSwitch IsChecked="{Binding BrowserIntegrationEnabled}" IsEnabled="{Binding CanUseBrowserBridgeIntegration}" ToolTip.Tip="{Binding BrowserBridgeIntegrationStatusText}" />
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.BrowserIntegrationPort}" Description="{Binding L.BrowserIntegrationPortDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <NumericUpDown Width="180" Minimum="1024" Maximum="65535" Increment="1" Value="{Binding BrowserIntegrationPort}" IsEnabled="{Binding CanUseBrowserBridgeIntegration}" ToolTip.Tip="{Binding BrowserBridgeIntegrationStatusText}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.CompactPasswordList}" Description="{Binding L.CompactPasswordListDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding CompactPasswordList}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding PlatformIntegrationsTitle}" Description="{Binding PlatformIntegrationSummaryText}" IsExpanded="False" ItemsSource="{Binding PlatformIntegrationCapabilities}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Permissions" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LocalizedPlatformIntegrationCapability">
                                            <fa:FASettingsExpanderItem Content="{Binding Title}" Description="{Binding Description}">
                                                <fa:FASettingsExpanderItem.Footer>
                                                    <StackPanel Spacing="2" Margin="16,0,0,0" MinWidth="160" MaxWidth="360">
                                                        <TextBlock Text="{Binding Status}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding UnsupportedReason}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" IsVisible="{Binding HasUnsupportedReason}" />
                                                    </StackPanel>
                                                </fa:FASettingsExpanderItem.Footer>
                                            </fa:FASettingsExpanderItem>
                                        </DataTemplate>
                                    </fa:FASettingsExpander.ItemTemplate>
                                </fa:FASettingsExpander>

                                <fa:FAInfoBar IsOpen="True" Severity="Informational" Title="{Binding L.DesktopEquivalents}" Message="{Binding L.DesktopEquivalentsMessage}" />
                                <fa:FASettingsExpander Header="{Binding L.FeatureParityMap}" Description="{Binding L.FeatureParityMapDescription}" IsExpanded="True" ItemsSource="{Binding Capabilities}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Sync" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LocalizedPlatformCapability">
                                            <fa:FASettingsExpanderItem Content="{Binding Title}" Description="{Binding Description}">
                                                <fa:FASettingsExpanderItem.Footer>
                                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                        <StackPanel MinWidth="132" Spacing="2">
                                                            <TextBlock Text="{Binding Status}" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding ToggleStatus}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            <TextBlock Text="{Binding UnsupportedReason}" FontSize="12" TextWrapping="Wrap" MaxWidth="280" Foreground="{DynamicResource TextFillColorSecondaryBrush}" IsVisible="{Binding HasUnsupportedReason}" />
                                                        </StackPanel>
                                                        <ToggleSwitch IsChecked="{Binding IsEnabled, Mode=TwoWay}" IsEnabled="{Binding CanToggle}" ToolTip.Tip="{Binding ToggleStatus}" />
                                                    </StackPanel>
                                                </fa:FASettingsExpanderItem.Footer>
                                            </fa:FASettingsExpanderItem>
                                        </DataTemplate>
                                    </fa:FASettingsExpander.ItemTemplate>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding AboutTitle}" Description="{Binding AboutDescription}" IsExpanded="False">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="ContactInfo" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="Monica" Description="{Binding AppVersionText}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <Image Source="/Assets/Logo.png" Width="44" Height="44" />
                                                    <StackPanel Spacing="2" MaxWidth="320">
                                                        <TextBlock Text="{Binding AppVersionLabel}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding AppVersionText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding GitHubRepositoryLabel}" Description="{Binding RepositoryUrlText}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ExternalLinksIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="260" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <Button Command="{Binding OpenGitHubRepositoryCommand}" IsEnabled="{Binding CanOpenExternalLinks}" ToolTip.Tip="{Binding ExternalLinksIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Link" FontSize="18" />
                                                            <TextBlock Text="{Binding OpenRepositoryText}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding DangerZoneTitle}" Description="{Binding DangerZoneDescription}" IsExpanded="False">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Delete" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding ClearVaultDataTitle}" Description="{Binding ClearVaultDataDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Spacing="8" Margin="16,0,0,0" MaxWidth="520">
                                                    <TextBlock Text="{Binding ClearVaultConfirmationInstructionText}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                                                    <TextBox PlaceholderText="{Binding ClearVaultConfirmationInstructionText}" Text="{Binding DangerZoneConfirmationText}" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                                        <Button Command="{Binding ClearVaultDataCommand}" CommandParameter="Passwords">
                                                            <TextBlock Text="{Binding ClearPasswordsOnlyText}" />
                                                        </Button>
                                                        <Button Command="{Binding ClearVaultDataCommand}" CommandParameter="SecureItems">
                                                            <TextBlock Text="{Binding ClearSecureItemsOnlyText}" />
                                                        </Button>
                                                        <Button Background="{DynamicResource SystemFillColorCriticalBrush}" Command="{Binding ClearVaultDataCommand}" CommandParameter="All">
                                                            <TextBlock Text="{Binding ClearAllVaultDataText}" />
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsDatabaseManagement}}">
                            <StackPanel Spacing="16" MaxWidth="980">
                                <TextBlock Text="{Binding L.LocalDatabaseDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <Border Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                        <StackPanel Spacing="12">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Database" FontSize="20" />
                                                <TextBlock Text="{Binding L.LocalDatabase}" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding LocalDatabaseSummaryText}" FontSize="24" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.LocalDatabaseDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                                <Button Command="{Binding LoadCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                                        <TextBlock Text="{Binding L.Refresh}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Command="{Binding SelectSectionCommand}" CommandParameter="Passwords">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Key" FontSize="18" />
                                                        <TextBlock Text="{Binding L.Passwords}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                        <StackPanel Spacing="12">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                <TextBlock Text="{Binding L.ExternalDatabases}" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding L.ExternalDatabasesDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                                <Button Command="{Binding SelectSectionCommand}" CommandParameter="Sync" HorizontalContentAlignment="Center">KDBX</Button>
                                                <Button Grid.Column="1" Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx" HorizontalContentAlignment="Center">MDBX</Button>
                                                <Button Grid.Column="2" Command="{Binding SelectSectionCommand}" CommandParameter="Sync" HorizontalContentAlignment="Center">Bitwarden</Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <fa:FASettingsExpander Header="{Binding L.CloudAndLocalVaults}" Description="{Binding L.CloudAndLocalVaultsDescription}" IsExpanded="True">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Folder" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.MdbxDatabaseCount}" Description="{Binding MdbxDatabaseCountText}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <Button Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Database" FontSize="20" />
                                                        <TextBlock Text="{Binding L.MdbxVaults}" />
                                                    </StackPanel>
                                                </Button>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                        <fa:FASettingsExpanderItem Content="{Binding L.MdbxLocalCache}" Description="{Binding L.MdbxLocalCacheDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding MdbxLocalCacheEnabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                        <fa:FASettingsExpanderItem Content="{Binding L.EnableOneDrive}" Description="{Binding L.EnableOneDriveDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding OneDriveEnabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <Border Padding="0" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                    <Grid RowDefinitions="Auto,*" MinHeight="220">
                                        <Grid Margin="18,16,18,10" ColumnDefinitions="*,Auto">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding L.RegisteredDatabases}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding VaultSourceCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Command="{Binding LoadCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                                    <TextBlock Text="{Binding L.Refresh}" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <ListBox Grid.Row="1" ItemsSource="{Binding VaultSources}" SelectionMode="Single" Margin="8,0,8,8">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:VaultSourceDisplayItem">
                                                    <Border Padding="8,10">
                                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="3">
                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                                            <Border Grid.Column="1" Grid.RowSpan="2" Padding="8,3" CornerRadius="10" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding Kind}" FontSize="12" />
                                                            </Border>
                                                            <TextBlock Grid.Row="1" Text="{Binding LocalPath}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                            <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                                <TextBlock Text="{Binding RemoteUrl}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="1" Text="{Binding SyncStatus}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <fa:FASettingsExpander Header="{Binding L.FeatureParityMap}" Description="{Binding L.FeatureParityMapDescription}" IsExpanded="False" ItemsSource="{Binding Capabilities}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Sync" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LocalizedPlatformCapability">
                                            <fa:FASettingsExpanderItem Content="{Binding Title}" Description="{Binding Description}">
                                                <fa:FASettingsExpanderItem.Footer>
                                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                        <StackPanel MinWidth="132" Spacing="2">
                                                            <TextBlock Text="{Binding Status}" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding ToggleStatus}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            <TextBlock Text="{Binding UnsupportedReason}" FontSize="12" TextWrapping="Wrap" MaxWidth="280" Foreground="{DynamicResource TextFillColorSecondaryBrush}" IsVisible="{Binding HasUnsupportedReason}" />
                                                        </StackPanel>
                                                        <ToggleSwitch IsChecked="{Binding IsEnabled, Mode=TwoWay}" IsEnabled="{Binding CanToggle}" ToolTip.Tip="{Binding ToggleStatus}" />
                                                    </StackPanel>
                                                </fa:FASettingsExpanderItem.Footer>
                                            </fa:FASettingsExpanderItem>
                                        </DataTemplate>
                                    </fa:FASettingsExpander.ItemTemplate>
                                </fa:FASettingsExpander>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <fa:FASettingsExpander Header="{Binding L.ImportData}" Description="{Binding L.ImportDataDescription}" IsExpanded="False">
                                        <fa:FASettingsExpander.IconSource>
                                            <fa:FASymbolIconSource Symbol="Folder" />
                                        </fa:FASettingsExpander.IconSource>
                                        <StackPanel Spacing="8">
                                            <TextBox Text="{Binding ImportJsonText}" PlaceholderText="{Binding L.ImportJsonWatermark}" AcceptsReturn="True" MinHeight="100" TextWrapping="Wrap" />
                                            <Button Command="{Binding ImportDataCommand}" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                    <TextBlock Text="{Binding L.Import}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </fa:FASettingsExpander>

                                    <fa:FASettingsExpander Grid.Column="1" Header="{Binding L.ExportData}" Description="{Binding L.ExportDataDescription}" IsExpanded="False">
                                        <fa:FASettingsExpander.IconSource>
                                            <fa:FASymbolIconSource Symbol="ProtectedDocument" />
                                        </fa:FASettingsExpander.IconSource>
                                        <StackPanel Spacing="8">
                                            <Button Command="{Binding ExportDataCommand}" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                                                    <TextBlock Text="{Binding L.Export}" />
                                                </StackPanel>
                                            </Button>
                                            <TextBox Text="{Binding ExportPreview}" AcceptsReturn="True" MinHeight="100" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </fa:FASettingsExpander>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsMdbx}}">
                            <StackPanel Spacing="16" MaxWidth="980">
                                <TextBlock Text="{Binding L.MdbxVaultsDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                                    <Border Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                        <StackPanel Spacing="12">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Database" FontSize="20" />
                                                <TextBlock Text="{Binding L.MdbxLocalSource}" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding MdbxLocalCountText}" FontSize="22" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding MdbxLocalSourceStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Button Command="{Binding CreateMdbxVaultCommand}" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Database" FontSize="18" />
                                                    <TextBlock Text="{Binding L.CreateLocalMdbxVault}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                        <StackPanel Spacing="12">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                <TextBlock Text="{Binding L.MdbxWebDavSource}" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding MdbxWebDavCountText}" FontSize="22" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding MdbxWebDavSourceStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                                <Button Command="{Binding CreateWebDavMdbxVaultCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="18" />
                                                        <TextBlock Text="{Binding L.RegisterMdbxSource}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Command="{Binding ConfigureMdbxRemoteSourcesCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Database" FontSize="18" />
                                                        <TextBlock Text="{Binding L.Configure}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                        <StackPanel Spacing="12">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                <TextBlock Text="{Binding L.MdbxOneDriveSource}" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding MdbxOneDriveCountText}" FontSize="22" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding MdbxOneDriveSourceStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                                <Button Command="{Binding CreateOneDriveMdbxVaultCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="18" />
                                                        <TextBlock Text="{Binding L.RegisterMdbxSource}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Command="{Binding ConfigureMdbxRemoteSourcesCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Database" FontSize="18" />
                                                        <TextBlock Text="{Binding L.Configure}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="2*,*" ColumnSpacing="12">
                                    <Border Padding="0" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                        <Grid RowDefinitions="Auto,*" MinHeight="320">
                                            <Grid Margin="18,16,18,10" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Text="{Binding L.RegisteredMdbxVaults}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding MdbxDatabaseCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Command="{Binding RefreshMdbxVaultsCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                                        <TextBlock Text="{Binding L.Refresh}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <Grid Grid.Row="1">
                                                <TextBlock Text="{Binding L.NoMdbxVaults}"
                                                           IsVisible="{Binding !HasMdbxDatabases}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <ListBox ItemsSource="{Binding MdbxDatabaseItems}" IsVisible="{Binding HasMdbxDatabases}" SelectionMode="Single" Margin="8,0,8,8">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:MdbxDatabaseDisplayItem">
                                                            <Border Padding="8,10">
                                                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                                        <Border Padding="8,2" CornerRadius="10" Background="{DynamicResource LayerFillColorSubtleBrush}" IsVisible="{Binding IsDefault}">
                                                                            <TextBlock Text="{Binding #Root.DataContext.L.Default}" FontSize="12" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <Border Grid.Column="1" Padding="8,3" CornerRadius="10" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Top">
                                                                        <TextBlock Text="{Binding Source}" FontSize="12" />
                                                                    </Border>
                                                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Description}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                    <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                                        <TextBlock Text="{Binding #Root.DataContext.L.LocalPath}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding LocalPath}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                    </Grid>
                                                                    <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                                        <TextBlock Text="{Binding SyncStatus}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                        <Button Grid.Column="1" Command="{Binding #Root.DataContext.SetDefaultMdbxDatabaseCommand}" CommandParameter="{Binding}" IsEnabled="{Binding !IsDefault}">
                                                                            <TextBlock Text="{Binding #Root.DataContext.L.SetDefault}" />
                                                                        </Button>
                                                                        <Button Grid.Column="2" Command="{Binding #Root.DataContext.OpenMdbxDatabaseCommand}" CommandParameter="{Binding}">
                                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                                <ic:FluentIcon Icon="ArrowDownload" FontSize="18" />
                                                                                <TextBlock Text="{Binding #Root.DataContext.L.Open}" />
                                                                            </StackPanel>
                                                                        </Button>
                                                                    </Grid>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="12">
                                        <fa:FASettingsExpander Header="{Binding L.MdbxRuntime}" Description="{Binding MdbxRuntimeSummaryText}" IsExpanded="True">
                                            <fa:FASettingsExpander.IconSource>
                                                <fa:FASymbolIconSource Symbol="Library" />
                                            </fa:FASettingsExpander.IconSource>
                                            <fa:FASettingsExpander.Items>
                                                <fa:FASettingsExpanderItem Content="{Binding L.MdbxLocalCache}" Description="{Binding L.MdbxLocalCacheDescription}">
                                                    <fa:FASettingsExpanderItem.Footer>
                                                        <ToggleSwitch IsChecked="{Binding MdbxLocalCacheEnabled}" />
                                                    </fa:FASettingsExpanderItem.Footer>
                                                </fa:FASettingsExpanderItem>
                                                <fa:FASettingsExpanderItem Content="{Binding L.MdbxSecurity}" Description="{Binding MdbxSecuritySummaryText}" />
                                            </fa:FASettingsExpander.Items>
                                        </fa:FASettingsExpander>

                                        <fa:FASettingsExpander Header="{Binding L.MdbxAndroidParity}" Description="{Binding L.MdbxAndroidParityDescription}" IsExpanded="False">
                                            <fa:FASettingsExpander.IconSource>
                                                <fa:FASymbolIconSource Symbol="Sync" />
                                            </fa:FASettingsExpander.IconSource>
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="{Binding L.MdbxAndroidParityLocal}" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding L.MdbxAndroidParityRemote}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </fa:FASettingsExpander>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsSync}}">
                            <StackPanel Spacing="16" MaxWidth="900">
                                <TextBlock Text="{Binding L.SyncSubtitle}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                <Border Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Border Width="12" Height="12" CornerRadius="6" Background="{DynamicResource AccentFillColorDefaultBrush}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock Text="{Binding L.WebDavConnection}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding WebDavConnectionStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                            <Button Command="{Binding CreateWebDavBackupCommand}" IsEnabled="{Binding !IsWebDavBusy}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowUpload" FontSize="18" />
                                                    <TextBlock Text="{Binding L.BackupNow}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding RestoreLatestWebDavBackupCommand}" IsEnabled="{Binding !IsWebDavBusy}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="18" />
                                                    <TextBlock Text="{Binding L.RestoreLatest}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding SelectSectionCommand}" CommandParameter="DatabaseManagement">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Database" FontSize="18" />
                                                    <TextBlock Text="{Binding L.DatabaseManagement}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <fa:FASettingsExpander Header="{Binding L.RemoteSync}" Description="{Binding L.RemoteSyncDescription}" IsExpanded="True">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Sync" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.EnableWebDav}" Description="{Binding L.EnableWebDavDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding WebDavEnabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.WebDavServerUrl}" Description="{Binding L.WebDavServerUrlDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <TextBox Width="360" Text="{Binding WebDavServerUrl}" PlaceholderText="https://dav.example.com" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.WebDavUsername}" Description="{Binding L.WebDavUsernameDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <TextBox Width="260" Text="{Binding WebDavUsername}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.WebDavPassword}" Description="{Binding L.WebDavPasswordDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <TextBox Width="260" PasswordChar="*" Text="{Binding WebDavPassword}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.WebDavRemotePath}" Description="{Binding L.WebDavRemotePathDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <TextBox Width="260" Text="{Binding WebDavRemotePath}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.SyncOnStartup}" Description="{Binding L.SyncOnStartupDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding WebDavSyncOnStartup}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.SyncAfterChanges}" Description="{Binding L.SyncAfterChangesDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding WebDavSyncAfterChanges}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.ConflictStrategy}" Description="{Binding L.ConflictStrategyDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="220" ItemsSource="{Binding ConflictStrategyOptions}" SelectedValue="{Binding SyncConflictStrategy}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.WebDavBackupOptions}" Description="{Binding WebDavBackupOptionsSummaryText}" IsExpanded="True">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Save" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludePasswords}" Description="{Binding L.WebDavBackupOptionsDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludePasswords}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeTotp}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeTotp}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeNotes}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeNotes}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeCards}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeCards}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeDocuments}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeDocuments}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeImages}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeImages}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeCategories}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeCategories}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.EncryptBackup}" Description="{Binding L.EncryptBackupDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding WebDavBackupEncryptionEnabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.BackupEncryptionPassword}" Description="{Binding L.BackupEncryptionPasswordDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <TextBox Width="260" PasswordChar="*" Text="{Binding WebDavBackupEncryptionPassword}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <Border Padding="0" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                    <Grid RowDefinitions="Auto,*" MinHeight="260">
                                        <Grid Margin="18,16,18,10" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding L.BackupHistory}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding WebDavBackupHistoryCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Command="{Binding LoadWebDavBackupsCommand}" IsEnabled="{Binding !IsLoadingWebDavBackups}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                                    <TextBlock Text="{Binding L.Refresh}" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <TextBlock Text="{Binding L.NoBackupsFound}"
                                                       IsVisible="{Binding !HasWebDavBackupHistory}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <ListBox ItemsSource="{Binding WebDavBackupHistory}" IsVisible="{Binding HasWebDavBackupHistory}" SelectionMode="Single" Margin="8,0,8,8">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:WebDavBackupHistoryItem">
                                                        <Border Padding="8,10">
                                                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="3">
                                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                                                <TextBlock Grid.Column="1" Text="{Binding SizeText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                <Button Grid.Column="2" Grid.RowSpan="2" Command="{Binding #Root.DataContext.RestoreWebDavBackupCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.OperationRestore}">
                                                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="18" />
                                                                </Button>
                                                                <Button Grid.Column="3" Grid.RowSpan="2" Command="{Binding #Root.DataContext.DeleteWebDavBackupCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.Delete}">
                                                                    <ic:FluentIcon Icon="Delete" FontSize="18" />
                                                                </Button>
                                                                <TextBlock Grid.Row="1" Text="{Binding DateString}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Path}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="260" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <fa:FASettingsExpander Header="{Binding L.CloudAndLocalVaults}" Description="{Binding L.CloudAndLocalVaultsDescription}" IsExpanded="True">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Folder" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.EnableOneDrive}" Description="{Binding L.EnableOneDriveDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding OneDriveEnabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.MdbxLocalCache}" Description="{Binding L.MdbxLocalCacheDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding MdbxLocalCacheEnabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.CreateMdbxMetadata}" Description="{Binding L.CreateMdbxMetadataDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <Button Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Database" FontSize="20" />
                                                        <TextBlock Text="{Binding L.MdbxVaults}" />
                                                    </StackPanel>
                                                </Button>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.ImportData}" Description="{Binding L.ImportDataDescription}" IsExpanded="True">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Folder" />
                                    </fa:FASettingsExpander.IconSource>
                                    <StackPanel Spacing="16">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding L.ImportMonicaJson}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ImportMonicaJsonDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBox Text="{Binding ImportJsonText}" PlaceholderText="{Binding L.ImportJsonWatermark}" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                                <Button Command="{Binding ImportMonicaJsonFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportFromFile}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Command="{Binding ImportDataCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.Import}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource CardBorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding L.ImportAegisJson}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ImportAegisJsonDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBox Text="{Binding ImportAegisJsonText}" PlaceholderText="{Binding L.ImportAegisJsonWatermark}" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                                <Button Command="{Binding ImportAegisJsonFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportFromFile}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Command="{Binding ImportAegisJsonCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportAegisJson}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource CardBorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding L.ImportTotpCsv}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ImportTotpCsvDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBox Text="{Binding ImportTotpCsvText}" PlaceholderText="{Binding L.ImportTotpCsvWatermark}" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                                <Button Command="{Binding ImportTotpCsvFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportFromFile}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Command="{Binding ImportTotpCsvCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportTotpCsv}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource CardBorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding L.ImportNoteCsv}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ImportNoteCsvDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBox Text="{Binding ImportNoteCsvText}" PlaceholderText="{Binding L.ImportNoteCsvWatermark}" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                                <Button Command="{Binding ImportNoteCsvFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportFromFile}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Command="{Binding ImportNoteCsvCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportNoteCsv}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource CardBorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding L.ImportPasswordCsv}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ImportPasswordCsvDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBox Text="{Binding ImportCsvText}" PlaceholderText="{Binding L.ImportCsvWatermark}" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="8">
                                                <Button Command="{Binding ImportPasswordCsvFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportFromFile}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Command="{Binding ImportPasswordCsvCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportPasswordCsv}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="2" Command="{Binding ExportPasswordCsvCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ExportPasswordCsv}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.ExportData}" Description="{Binding L.ExportDataDescription}" IsExpanded="True">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="ProtectedDocument" />
                                    </fa:FASettingsExpander.IconSource>
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                                            <Button Command="{Binding SaveMonicaJsonExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Save" FontSize="20" />
                                                    <TextBlock Text="{Binding L.SaveJsonExport}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="1" Command="{Binding SavePasswordCsvExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Save" FontSize="20" />
                                                    <TextBlock Text="{Binding L.SaveCsvExport}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="2" Command="{Binding SaveTotpCsvExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Save" FontSize="20" />
                                                    <TextBlock Text="{Binding L.SaveTotpCsvExport}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="3" Command="{Binding SaveNoteCsvExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Save" FontSize="20" />
                                                    <TextBlock Text="{Binding L.SaveNoteCsvExport}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="4" Command="{Binding SaveAegisJsonExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Save" FontSize="20" />
                                                    <TextBlock Text="{Binding L.SaveAegisExport}" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                        <TextBlock Text="{Binding L.ExportPreview}" FontWeight="SemiBold" />
                                        <TextBox Text="{Binding ExportPreview}" AcceptsReturn="True" MinHeight="160" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding L.ExportCsvPreview}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding ExportCsvPreview}" AcceptsReturn="True" MinHeight="160" TextWrapping="Wrap" />
                                        <StackPanel Spacing="8" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding L.ExportTotpCsv}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ExportTotpCsvDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Button Command="{Binding ExportTotpCsvCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                                                    <TextBlock Text="{Binding L.ExportTotpCsv}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Text="{Binding L.ExportTotpCsvPreview}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding ExportTotpCsvPreview}" AcceptsReturn="True" MinHeight="160" TextWrapping="Wrap" />
                                        <StackPanel Spacing="8" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding L.ExportNoteCsv}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ExportNoteCsvDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Button Command="{Binding ExportNoteCsvCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                                                    <TextBlock Text="{Binding L.ExportNoteCsv}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Text="{Binding L.ExportNoteCsvPreview}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding ExportNoteCsvPreview}" AcceptsReturn="True" MinHeight="160" TextWrapping="Wrap" />
                                        <StackPanel Spacing="8" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding L.ExportAegisJson}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ExportAegisJsonDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Button Command="{Binding ExportAegisJsonCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                                                    <TextBlock Text="{Binding L.ExportAegisJson}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Text="{Binding L.ExportAegisPreview}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding ExportAegisPreview}" AcceptsReturn="True" MinHeight="160" TextWrapping="Wrap" />
                                    </StackPanel>
                                </fa:FASettingsExpander>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsGenerator}}" Spacing="16" MaxWidth="720" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding L.PasswordGenerator}" FontSize="20" FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding GeneratorLengthText}" />
                                    <Slider Minimum="8" Maximum="128" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding GeneratorLength}" />
                                </StackPanel>
                                <NumericUpDown Grid.Column="1" Width="96" Minimum="8" Maximum="128" Value="{Binding GeneratorLength}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="24" RowSpacing="10">
                                <CheckBox Content="{Binding L.IncludeUppercase}" IsChecked="{Binding GeneratorIncludeUppercase}" />
                                <CheckBox Grid.Column="1" Content="{Binding L.IncludeLowercase}" IsChecked="{Binding GeneratorIncludeLowercase}" />
                                <CheckBox Grid.Row="1" Content="{Binding L.IncludeNumbers}" IsChecked="{Binding GeneratorIncludeNumbers}" />
                                <CheckBox Grid.Row="1" Grid.Column="1" Content="{Binding L.IncludeSymbols}" IsChecked="{Binding GeneratorIncludeSymbols}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                <TextBox Text="{Binding GeneratedPassword}" FontFamily="Consolas" FontSize="18" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Command="{Binding GeneratePasswordCommand}" ToolTip.Tip="{Binding L.Generate}">
                                    <ic:FluentIcon Icon="Sparkle" FontSize="20" />
                                </Button>
                                <Button Grid.Column="2" Command="{Binding CopyGeneratedPasswordCommand}" ToolTip.Tip="{Binding L.CopyPassword}">
                                    <ic:FluentIcon Icon="Copy" FontSize="20" />
                                </Button>
                                <Button Grid.Column="3" Command="{Binding AddPasswordCommand}" ToolTip.Tip="{Binding L.SaveAsLogin}">
                                    <ic:FluentIcon Icon="Key" FontSize="20" />
                                </Button>
                            </Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding L.PasswordStrength}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding GeneratedPasswordStrengthText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsNotes}}" RowDefinitions="44,*" Background="{DynamicResource LayerFillColorDefaultBrush}">
                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                <Grid ColumnDefinitions="280,*" Height="44">
                                    <Border Padding="14,0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,1,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                            <ic:FluentIcon Icon="Folder" FontSize="17" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding L.SecureNotes}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding NoteCountText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Background="{DynamicResource LayerFillColorSubtleBrush}">
                                        <Button Click="PreviousNoteTabButton_OnClick"
                                                ToolTip.Tip="向左滚动标签"
                                                Width="30"
                                                Height="34"
                                                Padding="0"
                                                Margin="8,5,2,0"
                                                VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="ChevronLeft" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>

                                        <ScrollViewer x:Name="NoteTabsScrollViewer"
                                                      Grid.Column="1"
                                                      Height="44"
                                                      MaxHeight="44"
                                                      ClipToBounds="True"
                                                      SizeChanged="NoteTabsScrollViewer_OnSizeChanged"
                                                      HorizontalScrollBarVisibility="Hidden"
                                                      VerticalScrollBarVisibility="Hidden">
                                            <ItemsControl ItemsSource="{Binding OpenNoteTabs}"
                                                          Height="40"
                                                          Margin="4,4,4,0"
                                                          HorizontalAlignment="Left">
                                                <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:NoteEditorTab">
                                                        <Border Classes="noteTab"
                                                                Classes.active="{Binding IsSelected}"
                                                                Width="{Binding #Root.DataContext.NoteTabWidth}"
                                                                MinWidth="92"
                                                                MaxWidth="156"
                                                                Height="34"
                                                                Margin="0,4,4,0"
                                                                BorderThickness="1,1,1,0"
                                                                CornerRadius="4,4,0,0">
                                                            <Grid RowDefinitions="3,*">
                                                                <Border IsVisible="{Binding IsSelected}" Background="{DynamicResource AccentFillColorDefaultBrush}" CornerRadius="4,4,0,0" />
                                                                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" MinWidth="0">
                                                                    <Button Classes="noteTabButton"
                                                                            Command="{Binding #Root.DataContext.SelectNoteTabCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip.Tip="{Binding Title}">
                                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5" Margin="10,0,6,0" MinWidth="0">
                                                                            <TextBlock Text="{Binding Title}" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                            <TextBlock Grid.Column="1" Text="*" IsVisible="{Binding IsDirty}" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                                                        </Grid>
                                                                    </Button>
                                                                    <Button Grid.Column="1"
                                                                            Click="CloseNoteTabButton_OnClick"
                                                                            IsVisible="{Binding IsSelected}"
                                                                            ToolTip.Tip="关闭标签"
                                                                            Width="24"
                                                                            Height="24"
                                                                            Padding="0"
                                                                            Margin="0,2,5,0"
                                                                            VerticalAlignment="Top">
                                                                        <ic:FluentIcon Icon="Dismiss" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Button>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <Button Grid.Column="2"
                                                Click="NextNoteTabButton_OnClick"
                                                ToolTip.Tip="向右滚动标签"
                                                Width="30"
                                                Height="34"
                                                Padding="0"
                                                Margin="2,5,4,0"
                                                VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="ChevronRight" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>

                                        <Button Grid.Column="3" Command="{Binding AddNoteCommand}" ToolTip.Tip="{Binding L.NewSecureNote}" Width="34" Height="34" Padding="0" Margin="0,5,8,0" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="Add" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Button Command="{Binding SaveNoteCommand}" ToolTip.Tip="{Binding L.SaveNote}" Width="34" Height="34" Padding="0">
                                                <ic:FluentIcon Icon="Save" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                            <Button Command="{Binding SaveAllNoteTabsCommand}" ToolTip.Tip="保存全部" Width="34" Height="34" Padding="0">
                                                <TextBlock Text="All" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                            <Button Command="{Binding ImportMarkdownNoteCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="导入 Markdown" Width="34" Height="34" Padding="0">
                                                <ic:FluentIcon Icon="ArrowUpload" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                            <Button Command="{Binding ExportCurrentNoteMarkdownCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="导出 Markdown" Width="34" Height="34" Padding="0">
                                                <ic:FluentIcon Icon="ArrowDownload" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                            <Button Command="{Binding ToggleNoteFavoriteCommand}" ToolTip.Tip="{Binding L.Favorite}" Width="34" Height="34" Padding="0">
                                                <ic:FluentIcon Icon="Star" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" ColumnDefinitions="280,*,260">
                                <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,1,0" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="12">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,0,0,10">
                                            <TextBlock Text="保险库" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Command="{Binding AddNoteCommand}" ToolTip.Tip="{Binding L.NewSecureNote}" Width="32" Height="32" Padding="0">
                                                <ic:FluentIcon Icon="Add" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                            <Button Grid.Column="2" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}" Width="32" Height="32" Padding="0">
                                                <ic:FluentIcon Icon="ArrowSync" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                        </Grid>

                                        <TextBox Grid.Row="1"
                                                 Text="{Binding NoteSearchText}"
                                                 PlaceholderText="搜索笔记、标签、正文"
                                                 Height="32"
                                                 Margin="0,0,0,10" />

                                        <Border Grid.Row="2" Padding="10,8" CornerRadius="6" Background="{DynamicResource LayerFillColorSubtleBrush}" Margin="0,0,0,10">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                <ic:FluentIcon Icon="Home" FontSize="16" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="主页" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding NoteTreeStatusText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel Spacing="10">
                                                <StackPanel IsVisible="{Binding HasFavoriteNoteItems}">
                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" Margin="2,0,0,6">
                                                        <ic:FluentIcon Icon="ChevronDown" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7">
                                                            <ic:FluentIcon Icon="Star" FontSize="14" VerticalAlignment="Center" />
                                                            <TextBlock Text="收藏" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding FavoriteNoteCount}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                    </Grid>

                                                    <ItemsControl ItemsSource="{Binding FavoriteNoteItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:SecureItem">
                                                                <Grid ColumnDefinitions="*,Auto" Margin="14,0,0,3">
                                                                    <Button Command="{Binding #Root.DataContext.OpenNoteCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            Padding="0"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            HorizontalContentAlignment="Stretch">
                                                                        <Border Padding="8,6" CornerRadius="5" Background="Transparent">
                                                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                                                <ic:FluentIcon Icon="Document" FontSize="15" VerticalAlignment="Top" Margin="0,2,0,0" />
                                                                                <StackPanel Grid.Column="1" Spacing="2">
                                                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                                        <TextBlock Text=".md" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                                        <ic:FluentIcon Icon="Star" FontSize="12" IsVisible="{Binding IsFavorite}" />
                                                                                    </StackPanel>
                                                                                    <TextBlock Text="{Binding Notes}" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Border>
                                                                    </Button>
                                                                    <Button Grid.Column="1"
                                                                            Command="{Binding #Root.DataContext.DeleteNoteCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip.Tip="{Binding #Root.DataContext.L.MoveToRecycleBin}"
                                                                            Width="28"
                                                                            Height="28"
                                                                            Padding="0"
                                                                            VerticalAlignment="Top">
                                                                        <ic:FluentIcon Icon="Delete" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <StackPanel>
                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" Margin="2,0,0,6">
                                                        <ic:FluentIcon Icon="ChevronDown" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7">
                                                            <ic:FluentIcon Icon="FolderOpen" FontSize="14" VerticalAlignment="Center" />
                                                            <TextBlock Text="全部笔记" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding FilteredNoteItems.Count}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                    </Grid>

                                                    <ItemsControl ItemsSource="{Binding FilteredNoteItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:SecureItem">
                                                                <Grid ColumnDefinitions="*,Auto" Margin="14,0,0,3">
                                                                    <Button Command="{Binding #Root.DataContext.OpenNoteCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            Padding="0"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            HorizontalContentAlignment="Stretch">
                                                                        <Border Padding="8,6" CornerRadius="5" Background="Transparent">
                                                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                                                <ic:FluentIcon Icon="Document" FontSize="15" VerticalAlignment="Top" Margin="0,2,0,0" />
                                                                                <StackPanel Grid.Column="1" Spacing="2">
                                                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                                        <TextBlock Text=".md" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                                        <ic:FluentIcon Icon="Star" FontSize="12" IsVisible="{Binding IsFavorite}" />
                                                                                    </StackPanel>
                                                                                    <TextBlock Text="{Binding Notes}" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Border>
                                                                    </Button>
                                                                    <Button Grid.Column="1"
                                                                            Command="{Binding #Root.DataContext.DeleteNoteCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip.Tip="{Binding #Root.DataContext.L.MoveToRecycleBin}"
                                                                            Width="28"
                                                                            Height="28"
                                                                            Padding="0"
                                                                            VerticalAlignment="Top">
                                                                        <ic:FluentIcon Icon="Delete" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <TextBlock IsVisible="{Binding HasFilteredNoteItems, Converter={x:Static local:BoolConverters.Not}}"
                                                               Text="没有匹配的笔记"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Margin="22,8,0,0" />
                                                </StackPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="36,24,36,20" MaxWidth="920" HorizontalAlignment="Stretch">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,16">
                                        <TextBox Text="{Binding NoteTitle}"
                                                 PlaceholderText="{Binding L.NoteTitleWatermark}"
                                                 FontSize="32"
                                                 FontWeight="SemiBold"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Padding="0" />
                                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding NoteIsMarkdown}" OffContent="{Binding L.PlainText}" OnContent="Markdown" VerticalAlignment="Center" />
                                        <ToggleSwitch Grid.Column="2" IsChecked="{Binding NotePreviewMode}" OffContent="{Binding L.Edit}" OnContent="{Binding L.Preview}" VerticalAlignment="Center" />
                                        <ToggleSwitch Grid.Column="3" IsChecked="{Binding NoteSplitPreviewMode}" OffContent="单栏" OnContent="分屏" VerticalAlignment="Center" />
                                    </Grid>

                                    <Border Grid.Row="1" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,12">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Button Click="UndoNoteEditorButton_OnClick" ToolTip.Tip="撤销" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="ArrowUndo" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Click="RedoNoteEditorButton_OnClick" ToolTip.Tip="重做" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="ArrowRedo" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Border Width="1" Height="20" Background="{DynamicResource CardBorderBrush}" Margin="4,0,6,0" VerticalAlignment="Center" />
                                            <Button Tag="h1" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="一级标题" Width="32" Height="32" Padding="0"><TextBlock Text="H1" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="h2" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="二级标题" Width="32" Height="32" Padding="0"><TextBlock Text="H2" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="h3" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="三级标题" Width="32" Height="32" Padding="0"><TextBlock Text="H3" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="bold" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="粗体" Width="32" Height="32" Padding="0"><TextBlock Text="B" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="italic" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="斜体" Width="32" Height="32" Padding="0"><TextBlock Text="I" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="strike" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="删除线" Width="32" Height="32" Padding="0"><TextBlock Text="S" TextDecorations="Strikethrough" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="inlinecode" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="行内代码" Width="32" Height="32" Padding="0"><TextBlock Text="`" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="quote" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="引用" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="TextQuote" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="code" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="代码块" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Code" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="ul" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="无序列表" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="TextBulletList" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="ol" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="有序列表" Width="32" Height="32" Padding="0"><TextBlock Text="1." FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="todo" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="任务列表" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="CheckboxChecked" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="table" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="表格" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Table" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="link" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="链接" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Link" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Tag="hr" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="分割线" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Subtract" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Click="InsertNoteImageButton_OnClick" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="插入图片" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Image" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="NoteFindPanel" Grid.Row="2" IsVisible="False" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource LayerFillColorSubtleBrush}" Padding="8" Margin="0,0,0,12">
                                        <Grid ColumnDefinitions="220,220,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
                                            <TextBox x:Name="NoteFindTextBox"
                                                     PlaceholderText="查找"
                                                     Height="32"
                                                     KeyDown="NoteFindTextBox_OnKeyDown"
                                                     TextChanged="NoteFindTextBox_OnTextChanged" />
                                            <TextBox x:Name="NoteReplaceTextBox"
                                                     Grid.Column="1"
                                                     PlaceholderText="替换为"
                                                     Height="32"
                                                     KeyDown="NoteReplaceTextBox_OnKeyDown" />
                                            <Button Grid.Column="2" Click="FindPreviousNoteMatchButton_OnClick" ToolTip.Tip="上一个" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="ChevronLeft" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Grid.Column="3" Click="FindNextNoteMatchButton_OnClick" ToolTip.Tip="下一个" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="ChevronRight" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <Button Grid.Column="4" Click="ReplaceCurrentNoteMatchButton_OnClick" ToolTip.Tip="替换当前匹配" MinWidth="54" Height="32" Padding="10,0"><TextBlock Text="替换" VerticalAlignment="Center" /></Button>
                                            <Button Grid.Column="5" Click="ReplaceAllNoteMatchesButton_OnClick" ToolTip.Tip="替换全部匹配" MinWidth="70" Height="32" Padding="10,0"><TextBlock Text="全部替换" VerticalAlignment="Center" /></Button>
                                            <CheckBox x:Name="NoteFindMatchCaseCheckBox" Grid.Column="6" Content="Aa" ToolTip.Tip="区分大小写" VerticalAlignment="Center" Click="NoteFindOptions_OnChanged" />
                                            <Button Grid.Column="7" Click="CloseNoteFindPanelButton_OnClick" ToolTip.Tip="关闭查找" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Dismiss" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            <TextBlock x:Name="NoteFindStatusText" Grid.Column="8" Text="0/0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding NoteEditorColumnWidth}" />
                                            <ColumnDefinition Width="{Binding NotePreviewSeparatorColumnWidth}" />
                                            <ColumnDefinition Width="{Binding NotePreviewColumnWidth}" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" IsVisible="{Binding IsNoteEditorPaneVisible}" ColumnDefinitions="36,*">
                                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,1,0" Padding="0,0,4,0" Margin="-24,0,10,0">
                                                <TextBlock Text="{Binding NoteLineNumbersText}" FontFamily="Consolas" FontSize="16" LineHeight="24" TextAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                                            </Border>
                                            <TextBox x:Name="NoteContentEditor"
                                                     Grid.Column="1"
                                                     Text="{Binding NoteContent}"
                                                     PlaceholderText="{Binding L.NoteContentWatermark}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalAlignment="Stretch"
                                                     VerticalContentAlignment="Top"
                                                     FontFamily="Consolas"
                                                     FontSize="16"
                                                     LineHeight="24"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Padding="0"
                                                     KeyDown="NoteContentEditor_OnKeyDown"
                                                     KeyUp="NoteContentEditor_OnKeyUp"
                                                     TextChanged="NoteContentEditor_OnTextChanged"
                                                     PointerReleased="NoteContentEditor_OnPointerReleased">
                                                <TextBox.Resources>
                                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBackgroundFocusedPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBorderBrushFocusedPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBackground" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBackgroundPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBackgroundFocused" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBorderBrush" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBorderBrushPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBorderBrushFocused" Color="Transparent" />
                                                    <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                                    <Thickness x:Key="TextBoxBorderThemeThickness">0</Thickness>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </Grid>
                                        <Border Grid.Column="1" IsVisible="{Binding NoteSplitPreviewMode}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,0,0,0" Margin="8,0,8,0" />

                                        <Border Grid.Column="2" IsVisible="{Binding IsNotePreviewPaneVisible}" Padding="0" Background="Transparent">
                                            <Grid RowDefinitions="*,Auto">
                                                <md:MarkdownScrollViewer IsVisible="{Binding NoteIsMarkdown}" Markdown="{Binding NotePreviewMarkdown}" />
                                                <ScrollViewer IsVisible="{Binding !NoteIsMarkdown}">
                                                    <TextBlock Text="{Binding NotePlainPreview}" TextWrapping="Wrap" FontSize="16" LineHeight="24" />
                                                </ScrollViewer>
                                                <Border Grid.Row="1" IsVisible="{Binding HasNoteImagePreviewItems}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0" Margin="0,12,0,0" Padding="0,10,0,0">
                                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxHeight="190">
                                                        <ItemsControl ItemsSource="{Binding NoteImagePreviewItems}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:NoteImagePreviewItem">
                                                                    <Border Width="172" Height="158" Margin="0,0,10,0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource CardBackgroundBrush}">
                                                                        <Grid RowDefinitions="*,Auto" Margin="8">
                                                                            <Image Source="{Binding Image}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                            <StackPanel Grid.Row="1" Spacing="1" Margin="0,6,0,0">
                                                                                <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock Text="{Binding SizeText}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="4" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,10,0,0">
                                        <TextBlock Text="{Binding NoteEditorStatusText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                    </Border>
                                </Grid>

                                <Border Grid.Column="2" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,0,0,0" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                    <Grid RowDefinitions="*,*,Auto" Margin="14,16" RowSpacing="14">
                                        <Grid RowDefinitions="Auto,*">
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                                <TextBlock Text="大纲" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Grid.Column="1" Text="{Binding NoteOutlineCount}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </Grid>
                                            <Grid Grid.Row="1">
                                                <TextBlock Text="无标题" IsVisible="{Binding HasNoteOutlineItems, Converter={x:Static local:BoolConverters.Not}}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <ScrollViewer IsVisible="{Binding HasNoteOutlineItems}">
                                                    <ItemsControl ItemsSource="{Binding NoteOutlineItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:NoteOutlineItem">
                                                                <Button Click="NoteOutlineItem_OnClick" Padding="0" Margin="{Binding Indent}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" ToolTip.Tip="{Binding Title}">
                                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                                        <TextBlock Text="{Binding LineNumber}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Grid>
                                        </Grid>

                                        <Grid Grid.Row="1" RowDefinitions="Auto,*">
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                                <TextBlock Text="引用" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Grid.Column="1" Text="{Binding NoteReferenceCount}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </Grid>
                                            <Grid Grid.Row="1">
                                                <TextBlock Text="无链接" IsVisible="{Binding HasNoteReferenceItems, Converter={x:Static local:BoolConverters.Not}}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <ScrollViewer IsVisible="{Binding HasNoteReferenceItems}">
                                                    <ItemsControl ItemsSource="{Binding NoteReferenceItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:NoteReferenceItem">
                                                                <Grid RowDefinitions="Auto,Auto" Margin="0,0,0,8">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="7">
                                                                        <ic:FluentIcon Icon="Link" FontSize="12" VerticalAlignment="Center" IsVisible="{Binding IsImage, Converter={x:Static local:BoolConverters.Not}}" />
                                                                        <ic:FluentIcon Icon="Image" FontSize="12" VerticalAlignment="Center" IsVisible="{Binding IsImage}" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Column="2" Text="{Binding LineNumber}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                                        <Button Grid.Column="3" Command="{Binding #Root.DataContext.OpenNoteReferenceCommand}" CommandParameter="{Binding}" ToolTip.Tip="打开" Width="24" Height="24" Padding="0">
                                                                            <ic:FluentIcon Icon="Open" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Button>
                                                                        <Button Grid.Column="4" Command="{Binding #Root.DataContext.CopyNoteReferenceCommand}" CommandParameter="{Binding}" ToolTip.Tip="复制" Width="24" Height="24" Padding="0">
                                                                            <ic:FluentIcon Icon="Copy" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Button>
                                                                    </Grid>
                                                                    <TextBlock Grid.Row="1" Text="{Binding Target}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="20,1,0,0" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Grid>
                                        </Grid>

                                        <StackPanel Grid.Row="2" Spacing="8">
                                            <Border Height="1" Background="{DynamicResource CardBorderBrush}" />
                                            <TextBlock Text="属性" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <TextBlock Text="标签" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                <TextBox Grid.Column="1" Text="{Binding NoteTagsText}" PlaceholderText="{Binding L.NoteTagsWatermark}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <TextBlock Text="格式" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding NoteFormatText}" VerticalAlignment="Center" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </fa:FANavigationView>
        </Grid>

        <Border Grid.Row="1"
                IsVisible="{Binding IsUnlocked}"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Border Padding="2,0" ClipToBounds="True">
                <Grid ColumnSpacing="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                <Button Classes="StatusBarButton"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="Passwords"
                        ToolTip.Tip="{Binding L.Passwords}">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="Monica" FontSize="12" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="1"
                        Classes="StatusBarButton"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="Sync"
                        ToolTip.Tip="{Binding L.SyncAndBackup}">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="&#xE777;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ShellVaultText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Classes="StatusBarButton"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="Sync"
                        ToolTip.Tip="{Binding L.SyncAndBackup}">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ShellSyncText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Classes="StatusBarButton"
                        Command="{Binding LoadCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        ToolTip.Tip="{Binding L.Refresh}">
                    <TextBlock Text="{Binding ShellPageText}"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </Button>

                <TextBlock Grid.Column="4" Text="Ln 1, Col 1" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" Margin="8,0" />
                <TextBlock Grid.Column="5" Text="Spaces: 4" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" Margin="8,0" />
                <TextBlock Grid.Column="6" Text="UTF-8" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" Margin="8,0" />
                <TextBlock Grid.Column="7" Text="CRLF" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" Margin="8,0" />

                <Button Grid.Column="8"
                        Classes="StatusBarButton"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="Settings"
                        ToolTip.Tip="{Binding L.Settings}">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ShellPlatformText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Button>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
