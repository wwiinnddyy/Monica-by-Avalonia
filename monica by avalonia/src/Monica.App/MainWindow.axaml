            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Button.mdbxPivotButton">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.mdbxPivotButton.accent">
            <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>
        <Style Selector="ListBox.databaseSourceList ListBoxItem">
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="88" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="ListBox.databaseSourceList ListBoxItem:selected">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
        </Style>
        <Style Selector="Button.databaseSourceButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.databaseSourceButton:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.databaseSourceRow">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="MinHeight" Value="88" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.databaseSourceRail">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Border.databaseWorkbench">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        </Style>
        <Style Selector="Button.databasePivotButton">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.databasePivotButton.accent">
            <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>
        <Style Selector="StackPanel.workspaceEmptyState">
            <Setter Property="Margin" Value="24" />
            <Setter Property="MaxWidth" Value="320" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.workspaceRecoverableStatus">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCautionBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        </Style>
        <Style Selector="Border.workspacePageHeader">
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,0,0,12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="Border.workspacePane">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        </Style>
        <Style Selector="Border.workspaceSidebar">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Border.workspaceStatusChip">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        </Style>
        <Style Selector="Border.workspaceNavItem">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.workspaceNavItem.accent">
            <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Button.workspaceNavItem">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.workspaceNavItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundPointerOver}" />
        </Style>
        <Style Selector="Button.workspaceNavItem.accent">
            <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="TextBlock.workspacePageTitle">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.workspacePageSubtitle">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.workspaceSectionLabel">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="TextBlock.workspaceDetailLabel">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="TextBlock.workspaceDetailValue">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="Grid.unlockSurface TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.unlockDescription">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="20" />
        </Style>
        <Style Selector="TextBox.unlockInput">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="PlaceholderForeground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBox.unlockInput:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="TextBox.unlockInput:focus">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Button.unlockPrimaryCommand">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LayerFillColorAltBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.unlockPrimaryCommand:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LayerFillColorAltBrush}" />
        </Style>
        <Style Selector="Button.unlockPrimaryCommand:pressed">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LayerFillColorAltBrush}" />
        </Style>
        <Style Selector="Button.unlockPrimaryCommand:disabled">
            <Setter Property="Opacity" Value="0.72" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,24" Background="{DynamicResource LayerFillColorDefaultBrush}">
        <Grid Grid.Row="0">
            <Grid Classes="unlockSurface"
                  IsVisible="{Binding !IsUnlocked}"
                  Background="{DynamicResource LayerFillColorDefaultBrush}"
                  ClipToBounds="True">
                <StackPanel Width="420"
                            MaxWidth="420"
                            Margin="24"
                            Spacing="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Image Source="/Assets/Logo.png"
                           Width="56"
                           Height="56"
                           HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding LoginTitle}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="unlockDescription"
                               Text="{Binding LoginDescription}" />
                    <Border IsVisible="{Binding HasLegacyVaultImportPrompt}"
                            Padding="12"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource LayerFillColorSubtleBrush}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding L.LegacyVaultDetected}" FontWeight="SemiBold" />
                            <TextBlock Classes="unlockDescription"
                                       Text="{Binding LegacyVaultImportPromptText}"
                                       TextAlignment="Left" />
                        </StackPanel>
                    </Border>
                    <TextBox Classes="unlockInput"
                             PasswordChar="*"
                             PlaceholderText="{Binding L.MasterPasswordWatermark}"
                             Text="{Binding MasterPassword}" />
                    <TextBox Classes="unlockInput"
                             IsVisible="{Binding !IsVaultInitialized}"
                             PasswordChar="*"
                             PlaceholderText="{Binding L.ConfirmMasterPasswordWatermark}"
                             Text="{Binding ConfirmMasterPassword}" />
                    <Button Classes="unlockPrimaryCommand"
                            Command="{Binding UnlockCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center">
                        <TextBlock Text="{Binding LoginButtonText}" Foreground="{DynamicResource LayerFillColorAltBrush}" />
                    </Button>
                    <TextBlock Classes="unlockDescription"
                               Text="{Binding StatusMessage}" />
                </StackPanel>
            </Grid>

            <fa:FANavigationView IsVisible="{Binding IsUnlocked}"
                                 PaneDisplayMode="Left"
                                 IsPaneOpen="False"
                                 IsBackButtonVisible="False"
                                 IsSettingsVisible="False"
                                 OpenPaneLength="240"
                                 Background="{DynamicResource LayerFillColorDefaultBrush}"
                                 SelectionChanged="NavigationView_OnSelectionChanged">
                <fa:FANavigationView.MenuItems>
                    <fa:FANavigationViewItem Content="{Binding L.Passwords}" Tag="Passwords">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Permissions" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.SecureNotes}" Tag="Notes">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="ProtectedDocument" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Totp}" Tag="Totp">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Clock" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Cards}" Tag="Cards">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="ContactInfo" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Generator}" Tag="Generator">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Edit" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Archive}" Tag="Archive">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Library" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.RecycleBin}" Tag="RecycleBin">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Delete" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.SecurityAnalysis}" Tag="SecurityAnalysis">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Permissions" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Timeline}" Tag="Timeline">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Clock" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.MdbxVaults}" Tag="Mdbx">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Folder" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                </fa:FANavigationView.MenuItems>

                <fa:FANavigationView.FooterMenuItems>
                    <fa:FANavigationViewItem Content="{Binding L.DatabaseManagement}" Tag="DatabaseManagement">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Library" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.SyncAndBackup}" Tag="Sync">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Sync" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Settings}" Tag="Settings">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Setting" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                </fa:FANavigationView.FooterMenuItems>

                <Grid Margin="18" RowDefinitions="Auto,Auto,*" Background="{DynamicResource LayerFillColorDefaultBrush}">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,18" IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsContentHeaderVisible}}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedSectionTitle}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Classes="IconButton" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}">
                                <ic:FluentIcon Icon="ArrowClockwise" FontSize="20" />
                            </Button>
                            <Button Classes="IconButton" Command="{Binding ExportDataCommand}" ToolTip.Tip="{Binding L.Export}">
                                <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Classes="workspaceRecoverableStatus" IsVisible="{Binding HasRecoverableStatusMessage}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <ic:FluentIcon Icon="Warning" FontSize="18" Foreground="{DynamicResource SystemFillColorCautionBrush}" VerticalAlignment="Top" Margin="0,2,0,0" />
                            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                            <Button Grid.Column="2" Classes="workspaceCommand" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}" AutomationProperties.Name="{Binding L.Refresh}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Icon="ArrowClockwise" FontSize="16" />
                                    <TextBlock Text="{Binding L.Refresh}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Grid x:Name="WorkspaceHost" Grid.Row="2" SizeChanged="WorkspaceHost_OnSizeChanged">
                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsPasswords}}" RowDefinitions="Auto,Auto,Auto,*">
                            <Border Grid.Row="0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,10">
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                    <StackPanel MinWidth="132">
                                        <TextBlock Text="{Binding L.PasswordManager}" FontSize="20" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding PasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <TextBox x:Name="PasswordSearchBox"
                                             Grid.Row="1"
                                             PlaceholderText="{Binding L.Search}"
                                             Text="{Binding PasswordSearchText}"
                                             Width="420"
                                             MaxWidth="720"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center" />

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Button Classes="passwordPrimaryCommand" Command="{Binding AddPasswordCommand}" ToolTip.Tip="{Binding L.AddPassword}">
                                            <StackPanel Orientation="Horizontal" Spacing="7">
                                                <ic:FluentIcon Icon="Add" FontSize="18" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding L.AddPassword}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="passwordCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Generator" ToolTip.Tip="{Binding L.PasswordGenerator}">
                                            <ic:FluentIcon Icon="Key" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>
                                        <Button Classes="passwordCommand" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}">
                                            <ic:FluentIcon Icon="ArrowSync" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>
                                        <Button Classes="passwordCommand" ToolTip.Tip="{Binding L.MoreOptions}">
                                            <ic:FluentIcon Icon="MoreHorizontal" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuItem Header="{Binding L.ImportPasswordCsv}" Command="{Binding ImportPasswordCsvFileCommand}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="FolderOpen" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding L.ExportPasswordCsv}" Command="{Binding SavePasswordCsvExportCommand}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="ArrowDownload" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding L.ExportData}" Command="{Binding SaveMonicaJsonExportCommand}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="Document" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding L.Archive}" Command="{Binding SelectSectionCommand}" CommandParameter="Archive">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="FolderOpen" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding L.DeletedPasswords}" Command="{Binding SelectSectionCommand}" CommandParameter="RecycleBin">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="Delete" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                        <Button Classes="passwordCommand" ToolTip.Tip="{Binding PasswordSortButtonTip}">
                                            <ic:FluentIcon Icon="TextBulletList" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuItem Header="{Binding SortUpdatedText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="updated-desc">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortUpdatedSelected}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding SortTitleText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="title-asc">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortTitleSelected}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding SortWebsiteText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="website-asc">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortWebsiteSelected}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding SortUsernameText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="username-asc">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortUsernameSelected}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding SortCreatedText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="created-desc">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortCreatedSelected}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding SortFavoritesText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="favorites-first">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortFavoritesSelected}" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    IsVisible="{Binding HasSelectedPasswords}"
                                    BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="10,8"
                                    Background="{DynamicResource AccentFillColorTertiaryBrush}"
                                    Margin="0,0,0,10">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <ic:FluentIcon Icon="CheckboxChecked" FontSize="18" />
                                        <TextBlock Text="{Binding SelectedPasswordCountText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                        <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding FavoriteSelectedPasswordsCommand}" ToolTip.Tip="{Binding L.BatchFavorite}">
                                            <ic:FluentIcon Icon="Star" FontSize="18" />
                                        </Button>
                                        <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding MoveSelectedPasswordsToCategoryCommand}" ToolTip.Tip="{Binding L.MoveToFolder}">
                                            <ic:FluentIcon Icon="Folder" FontSize="18" />
                                        </Button>
                                        <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding ArchiveSelectedPasswordsCommand}" ToolTip.Tip="{Binding L.BatchArchive}">
                                            <ic:FluentIcon Icon="FolderOpen" FontSize="18" />
                                        </Button>
                                        <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding DeleteSelectedPasswordsCommand}" ToolTip.Tip="{Binding L.BatchDelete}">
                                            <ic:FluentIcon Icon="Delete" FontSize="18" />
                                        </Button>
                                        <Button Classes="passwordCommand" Margin="0,0,0,6" Command="{Binding ClearPasswordSelectionCommand}" ToolTip.Tip="{Binding L.Cancel}">
                                            <ic:FluentIcon Icon="Dismiss" FontSize="18" />
                                        </Button>
                                    </WrapPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="10" Margin="0,0,0,12">
                                <Border IsVisible="{Binding HasPasswordFilters}" Padding="10,5" CornerRadius="6" Background="{DynamicResource LayerFillColorSubtleBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" MaxWidth="260" VerticalAlignment="Center">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                        <ic:FluentIcon Icon="Info" FontSize="14" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding PasswordFilterSummaryText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Button Grid.Column="1"
                                        Classes="passwordCommand"
                                        Command="{Binding ClearPasswordFiltersCommand}"
                                        IsVisible="{Binding HasPasswordFilters}"
                                        ToolTip.Tip="{Binding ClearPasswordFiltersText}">
                                    <ic:FluentIcon Icon="Dismiss" FontSize="18" />
                                </Button>
                                <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,8,6" IsChecked="{Binding QuickFilterFavorite}" ToolTip.Tip="{Binding L.QuickFilterFavorite}">
                                        <ic:FluentIcon Icon="Star" FontSize="16" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,8,6" IsChecked="{Binding QuickFilter2Fa}" ToolTip.Tip="{Binding L.QuickFilter2Fa}">
                                        <ic:FluentIcon Icon="Key" FontSize="16" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,8,6" IsChecked="{Binding QuickFilterNotes}" ToolTip.Tip="{Binding L.QuickFilterNotes}">
                                        <ic:FluentIcon Icon="Note" FontSize="16" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,8,6" IsChecked="{Binding QuickFilterPasskey}" ToolTip.Tip="{Binding L.QuickFilterPasskey}">
                                        <ic:FluentIcon Icon="Fingerprint" FontSize="16" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,8,6" IsChecked="{Binding QuickFilterBoundNote}" ToolTip.Tip="{Binding L.QuickFilterBoundNote}">
                                        <ic:FluentIcon Icon="Document" FontSize="16" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,8,6" IsChecked="{Binding QuickFilterUncategorized}" ToolTip.Tip="{Binding L.QuickFilterUncategorized}">
                                        <ic:FluentIcon Icon="Folder" FontSize="16" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,8,6" IsChecked="{Binding QuickFilterLocalOnly}" ToolTip.Tip="{Binding L.QuickFilterLocalOnly}">
                                        <ic:FluentIcon Icon="Desktop" FontSize="16" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,8,6" IsChecked="{Binding QuickFilterAttachments}" ToolTip.Tip="{Binding L.QuickFilterAttachments}">
                                        <ic:FluentIcon Icon="Attach" FontSize="16" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                </WrapPanel>
                            </Grid>

                            <Grid Grid.Row="3" ColumnDefinitions="320,*" ColumnSpacing="12" MinWidth="0" ClipToBounds="True">
                                <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                    <Grid RowDefinitions="Auto,2*,Auto,Auto,*" Margin="10" RowSpacing="8">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <StackPanel>
                                                <TextBlock Text="密码列表" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{Binding PasswordCountText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" IsChecked="{Binding AreAllFilteredPasswordsSelected}" ToolTip.Tip="全选当前列表" VerticalAlignment="Center" />
                                        </Grid>

                                        <ListBox x:Name="PasswordListBox"
                                                 Grid.Row="1"
                                                 Classes="passwordVaultList"
                                                 ItemsSource="{Binding FilteredPasswords}"
                                                 SelectedItem="{Binding SelectedPassword}"
                                                 SelectionMode="Single"
                                                 Padding="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 Background="Transparent">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VirtualizingStackPanel Orientation="Vertical" CacheLength="2" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:DataType="models:PasswordEntry">
                                                    <Border Margin="0,0,0,4" Padding="8,6" CornerRadius="7" Background="Transparent" HorizontalAlignment="Stretch" MinHeight="58">
                                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                                                            <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                                            <Border Grid.Column="1" Width="34" Height="34" CornerRadius="17" Background="{DynamicResource AccentFillColorDefaultBrush}">
                                                                <TextBlock Text="{Binding AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <Grid Grid.Column="2" RowDefinitions="Auto,Auto" VerticalAlignment="Center">
                                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                                        <ic:FluentIcon Icon="Star" FontSize="13" IsVisible="{Binding IsFavorite}" />
                                                                        <ic:FluentIcon Icon="Key" FontSize="13" IsVisible="{Binding HasAuthenticator}" />
                                                                        <ic:FluentIcon Icon="Attach" FontSize="13" IsVisible="{Binding HasAttachments}" />
                                                                    </StackPanel>
                                                                </Grid>
                                                                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                    <TextBlock Text="{Binding Username}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                                    <TextBlock Grid.Column="1" Text="{Binding Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" MaxWidth="120" />
                                                                </Grid>
                                                            </Grid>
                                                            <StackPanel Grid.Column="3" Classes="passwordRowActions" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                                <Button Classes="passwordInlineCommand"
                                                                        Command="{Binding #Root.DataContext.CopyUsernameCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        ToolTip.Tip="{Binding #Root.DataContext.L.CopyUsername}">
                                                                    <ic:FluentIcon Icon="Copy" FontSize="14" />
                                                                </Button>
                                                                <Button Classes="passwordInlineCommand"
                                                                        Command="{Binding #Root.DataContext.CopyPasswordCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        ToolTip.Tip="{Binding #Root.DataContext.L.CopyPassword}">
                                                                    <ic:FluentIcon Icon="Key" FontSize="14" />
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,6,0,0">
                                            <StackPanel>
                                                <TextBlock Text="文件夹" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{Binding SelectedPasswordFolderFilter.Name}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Command="{Binding RenameSelectedPasswordFolderCommand}" IsEnabled="{Binding CanManageSelectedPasswordFolder}" ToolTip.Tip="{Binding L.RenameFolder}" Width="30" Height="30" Padding="0">
                                                <ic:FluentIcon Icon="Edit" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                            <Button Grid.Column="2" Command="{Binding DeleteSelectedPasswordFolderCommand}" IsEnabled="{Binding CanManageSelectedPasswordFolder}" ToolTip.Tip="{Binding L.DeleteFolder}" Width="30" Height="30" Padding="0">
                                                <ic:FluentIcon Icon="Delete" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                        </Grid>

                                        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                            <TextBox Text="{Binding NewFolderName}" PlaceholderText="{Binding L.NewFolder}" Height="32" />
                                            <Button Grid.Column="1" Command="{Binding CreatePasswordFolderCommand}" ToolTip.Tip="{Binding L.CreateFolder}" Width="34" Height="32" Padding="0">
                                                <ic:FluentIcon Icon="FolderAdd" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                        </Grid>

                                        <ScrollViewer Grid.Row="4" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                            <StackPanel Spacing="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding L.FolderScopes}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="6,0,0,0" />
                                                    <ListBox Classes="passwordFolderList"
                                                             ItemsSource="{Binding SystemPasswordFolderFilters}"
                                                             SelectedItem="{Binding SelectedPasswordFolderFilter}"
                                                             SelectionMode="Single"
                                                             Padding="0"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                             Background="Transparent">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:PasswordFolderFilterChoice">
                                                                <Border Padding="8,7" CornerRadius="6" Background="Transparent" HorizontalAlignment="Stretch">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" MinHeight="34">
                                                                        <ic:FluentIcon Icon="Folder" FontSize="15" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding FolderDisplayName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip.Tip="{Binding Name}" />
                                                                        <Border Grid.Column="2" Padding="7,2" CornerRadius="9" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Count}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </StackPanel>

                                                <StackPanel IsVisible="{Binding HasRegularPasswordFolderFilters}" Spacing="4">
                                                    <TextBlock Text="{Binding L.Folders}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="6,4,0,0" />
                                                    <ListBox Classes="passwordFolderList"
                                                             ItemsSource="{Binding RegularPasswordFolderFilters}"
                                                             SelectedItem="{Binding SelectedPasswordFolderFilter}"
                                                             SelectionMode="Single"
                                                             Padding="0"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                             Background="Transparent">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:PasswordFolderFilterChoice">
                                                                <Border Padding="8,7" CornerRadius="6" Background="Transparent" HorizontalAlignment="Stretch">
                                                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="7" Margin="{Binding Indent}" MinHeight="34">
                                                                        <Button Classes="passwordInlineCommand"
                                                                                Command="{Binding #Root.DataContext.TogglePasswordFolderExpansionCommand}"
                                                                                CommandParameter="{Binding}"
                                                                                IsEnabled="{Binding HasChildren}"
                                                                                Opacity="{Binding HasChildren, Converter={x:Static local:BoolConverters.ToOpacity}}"
                                                                                Width="28"
                                                                                Height="28"
                                                                                Padding="0"
                                                                                ToolTip.Tip="{Binding Name}">
                                                                            <Panel>
                                                                                <ic:FluentIcon Icon="ChevronDown" FontSize="13" IsVisible="{Binding IsExpanded}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                                <ic:FluentIcon Icon="ChevronRight" FontSize="13" IsVisible="{Binding IsExpanded, Converter={x:Static local:BoolConverters.Not}}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                            </Panel>
                                                                        </Button>
                                                                        <Panel Grid.Column="1" Width="18" Height="18" VerticalAlignment="Center">
                                                                            <ic:FluentIcon Icon="FolderOpen" FontSize="15" IsVisible="{Binding IsExpanded}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                            <ic:FluentIcon Icon="Folder" FontSize="15" IsVisible="{Binding IsExpanded, Converter={x:Static local:BoolConverters.Not}}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Panel>
                                                                        <TextBlock Grid.Column="2" Text="{Binding FolderDisplayName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip.Tip="{Binding Name}" />
                                                                        <Border Grid.Column="3" Padding="7,2" CornerRadius="9" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Count}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </StackPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <Border x:Name="PasswordDetailRegion" Grid.Column="1" Focusable="True" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}" MinWidth="0" ClipToBounds="True">
                                    <Grid RowDefinitions="Auto,*">
                                        <Border IsVisible="{Binding HasSelectedPassword}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="16,14">
                                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                <Border Width="46" Height="46" CornerRadius="23" Background="{DynamicResource AccentFillColorDefaultBrush}" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding SelectedPassword.AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="2" VerticalAlignment="Center" MinWidth="0">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" MinWidth="0">
                                                        <TextBlock Text="{Binding SelectedPasswordTitle}" FontSize="20" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MinWidth="0" MaxWidth="300" HorizontalAlignment="Left" ToolTip.Tip="{Binding SelectedPasswordTitle}" />
                                                        <Border Grid.Column="1" Padding="8,2" CornerRadius="10" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding SelectedPasswordSourceText}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Grid.Row="1" Text="{Binding SelectedPasswordSubtitle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MinWidth="0" MaxWidth="300" HorizontalAlignment="Left" ToolTip.Tip="{Binding SelectedPasswordSubtitle}" />
                                                </Grid>
                                                <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0" Orientation="Horizontal">
                                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding CopyUsernameCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.CopyUsername}">
                                                        <ic:FluentIcon Icon="Copy" FontSize="18" />
                                                    </Button>
                                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding CopyPasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.CopyPassword}">
                                                        <ic:FluentIcon Icon="Key" FontSize="18" />
                                                    </Button>
                                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding CopyWebsiteCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.CopyWebsite}">
                                                        <ic:FluentIcon Icon="Link" FontSize="18" />
                                                    </Button>
                                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding ToggleFavoriteCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.Favorite}">
                                                        <ic:FluentIcon Icon="Star" FontSize="18" />
                                                    </Button>
                                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding EditPasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.EditPassword}">
                                                        <ic:FluentIcon Icon="Edit" FontSize="18" />
                                                    </Button>
                                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding ArchivePasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.ArchivePassword}">
                                                        <ic:FluentIcon Icon="FolderOpen" FontSize="18" />
                                                    </Button>
                                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding DeletePasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.MoveToRecycleBin}">
                                                        <ic:FluentIcon Icon="Delete" FontSize="18" />
                                                    </Button>
                                                </WrapPanel>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Row="1" ClipToBounds="True">
                                            <StackPanel Classes="workspaceEmptyState"
                                                        IsVisible="{Binding HasNoSelectedPassword}"
                                                        Spacing="10"
                                                        Width="260"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="24">
                                                <ic:FluentIcon Icon="Info" FontSize="32" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding L.PasswordDetails}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding PasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel IsVisible="{Binding HasSelectedPasswordLoadingState}"
                                                        Panel.ZIndex="2"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Spacing="12"
                                                        Width="260">
                                                <ProgressBar IsIndeterminate="True" Height="4" />
                                                <TextBlock Text="{Binding L.LoadingPasswordDetails}" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <local:PasswordDetailDialog Margin="16" DataContext="{Binding SelectedPasswordDetails}" ShowHeader="False" IsVisible="{Binding #Root.DataContext.HasCurrentSelectedPasswordDetails}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsArchive}}" RowDefinitions="Auto,*" HorizontalAlignment="Stretch" ClipToBounds="True">
                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                <Grid ColumnDefinitions="*,320,Auto" ColumnSpacing="12" MinHeight="56">
                                    <StackPanel MinWidth="0" VerticalAlignment="Center">
                                        <TextBlock Classes="workspacePageTitle" Text="{Binding L.Archive}" />
                                        <TextBlock Text="{Binding ArchivedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" PlaceholderText="{Binding L.Search}" Text="{Binding SearchText}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Classes="workspacePrimaryCommand" Command="{Binding UnarchivePasswordCommand}" CommandParameter="{Binding SelectedArchivedPassword}" ToolTip.Tip="{Binding L.UnarchivePassword}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="ArrowUndo" FontSize="18" />
                                                <TextBlock Text="{Binding L.UnarchivePassword}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Passwords" ToolTip.Tip="{Binding L.Passwords}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Key" FontSize="16" />
                                                <TextBlock Text="{Binding L.Passwords}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" ColumnDefinitions="300,*" ColumnSpacing="14" MinWidth="0">
                                <Border Classes="archiveFilterRail" ClipToBounds="True">
                                    <Grid RowDefinitions="Auto,*">
                                        <StackPanel Margin="14,12,14,8" Spacing="3">
                                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.Archive}" />
                                            <TextBlock Text="{Binding ArchivedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                        </StackPanel>
                                        <Grid Grid.Row="1">
                                            <StackPanel IsVisible="{Binding !HasFilteredArchivedPasswords}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                                                <ic:FluentIcon Icon="Archive" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding ArchivedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding L.ArchiveEmptyHint}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                                <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Passwords" ToolTip.Tip="{Binding L.Passwords}" HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Key" FontSize="16" />
                                                        <TextBlock Text="{Binding L.Passwords}" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                            <ListBox Classes="archiveRecoveryList" ItemsSource="{Binding FilteredArchivedPasswords}" SelectedItem="{Binding SelectedArchivedPassword}" IsVisible="{Binding HasFilteredArchivedPasswords}" SelectionMode="Single" Margin="8,0,8,8">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="models:PasswordEntry">
                                                        <Border Classes="archiveRecoveryRow">
                                                            <Button Classes="archiveRecoveryRowButton"
                                                                    Command="{Binding #Root.DataContext.ShowArchivedPasswordDetailsCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="{Binding Title}">
                                                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="2">
                                                                    <Border Grid.RowSpan="3" Width="38" Height="38" CornerRadius="19" Background="#5B5FC7" VerticalAlignment="Top">
                                                                        <TextBlock Text="{Binding AvatarText}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Username}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                                </Grid>
                                                            </Button>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Classes="archiveRecoveryPanel" Padding="24" MinWidth="0">
                                    <Grid>
                                        <StackPanel IsVisible="{Binding HasSelectedArchivedPassword}" Spacing="18">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                                <Border Width="54" Height="54" CornerRadius="27" Background="#5B5FC7">
                                                    <TextBlock Text="{Binding SelectedArchivedPassword.AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding SelectedArchivedPassword.Title}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding SelectedArchivedPassword.Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                                                <Button Classes="workspacePrimaryCommand" Command="{Binding UnarchivePasswordCommand}" CommandParameter="{Binding SelectedArchivedPassword}" ToolTip.Tip="{Binding L.UnarchivePassword}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUndo" FontSize="18" />
                                                        <TextBlock Text="{Binding L.UnarchivePassword}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceCommand" Command="{Binding ShowPasswordDetailsCommand}" CommandParameter="{Binding SelectedArchivedPassword}" ToolTip.Tip="{Binding L.PasswordDetails}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <ic:FluentIcon Icon="Info" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.PasswordDetails}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceCommand" Command="{Binding DeletePasswordCommand}" CommandParameter="{Binding SelectedArchivedPassword}" ToolTip.Tip="{Binding L.MoveToRecycleBin}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <ic:FluentIcon Icon="Delete" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.MoveToRecycleBin}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                            <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="14">
                                                <TextBlock Classes="workspaceDetailLabel" Text="{Binding L.Username}" />
                                                <TextBlock Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedArchivedPassword.Username}" />
                                                <TextBlock Grid.Row="1" Classes="workspaceDetailLabel" Text="{Binding L.Website}" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedArchivedPassword.Website}" />
                                                <TextBlock Grid.Row="2" Classes="workspaceDetailLabel" Text="{Binding L.CreatedAt}" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedArchivedPassword.CreatedAt, StringFormat='{}{0:g}'}" />
                                                <TextBlock Grid.Row="3" Classes="workspaceDetailLabel" Text="{Binding L.UpdatedAt}" />
                                                <TextBlock Grid.Row="3" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedArchivedPassword.UpdatedAt, StringFormat='{}{0:g}'}" />
                                                <TextBlock Grid.Row="4" Classes="workspaceDetailLabel" Text="{Binding L.Archive}" />
                                                <TextBlock Grid.Row="4" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedArchivedPassword.ArchivedAt, StringFormat='{}{0:g}'}" />
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel IsVisible="{Binding !HasSelectedArchivedPassword}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="Archive" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding ArchivedPasswordCountText}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsRecycleBin}}" RowDefinitions="Auto,*" HorizontalAlignment="Stretch" ClipToBounds="True">
                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                <Grid ColumnDefinitions="*,320,Auto" ColumnSpacing="12" MinHeight="56">
                                    <StackPanel MinWidth="0" VerticalAlignment="Center">
                                        <TextBlock Classes="workspacePageTitle" Text="{Binding L.DeletedPasswords}" />
                                        <TextBlock Text="{Binding DeletedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" PlaceholderText="{Binding L.Search}" Text="{Binding SearchText}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Classes="workspacePrimaryCommand" Command="{Binding RestorePasswordCommand}" CommandParameter="{Binding SelectedDeletedPassword}" ToolTip.Tip="{Binding L.RestorePassword}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="ArrowUndo" FontSize="18" />
                                                <TextBlock Text="{Binding L.RestorePassword}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Archive" ToolTip.Tip="{Binding L.Archive}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Archive" FontSize="16" />
                                                <TextBlock Text="{Binding L.Archive}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" ColumnDefinitions="300,*" ColumnSpacing="14" MinWidth="0">
                                <Border Classes="recycleFilterRail" ClipToBounds="True">
                                    <Grid RowDefinitions="Auto,*">
                                        <StackPanel Margin="14,12,14,8" Spacing="3">
                                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.DeletedPasswords}" />
                                            <TextBlock Text="{Binding DeletedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                        </StackPanel>
                                        <Grid Grid.Row="1">
                                            <StackPanel IsVisible="{Binding !HasFilteredDeletedPasswords}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                                                <ic:FluentIcon Icon="Delete" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding DeletedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding L.RecycleBinEmptyHint}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                                <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Passwords" ToolTip.Tip="{Binding L.Passwords}" HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Key" FontSize="16" />
                                                        <TextBlock Text="{Binding L.Passwords}" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                            <ListBox Classes="recycleQueueList" ItemsSource="{Binding FilteredDeletedPasswords}" SelectedItem="{Binding SelectedDeletedPassword}" IsVisible="{Binding HasFilteredDeletedPasswords}" SelectionMode="Single" Margin="8,0,8,8">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="models:PasswordEntry">
                                                        <Border Classes="recycleQueueRow">
                                                            <Button Classes="recycleQueueRowButton"
                                                                    Command="{Binding #Root.DataContext.ShowDeletedPasswordDetailsCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="{Binding Title}">
                                                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="2">
                                                                    <Border Grid.RowSpan="3" Width="38" Height="38" CornerRadius="19" Background="#737373" VerticalAlignment="Top">
                                                                        <TextBlock Text="{Binding AvatarText}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Username}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                                </Grid>
                                                            </Button>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Classes="recycleRiskPanel" Padding="24" MinWidth="0">
                                    <Grid>
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding HasSelectedDeletedPassword}">
                                        <StackPanel Spacing="18">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                                <Border Width="54" Height="54" CornerRadius="27" Background="#737373">
                                                    <TextBlock Text="{Binding SelectedDeletedPassword.AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding SelectedDeletedPassword.Title}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding SelectedDeletedPassword.Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                                                <Button Classes="workspacePrimaryCommand" Command="{Binding RestorePasswordCommand}" CommandParameter="{Binding SelectedDeletedPassword}" ToolTip.Tip="{Binding L.RestorePassword}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUndo" FontSize="18" />
                                                        <TextBlock Text="{Binding L.RestorePassword}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceCommand" Command="{Binding ShowPasswordDetailsCommand}" CommandParameter="{Binding SelectedDeletedPassword}" ToolTip.Tip="{Binding L.PasswordDetails}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <ic:FluentIcon Icon="Info" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.PasswordDetails}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                            <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="14">
                                                <TextBlock Classes="workspaceDetailLabel" Text="{Binding L.Username}" />
                                                <TextBlock Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedDeletedPassword.Username}" />
                                                <TextBlock Grid.Row="1" Classes="workspaceDetailLabel" Text="{Binding L.Website}" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedDeletedPassword.Website}" />
                                                <TextBlock Grid.Row="2" Classes="workspaceDetailLabel" Text="{Binding L.CreatedAt}" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedDeletedPassword.CreatedAt, StringFormat='{}{0:g}'}" />
                                                <TextBlock Grid.Row="3" Classes="workspaceDetailLabel" Text="{Binding L.UpdatedAt}" />
                                                <TextBlock Grid.Row="3" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedDeletedPassword.UpdatedAt, StringFormat='{}{0:g}'}" />
                                                <TextBlock Grid.Row="4" Classes="workspaceDetailLabel" Text="{Binding L.RecycleBin}" />
                                                <TextBlock Grid.Row="4" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedDeletedPassword.DeletedAt, StringFormat='{}{0:g}'}" />
                                            </Grid>
                                            <Border Classes="recycleDangerZone" Padding="14">
                                                <StackPanel Spacing="10">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="{Binding L.DeletePermanently}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding DeletedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12" />
                                                    </StackPanel>
                                                    <Button Classes="workspaceCommand" Command="{Binding DeletePasswordPermanentlyCommand}" CommandParameter="{Binding SelectedDeletedPassword}" ToolTip.Tip="{Binding L.DeletePermanently}" HorizontalAlignment="Left">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <ic:FluentIcon Icon="DeleteDismiss" FontSize="16" />
                                                            <TextBlock Text="{Binding L.DeletePermanently}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Border Height="1" Background="{DynamicResource CardBorderBrush}" />
                                                    <Button Classes="workspaceCommand"
                                                            Command="{Binding EmptyRecycleBinCommand}"
                                                            IsEnabled="{Binding HasDeletedPasswords}"
                                                            ToolTip.Tip="{Binding L.EmptyRecycleBin}"
                                                            HorizontalAlignment="Left">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <ic:FluentIcon Icon="DeleteDismiss" FontSize="16" />
                                                            <TextBlock Text="{Binding L.EmptyRecycleBin}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        </ScrollViewer>
                                        <StackPanel IsVisible="{Binding !HasSelectedDeletedPassword}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="Delete" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding DeletedPasswordCountText}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsTimeline}}" RowDefinitions="Auto,*" HorizontalAlignment="Stretch" ClipToBounds="True">
                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                <Grid ColumnDefinitions="*,320,Auto" ColumnSpacing="12" MinHeight="56">
                                    <StackPanel MinWidth="0" VerticalAlignment="Center">
                                        <TextBlock Classes="workspacePageTitle" Text="{Binding L.Timeline}" />
                                        <TextBlock Text="{Binding TimelineCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" PlaceholderText="{Binding L.Search}" Text="{Binding SearchText}" VerticalAlignment="Center" />
                                    <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Classes="workspaceCommand" Command="{Binding ExportTimelineCommand}" ToolTip.Tip="{Binding L.Export}" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="ArrowDownload" FontSize="18" />
                                                <TextBlock Text="{Binding L.Export}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="workspaceCommand" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                                <TextBlock Text="{Binding L.Refresh}" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" ColumnDefinitions="420,*" ColumnSpacing="14" MinWidth="0">
                                <Border Classes="timelineFilterRail" ClipToBounds="True">
                                    <Grid RowDefinitions="Auto,*">
                                        <StackPanel Margin="14,12,14,8" Spacing="3">
                                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.Timeline}" />
                                            <TextBlock Text="{Binding TimelineCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                        </StackPanel>
                                        <Grid Grid.Row="1">
                                            <StackPanel IsVisible="{Binding !HasTimelineEntries}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                                                <ic:FluentIcon Icon="Clock" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding TimelineCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding L.TimelineEmptyHint}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                                <Button Classes="workspaceCommand" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}" HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowClockwise" FontSize="16" />
                                                        <TextBlock Text="{Binding L.Refresh}" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                            <ListBox Classes="timelineEventStream" ItemsSource="{Binding TimelineEntries}" SelectedItem="{Binding SelectedTimelineEntry}" IsVisible="{Binding HasTimelineEntries}" SelectionMode="Single" Margin="8,0,8,8">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:TimelineEntry">
                                                        <Border Classes="timelineEventRow">
                                                            <Button Classes="timelineEventButton"
                                                                    Command="{Binding #Root.DataContext.ShowTimelineEntryDetailsCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="{Binding Title}">
                                                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="2">
                                                                    <ic:FluentIcon Grid.RowSpan="3" Icon="Clock" FontSize="20" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
                                                                    <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Description}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TimestampText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                                </Grid>
                                                            </Button>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Classes="timelineInspector" Padding="24" MinWidth="0">
                                    <Grid>
                                        <StackPanel IsVisible="{Binding HasSelectedTimelineEntry}" Spacing="18">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                                <Border Width="54" Height="54" CornerRadius="27" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                                    <ic:FluentIcon Icon="Clock" FontSize="24" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding SelectedTimelineEntry.Title}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding SelectedTimelineEntry.TimestampText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding SelectedTimelineEntry.Description}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <WrapPanel Orientation="Horizontal">
                                                <Border Classes="workspaceStatusChip" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding SelectedTimelineEntry.OperationType}" FontSize="12" FontWeight="SemiBold" />
                                                </Border>
                                                <Border Classes="workspaceStatusChip" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding SelectedTimelineEntry.ItemType}" FontSize="12" />
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                        <StackPanel IsVisible="{Binding !HasSelectedTimelineEntry}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="Clock" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding L.TimelineEmptySelectionHint}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsSecurityAnalysis}}" RowDefinitions="Auto,*" MaxWidth="1120" Width="{Binding Bounds.Width, ElementName=WorkspaceHost}" HorizontalAlignment="Left" ClipToBounds="True">
                            <Border Classes="workspacePageHeader">
                                <StackPanel Spacing="8" MinWidth="0">
                                    <TextBlock Classes="workspacePageTitle" Text="{Binding L.SecurityAnalysis}" />
                                    <TextBlock Classes="workspacePageSubtitle" Text="{Binding L.SecurityAnalysisSubtitle}" MaxWidth="760" />
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Classes="workspacePrimaryCommand" Command="{Binding CheckCompromisedPasswordsCommand}" IsEnabled="{Binding !IsCheckingCompromisedPasswords}" ToolTip.Tip="{Binding L.CheckCompromisedPasswords}" Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Shield" FontSize="18" />
                                                <TextBlock Text="{Binding L.CheckCompromisedPasswords}" />
                                            </StackPanel>
                                        </Button>
                                        <TextBlock Text="{Binding CompromisedPasswordStatus}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,0,8" MaxWidth="620" />
                                    </WrapPanel>
                                    <ItemsControl ItemsSource="{Binding SecuritySummaryItems}" MaxWidth="{Binding Bounds.Width, ElementName=WorkspaceHost}" HorizontalAlignment="Left">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SecuritySummaryItem">
                                                <Border Width="138" MinHeight="80" Margin="0,0,8,8" Padding="10" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                        <TextBlock Text="{Binding Value}" FontSize="20" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12" MaxLines="2" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="16" MinWidth="0">
                                <Border Classes="workspaceSidebar" ClipToBounds="True">
                                    <Grid RowDefinitions="Auto,*">
                                        <StackPanel Margin="14,12,14,8" Spacing="3">
                                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.SecurityAnalysis}" />
                                            <TextBlock Text="{Binding SecurityIssueCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                        </StackPanel>
                                        <Grid Grid.Row="1">
                                            <StackPanel IsVisible="{Binding !HasSecurityIssues}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                                                <ic:FluentIcon Icon="Shield" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding SecurityIssueCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ListBox Classes="workspaceList" ItemsSource="{Binding SecurityIssueItems}" SelectedItem="{Binding SelectedSecurityIssue}" IsVisible="{Binding HasSecurityIssues}" SelectionMode="Single" Margin="8,0,8,8">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:SecurityIssueItem">
                                                        <Border Classes="workspaceListRow">
                                                            <Button Classes="workspaceListRowButton"
                                                                    Command="{Binding #Root.DataContext.ShowSecurityIssueDetailsCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="{Binding Title}">
                                                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="3">
                                                                    <ic:FluentIcon Grid.RowSpan="3" Icon="Key" FontSize="20" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
                                                                    <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Subtitle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                                    <WrapPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                                                        <Border Classes="workspaceStatusChip" Margin="0,0,6,4">
                                                                            <TextBlock Text="{Binding Category}" FontSize="12" FontWeight="SemiBold" />
                                                                        </Border>
                                                                        <Border Classes="workspaceStatusChip" Margin="0,0,6,4">
                                                                            <TextBlock Text="{Binding Severity}" FontSize="12" />
                                                                        </Border>
                                                                    </WrapPanel>
                                                                </Grid>
                                                            </Button>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Classes="workspacePane" Padding="20" MinWidth="0">
                                    <Grid>
                                        <StackPanel IsVisible="{Binding HasSelectedSecurityIssue}" Spacing="18">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                                <Border Width="54" Height="54" CornerRadius="27" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                                    <ic:FluentIcon Icon="Shield" FontSize="24" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding SelectedSecurityIssue.Title}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding SelectedSecurityIssue.Subtitle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel Orientation="Horizontal">
                                                <Border Classes="workspaceStatusChip" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding SelectedSecurityIssue.Category}" FontSize="12" FontWeight="SemiBold" />
                                                </Border>
                                                <Border Classes="workspaceStatusChip" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding SelectedSecurityIssue.Severity}" FontSize="12" />
                                                </Border>
                                            </WrapPanel>
                                            <WrapPanel Orientation="Horizontal" MaxWidth="280" HorizontalAlignment="Left">
                                                <Button Classes="workspacePrimaryCommand" Command="{Binding ShowPasswordDetailsCommand}" CommandParameter="{Binding SelectedSecurityIssue.Entry}" ToolTip.Tip="{Binding L.PasswordDetails}" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Info" FontSize="18" />
                                                        <TextBlock Text="{Binding L.PasswordDetails}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceCommand" Command="{Binding EditPasswordCommand}" CommandParameter="{Binding SelectedSecurityIssue.Entry}" ToolTip.Tip="{Binding L.EditPassword}" Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <ic:FluentIcon Icon="Edit" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.EditPassword}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                        <StackPanel IsVisible="{Binding !HasSelectedSecurityIssue}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="Shield" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding SecurityIssueCountText}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsTotp}}"
                              RowDefinitions="Auto,*"
                              HorizontalAlignment="Stretch"
                              ClipToBounds="True">
                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                <Grid ColumnDefinitions="*,320,Auto" ColumnSpacing="12" MinHeight="56">
                                    <StackPanel MinWidth="0" VerticalAlignment="Center">
                                        <TextBlock Classes="workspacePageTitle" Text="{Binding L.TwoStepVerification}" />
                                        <TextBlock Text="{Binding TotpConsoleStatusText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1"
                                             PlaceholderText="{Binding L.Search}"
                                             Text="{Binding SearchText}"
                                             VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Classes="workspacePrimaryCommand" Command="{Binding AddTotpCommand}" ToolTip.Tip="{Binding L.AddAuthenticator}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Add" FontSize="18" />
                                                <TextBlock Text="{Binding TotpManualAddText}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="workspaceCommand" Command="{Binding ScanTotpQrCommand}" ToolTip.Tip="{Binding TotpScanQrText}" AutomationProperties.Name="{Binding TotpScanQrText}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <ic:FluentIcon Icon="Document" FontSize="16" />
                                                <TextBlock Text="{Binding TotpScanQrText}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="workspaceCommand" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}" AutomationProperties.Name="{Binding L.Refresh}" Width="36" Height="36" Padding="0">
                                            <ic:FluentIcon Icon="ArrowClockwise" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>
                                        <Button Classes="workspaceCommand" ToolTip.Tip="{Binding TotpMoreActionsText}" AutomationProperties.Name="{Binding TotpMoreActionsText}" Width="36" Height="36" Padding="0">
                                            <ic:FluentIcon Icon="MoreHorizontal" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuItem Header="{Binding L.ImportTotpCsv}" Command="{Binding ImportTotpCsvFileCommand}" IsEnabled="{Binding CanUseFilePicker}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="ArrowUpload" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding L.ImportAegisJson}" Command="{Binding ImportAegisJsonFileCommand}" IsEnabled="{Binding CanUseFilePicker}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="ArrowUpload" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator />
                                                    <MenuItem Header="{Binding L.SaveTotpCsvExport}" Command="{Binding SaveTotpCsvExportCommand}" IsEnabled="{Binding CanUseFilePicker}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="ArrowDownload" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding L.SaveAegisExport}" Command="{Binding SaveAegisJsonExportCommand}" IsEnabled="{Binding CanUseFilePicker}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="ArrowDownload" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator />
                                                    <MenuItem Header="{Binding TotpShowHiddenText}" IsEnabled="False">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="Info" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding SortTitleText}" IsEnabled="False">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="TextBulletList" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding TotpHelpText}" IsEnabled="False">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="Info" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" ColumnSpacing="14" MinWidth="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding TotpAccountColumnWidth}" />
                                    <ColumnDefinition Width="{Binding TotpCodeColumnWidth}" />
                                    <ColumnDefinition Width="{Binding TotpInspectorColumnWidth}" />
                                </Grid.ColumnDefinitions>
                                <Border Classes="workspaceSidebar" ClipToBounds="True">
                                <Grid RowDefinitions="Auto,Auto,*,Auto">
                                    <Grid Margin="14,12,14,8" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Spacing="3">
                                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding TotpFilterTitleText}" />
                                            <TextBlock Text="{Binding TotpFilteredStatusText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" MaxLines="2" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Classes="workspaceCommand" Command="{Binding AddTotpCommand}" ToolTip.Tip="{Binding L.AddAuthenticator}" AutomationProperties.Name="{Binding L.AddAuthenticator}" Width="34" Height="34" Padding="0">
                                            <ic:FluentIcon Icon="Add" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>
                                    </Grid>
                                    <ScrollViewer Grid.Row="1"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto"
                                                  MaxHeight="176"
                                                  Margin="8,0,8,8">
                                        <StackPanel Spacing="2">
                                            <ItemsControl ItemsSource="{Binding TotpFilterChoices}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:TotpFilterChoice">
                                                        <Button Classes="totpFilterButton"
                                                                Command="{Binding #Root.DataContext.SelectTotpFilterCommand}"
                                                                CommandParameter="{Binding Key}"
                                                                ToolTip.Tip="{Binding Label}">
                                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" MinWidth="0" Margin="{Binding Indent}">
                                                                <Border Width="3"
                                                                        Height="18"
                                                                        CornerRadius="2"
                                                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                                        IsVisible="{Binding IsSelected}" />
                                                                <TextBlock Grid.Column="1" Text="{Binding Label}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                <Border Grid.Column="2" Classes="workspaceStatusChip">
                                                                    <TextBlock Text="{Binding Count}" FontSize="12" />
                                                                </Border>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                    <Grid Grid.Row="2">
                                    <ListBox Classes="totpAccountList"
                                             ItemsSource="{Binding FilteredTotpItems}"
                                             SelectedItem="{Binding SelectedTotpItem}"
                                             SelectionMode="Single"
                                             IsVisible="{Binding HasFilteredTotpItems}"
                                             Margin="8,0,8,8">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:SecureItem">
                                                <Border Classes="totpAccountRow">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Copy}" Command="{Binding #Root.DataContext.CopyTotpCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Copy" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Edit}" Command="{Binding #Root.DataContext.EditTotpCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Edit" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Favorite}" Command="{Binding #Root.DataContext.ToggleTotpFavoriteCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Star" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Select}" Command="{Binding #Root.DataContext.ToggleTotpSelectionCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator />
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Delete}" Command="{Binding #Root.DataContext.DeleteTotpCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Delete" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Button Classes="totpAccountButton"
                                                                Command="{Binding #Root.DataContext.ShowTotpDetailsCommand}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip.Tip="{Binding Title}">
                                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4" MinWidth="0">
                                                            <Border Grid.RowSpan="3" Width="38" Height="38" CornerRadius="19" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1" VerticalAlignment="Top">
                                                                <ic:FluentIcon Icon="Key" FontSize="17" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <Grid Grid.Column="1" ColumnDefinitions="*,Auto" MinWidth="0">
                                                                <StackPanel Orientation="Horizontal" Spacing="6" MinWidth="0">
                                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                    <ic:FluentIcon Icon="Star" FontSize="14" Foreground="{DynamicResource SystemFillColorCautionBrush}" IsVisible="{Binding IsFavorite}" />
                                                                </StackPanel>
                                                                <Border Grid.Column="1" Classes="workspaceStatusChip" Margin="8,0,0,0">
                                                                    <TextBlock Text="{Binding TotpTimeRemaining}" FontSize="12" />
                                                                </Border>
                                                            </Grid>
                                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Notes}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                            <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*" MinWidth="0">
                                                                <ProgressBar Maximum="100" Value="{Binding TotpProgress}" Height="4" VerticalAlignment="Center" />
                                                            </Grid>
                                                        </Grid>
                                                    </Button>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <StackPanel IsVisible="{Binding !HasFilteredTotpItems}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                                        <ic:FluentIcon Icon="Key" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding TotpEmptyStateText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                                        <Button Classes="workspacePrimaryCommand" Command="{Binding AddTotpCommand}" ToolTip.Tip="{Binding L.AddAuthenticator}" HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Add" FontSize="18" />
                                                <TextBlock Text="{Binding TotpManualAddText}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="workspaceCommand" Command="{Binding ScanTotpQrCommand}" ToolTip.Tip="{Binding TotpScanQrText}" HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Document" FontSize="16" />
                                                <TextBlock Text="{Binding TotpScanQrText}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="workspaceCommand" Command="{Binding ClearTotpFiltersCommand}" IsVisible="{Binding HasTotpFilterOrSearch}" ToolTip.Tip="{Binding ClearTotpFiltersText}" HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Dismiss" FontSize="12" />
                                                <TextBlock Text="{Binding ClearTotpFiltersText}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    </Grid>

                                    <Border Grid.Row="3"
                                            Padding="12"
                                            CornerRadius="12"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1,1,0,0"
                                            Background="{DynamicResource LayerFillColorSubtleBrush}"
                                            IsVisible="{Binding HasSelectedTotpItems}">
                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                                                <TextBlock Text="{Binding SelectedTotpCountText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Classes="workspaceCommand" Command="{Binding FavoriteSelectedTotpCommand}" ToolTip.Tip="{Binding L.BatchFavorite}" AutomationProperties.Name="{Binding L.BatchFavorite}" Width="34" Height="34" Padding="0">
                                                <ic:FluentIcon Icon="Star" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                            <Button Grid.Column="2" Classes="workspaceCommand" Command="{Binding DeleteSelectedTotpCommand}" ToolTip.Tip="{Binding L.BatchDelete}" AutomationProperties.Name="{Binding L.BatchDelete}" Width="34" Height="34" Padding="0">
                                                <ic:FluentIcon Icon="Delete" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                            <Button Grid.Column="3" Classes="workspaceCommand" Command="{Binding ClearTotpSelectionCommand}" ToolTip.Tip="{Binding L.Cancel}" AutomationProperties.Name="{Binding L.Cancel}" Width="34" Height="34" Padding="0">
                                                <ic:FluentIcon Icon="Dismiss" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                                </Border>

                                <Border Grid.Column="1" Classes="totpCodeConsole" Padding="{Binding TotpCodeConsolePadding}" MinWidth="0" ClipToBounds="True">
                                    <Grid>
                                    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" IsVisible="{Binding HasSelectedTotpItem}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                            <Border Width="50" Height="50" CornerRadius="25" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                                <ic:FluentIcon Icon="Key" FontSize="22" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding SelectedTotpDetails.Title}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <ic:FluentIcon Icon="Star" FontSize="16" Foreground="{DynamicResource SystemFillColorCautionBrush}" IsVisible="{Binding SelectedTotpItem.IsFavorite}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding SelectedTotpDetails.Account}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding SelectedTotpItem.TotpTimeRemaining}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        </Grid>

                                        <StackPanel Grid.Row="1" Margin="0,28,0,0" Spacing="14" HorizontalAlignment="Center" MaxWidth="520">
                                            <TextBlock Text="{Binding L.TotpCode}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding SelectedTotpItem.TotpCode}" FontFamily="Consolas" FontSize="{Binding TotpCodeFontSize}" FontWeight="Bold" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" />
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" MaxWidth="360" HorizontalAlignment="Stretch">
                                                <ProgressBar Maximum="100" Value="{Binding SelectedTotpItem.TotpProgress}" Height="6" VerticalAlignment="Center" />
                                                <Border Grid.Column="1" Classes="workspaceStatusChip">
                                                    <TextBlock Text="{Binding SelectedTotpItem.TotpTimeRemaining}" FontSize="12" FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                        </StackPanel>

                                        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,18,0,8" HorizontalAlignment="Center">
                                            <Button Classes="workspacePrimaryCommand" Command="{Binding CopyTotpCommand}" CommandParameter="{Binding SelectedTotpItem}" ToolTip.Tip="{Binding L.CopyCode}" Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Copy" FontSize="18" />
                                                    <TextBlock Text="{Binding L.CopyCode}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceCommand" Command="{Binding EditTotpCommand}" CommandParameter="{Binding SelectedTotpItem}" ToolTip.Tip="{Binding L.Edit}" Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <ic:FluentIcon Icon="Edit" FontSize="16" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding L.Edit}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceCommand" Command="{Binding ToggleTotpFavoriteCommand}" CommandParameter="{Binding SelectedTotpItem}" ToolTip.Tip="{Binding L.Favorite}" AutomationProperties.Name="{Binding L.Favorite}" Width="36" Height="36" Padding="0" Margin="0,0,0,8">
                                                <ic:FluentIcon Icon="Star" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                        </WrapPanel>

                                        <Border Grid.Row="3" Margin="0,12,0,0" Padding="14" CornerRadius="8" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Top">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <ic:FluentIcon Icon="Clock" FontSize="18" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="1" Text="{Binding L.TotpPageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                        <StackPanel IsVisible="{Binding !HasSelectedTotpItem}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="Key" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding L.TotpPageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Classes="totpInspector" Padding="16" ClipToBounds="True">
                                    <Grid>
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding HasSelectedTotpItem}">
                                            <StackPanel Spacing="16">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.Details}" />
                                                    <TextBlock Text="{Binding SelectedTotpDetails.Issuer}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                </StackPanel>

                                                <ItemsControl ItemsSource="{Binding SelectedTotpDetails.Fields}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:WalletFieldDisplayItem">
                                                            <Grid RowDefinitions="Auto,Auto" Margin="0,0,0,10">
                                                                <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock Grid.Row="1" Text="{Binding Value}" TextWrapping="Wrap" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <StackPanel Spacing="4" IsVisible="{Binding SelectedTotpDetails.HasNotes}">
                                                    <TextBlock Text="{Binding L.Notes}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SelectedTotpDetails.Notes}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>

                                                <Border Classes="totpRiskZone" Padding="14">
                                                    <StackPanel Spacing="10">
                                                        <StackPanel Spacing="3">
                                                            <TextBlock Text="{Binding L.Delete}" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding L.TotpPageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12" />
                                                        </StackPanel>
                                                        <Button Classes="workspaceCommand" Command="{Binding DeleteTotpCommand}" CommandParameter="{Binding SelectedTotpItem}" ToolTip.Tip="{Binding L.Delete}" HorizontalAlignment="Left">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <ic:FluentIcon Icon="Delete" FontSize="16" />
                                                                <TextBlock Text="{Binding L.Delete}" />
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <StackPanel IsVisible="{Binding !HasSelectedTotpItem}" Spacing="10" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="Info" FontSize="28" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Text="{Binding L.Details}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.TotpPageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsCards}}"
                              RowDefinitions="Auto,*"
                              HorizontalAlignment="Stretch"
                              ClipToBounds="True">
                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                <Grid ColumnDefinitions="*,320,Auto" ColumnSpacing="12" MinHeight="56">
                                    <StackPanel MinWidth="0" VerticalAlignment="Center">
                                        <TextBlock Classes="workspacePageTitle" Text="{Binding L.Wallet}" />
                                        <TextBlock Text="{Binding WalletCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1"
                                             PlaceholderText="{Binding L.Search}"
                                             Text="{Binding SearchText}"
                                             VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Classes="workspacePrimaryCommand" Command="{Binding AddWalletItemCommand}" ToolTip.Tip="{Binding L.AddItem}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Add" FontSize="18" />
                                                <TextBlock Text="{Binding L.AddItem}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" ColumnDefinitions="300,*,300" ColumnSpacing="14" MinWidth="0">
                                <Border Classes="workspaceSidebar" ClipToBounds="True">
                                <Grid RowDefinitions="Auto,*,Auto">
                                    <Grid Margin="14,12,14,8" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Spacing="3">
                                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.Wallet}" />
                                            <TextBlock Text="{Binding L.WalletPageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" MaxLines="2" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Classes="workspaceCommand" Command="{Binding AddWalletItemCommand}" ToolTip.Tip="{Binding L.AddItem}" AutomationProperties.Name="{Binding L.AddItem}" Width="34" Height="34" Padding="0">
                                            <ic:FluentIcon Icon="Add" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>
                                    </Grid>
                                    <Grid Grid.Row="1">
                                    <ListBox Classes="walletItemList"
                                             ItemsSource="{Binding WalletItems}"
                                             SelectedItem="{Binding SelectedWalletItem}"
                                             SelectionMode="Single"
                                             IsVisible="{Binding HasWalletItems}"
                                             Margin="8,0,8,8">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:SecureItem">
                                                <Border Classes="walletItemRow">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Details}" Command="{Binding #Root.DataContext.ShowWalletDetailsCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Info" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Edit}" Command="{Binding #Root.DataContext.EditWalletItemCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Edit" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Select}" Command="{Binding #Root.DataContext.ToggleWalletSelectionCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator />
                                                            <MenuItem Header="{Binding #Root.DataContext.L.Delete}" Command="{Binding #Root.DataContext.DeleteWalletItemCommand}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Delete" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Button Classes="walletItemButton"
                                                                Command="{Binding #Root.DataContext.ShowWalletDetailsCommand}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip.Tip="{Binding Title}">
                                                        <Grid ColumnDefinitions="Auto,*" MinHeight="62" ColumnSpacing="10">
                                                            <Border Width="44" Height="44" CornerRadius="8" Background="{DynamicResource AccentFillColorDefaultBrush}" VerticalAlignment="Top">
                                                                    <ic:FluentIcon Icon="WalletCreditCard" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="0" Spacing="3">
                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding Notes}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                                <Border Classes="workspaceStatusChip" HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding ItemType}" FontSize="12" />
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <StackPanel IsVisible="{Binding !HasWalletItems}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                                        <ic:FluentIcon Icon="WalletCreditCard" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding L.WalletPageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                                        <Button Classes="workspacePrimaryCommand" Command="{Binding AddWalletItemCommand}" ToolTip.Tip="{Binding L.AddItem}" HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Add" FontSize="18" />
                                                <TextBlock Text="{Binding L.AddItem}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    </Grid>

                                    <Border Grid.Row="2"
                                            Padding="12"
                                            CornerRadius="12"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1,1,0,0"
                                            Background="{DynamicResource LayerFillColorSubtleBrush}"
                                            IsVisible="{Binding HasSelectedWalletItems}">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                                                <TextBlock Text="{Binding SelectedWalletCountText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Classes="workspaceCommand" Command="{Binding DeleteSelectedWalletItemsCommand}" ToolTip.Tip="{Binding L.BatchDelete}" AutomationProperties.Name="{Binding L.BatchDelete}" Width="34" Height="34" Padding="0">
                                                <ic:FluentIcon Icon="Delete" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                            <Button Grid.Column="2" Classes="workspaceCommand" Command="{Binding ClearWalletSelectionCommand}" ToolTip.Tip="{Binding L.Cancel}" AutomationProperties.Name="{Binding L.Cancel}" Width="34" Height="34" Padding="0">
                                                <ic:FluentIcon Icon="Dismiss" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                                </Border>

                                <Border Grid.Column="1" Classes="walletWorkbench" Padding="24" MinWidth="0" ClipToBounds="True">
                                    <Grid>
                                    <Grid RowDefinitions="Auto,Auto,*" IsVisible="{Binding HasSelectedWalletItem}">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                            <Border Width="56" Height="56" CornerRadius="10" Background="{DynamicResource AccentFillColorDefaultBrush}">
                                                <ic:FluentIcon Icon="WalletCreditCard" FontSize="26" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="0">
                                                <TextBlock Text="{Binding SelectedWalletDetails.Title}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding SelectedWalletDetails.KindText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0" Spacing="8" HorizontalAlignment="Left">
                                            <Button Classes="workspaceCommand" Command="{Binding EditWalletItemCommand}" CommandParameter="{Binding SelectedWalletItem}" ToolTip.Tip="{Binding L.Edit}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <ic:FluentIcon Icon="Edit" FontSize="16" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding L.Edit}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>

                                        <ScrollViewer Grid.Row="2" Margin="0,18,0,0" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel Spacing="16">
                                                <Border Padding="20" CornerRadius="12" Background="#172F7DFF" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" MaxWidth="420" HorizontalAlignment="Left">
                                                    <Grid RowDefinitions="Auto,*,Auto" MinHeight="170">
                                                        <TextBlock Text="{Binding SelectedWalletDetails.KindText}" FontWeight="SemiBold" />
                                                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="4">
                                                            <TextBlock Text="{Binding SelectedWalletDetails.PrimaryText}" FontSize="24" FontFamily="Consolas" FontWeight="Bold" />
                                                            <TextBlock Text="{Binding SelectedWalletDetails.SecondaryText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Row="2" Text="{Binding SelectedWalletDetails.ExpiryText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </Grid>
                                                </Border>

                                                <ItemsControl ItemsSource="{Binding SelectedWalletDetails.Fields}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:WalletFieldDisplayItem">
                                                            <Grid ColumnDefinitions="130,*,Auto" Margin="0,0,0,8" ColumnSpacing="8">
                                                                <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap" />
                                                                <Button Grid.Column="2" Classes="workspaceCommand" Command="{Binding #Root.DataContext.CopyWalletFieldCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.Copy}" Width="32" Height="32" Padding="0" VerticalAlignment="Top">
                                                                    <ic:FluentIcon Icon="Copy" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Button>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>

                                        <StackPanel IsVisible="{Binding !HasSelectedWalletItem}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="WalletCreditCard" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding L.WalletPageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                                            <Button Classes="workspacePrimaryCommand" Command="{Binding AddWalletItemCommand}" ToolTip.Tip="{Binding L.AddItem}" HorizontalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Add" FontSize="18" />
                                                    <TextBlock Text="{Binding L.AddItem}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Classes="walletInspector" Padding="16" ClipToBounds="True">
                                    <Grid>
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding HasSelectedWalletItem}">
                                            <StackPanel Spacing="16">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.Details}" />
                                                    <TextBlock Text="{Binding SelectedWalletDetails.KindText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                </StackPanel>

                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="{Binding L.DocumentPhotos}" FontWeight="SemiBold" />
                                                    <ItemsControl ItemsSource="{Binding SelectedWalletDetails.ImagePaths}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Padding="10" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Margin="0,0,0,8">
                                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Text="{Binding L.NoDocumentPhotos}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" IsVisible="{Binding !SelectedWalletDetails.HasImages}" />
                                                </StackPanel>

                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding L.Notes}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SelectedWalletDetails.Notes}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>

                                                <Border Classes="walletRiskZone" Padding="14">
                                                    <StackPanel Spacing="10">
                                                        <StackPanel Spacing="3">
                                                            <TextBlock Text="{Binding L.Delete}" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding L.WalletPageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12" />
                                                        </StackPanel>
                                                        <Button Classes="workspaceCommand" Command="{Binding DeleteWalletItemCommand}" CommandParameter="{Binding SelectedWalletItem}" ToolTip.Tip="{Binding L.Delete}" HorizontalAlignment="Left">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <ic:FluentIcon Icon="Delete" FontSize="16" />
                                                                <TextBlock Text="{Binding L.Delete}" />
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <StackPanel IsVisible="{Binding !HasSelectedWalletItem}" Spacing="10" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="Info" FontSize="28" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Text="{Binding L.Details}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.WalletPageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                </Grid>
                            </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsSettings}}"
                              RowDefinitions="Auto,*"
                              MaxWidth="1080"
                              Width="{Binding Bounds.Width, ElementName=WorkspaceHost}"
                              HorizontalAlignment="Left"
                              ClipToBounds="True">
                            <Border Classes="workspacePageHeader">
                                <StackPanel MinWidth="0" Spacing="3">
                                    <TextBlock Classes="workspacePageTitle" Text="{Binding L.Settings}" />
                                    <TextBlock Classes="workspacePageSubtitle" Text="{Binding L.SettingsSubtitle}" />
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1" ColumnDefinitions="260,*" ColumnSpacing="16" MinWidth="0">
                                <Border Classes="workspaceSidebar" Padding="14" ClipToBounds="True">
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Spacing="8">
                                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.Settings}" Margin="2,0,0,4" />
                                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsGeneralSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="General">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <ic:FluentIcon Icon="Settings" FontSize="17" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding L.General}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsSecuritySelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="Security">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <ic:FluentIcon Icon="Shield" FontSize="17" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding L.Security}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsSecurityRecoverySelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="SecurityRecovery">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <ic:FluentIcon Icon="Key" FontSize="17" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding SecurityRecoveryTitle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsDataSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="Data">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <ic:FluentIcon Icon="Save" FontSize="17" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding L.DataManagement}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsDesktopSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="Desktop">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <ic:FluentIcon Icon="Desktop" FontSize="17" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding L.Desktop}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsIntegrationsSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="Integrations">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <ic:FluentIcon Icon="Link" FontSize="17" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding PlatformIntegrationsTitle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsAboutSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="About">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <ic:FluentIcon Icon="Info" FontSize="17" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding AboutTitle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsDangerSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="Danger">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <ic:FluentIcon Icon="Delete" FontSize="17" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding DangerZoneTitle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                                    <StackPanel Spacing="14" MaxWidth="760" HorizontalAlignment="Stretch">

                                <fa:FASettingsExpander Header="{Binding L.General}" Description="{Binding L.GeneralSettingsDescription}" IsExpanded="True" IsVisible="{Binding IsSettingsGeneralSelected}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Setting" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.Language}" Description="{Binding L.LanguageDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="220" ItemsSource="{Binding LanguageOptions}" SelectedValue="{Binding SettingsLanguage}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.Theme}" Description="{Binding L.ThemeDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="220" ItemsSource="{Binding ThemeOptions}" SelectedValue="{Binding SettingsTheme}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.StartupView}" Description="{Binding L.StartupViewDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="220" ItemsSource="{Binding StartupSectionOptions}" SelectedValue="{Binding StartupSection}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.Security}" Description="{Binding L.SecuritySettingsDescription}" IsExpanded="True" IsVisible="{Binding IsSettingsSecuritySelected}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Permissions" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.AutoLock}" Description="{Binding L.AutoLockDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding AutoLockEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.AutoLockAfter}" Description="{Binding L.AutoLockAfterDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="180" ItemsSource="{Binding AutoLockMinuteOptions}" SelectedValue="{Binding AutoLockMinutes}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.ClearClipboard}" Description="{Binding L.ClearClipboardDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding ClearClipboardEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.ClearClipboardAfter}" Description="{Binding L.ClearClipboardAfterDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="180" ItemsSource="{Binding ClipboardSecondOptions}" SelectedValue="{Binding ClipboardClearSeconds}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.RequirePasswordBeforeExport}" Description="{Binding L.RequirePasswordBeforeExportDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding RequirePasswordBeforeExport}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding ChangeMasterPasswordTitle}" Description="{Binding ChangeMasterPasswordDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Spacing="8" Margin="16,0,0,0" MaxWidth="420">
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding CurrentMasterPasswordText}" Text="{Binding CurrentMasterPassword}" IsEnabled="{Binding !IsChangingMasterPassword}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding NewMasterPasswordText}" Text="{Binding NewMasterPassword}" IsEnabled="{Binding !IsChangingMasterPassword}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding ConfirmNewMasterPasswordText}" Text="{Binding ConfirmNewMasterPassword}" IsEnabled="{Binding !IsChangingMasterPassword}" />
                                                    <Button Command="{Binding ChangeMasterPasswordCommand}" IsEnabled="{Binding !IsChangingMasterPassword}" HorizontalAlignment="Right">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Key" FontSize="18" />
                                                            <TextBlock Text="{Binding ChangeMasterPasswordActionText}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding SecurityRecoveryTitle}" Description="{Binding SecurityRecoveryDescription}" IsExpanded="True" IsVisible="{Binding IsSettingsSecurityRecoverySelected}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="ProtectedDocument" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding SecurityRecoveryEnabledText}" Description="{Binding SecurityRecoveryStatusText}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding SecurityRecoveryEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding SecurityQuestion1Text}" Description="{Binding SecurityRecoveryDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Spacing="8" Margin="16,0,0,0" MaxWidth="420">
                                                    <ComboBox Width="360" ItemsSource="{Binding SecurityQuestionOptions}" SelectedValue="{Binding SecurityQuestion1Id}" SelectedValueBinding="{Binding Value}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:SettingsChoice">
                                                                <TextBlock Text="{Binding Label}" TextWrapping="Wrap" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBox IsVisible="{Binding IsSecurityQuestion1Custom}" PlaceholderText="{Binding CustomSecurityQuestionText}" Text="{Binding SecurityQuestion1CustomText}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding SecurityQuestionAnswerText}" Text="{Binding SecurityQuestion1Answer}" />
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding SecurityQuestion2Text}" Description="{Binding SecurityRecoveryDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Spacing="8" Margin="16,0,0,0" MaxWidth="420">
                                                    <ComboBox Width="360" ItemsSource="{Binding SecurityQuestionOptions}" SelectedValue="{Binding SecurityQuestion2Id}" SelectedValueBinding="{Binding Value}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:SettingsChoice">
                                                                <TextBlock Text="{Binding Label}" TextWrapping="Wrap" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBox IsVisible="{Binding IsSecurityQuestion2Custom}" PlaceholderText="{Binding CustomSecurityQuestionText}" Text="{Binding SecurityQuestion2CustomText}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding SecurityQuestionAnswerText}" Text="{Binding SecurityQuestion2Answer}" />
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding SaveSecurityQuestionsText}" Description="{Binding SecurityRecoveryStatusText}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <Button Command="{Binding SaveSecurityQuestionsCommand}">
                                                    <TextBlock Text="{Binding SaveSecurityQuestionsText}" />
                                                </Button>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding ResetMasterPasswordTitle}" Description="{Binding ResetMasterPasswordDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Spacing="8" Margin="16,0,0,0" MaxWidth="460">
                                                    <TextBlock Text="{Binding SecurityRecoveryQuestion1PromptText}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding SecurityQuestionAnswerText}" Text="{Binding SecurityRecoveryAnswer1}" IsEnabled="{Binding CanRunResetMasterPassword}" />
                                                    <TextBlock Text="{Binding SecurityRecoveryQuestion2PromptText}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding SecurityQuestionAnswerText}" Text="{Binding SecurityRecoveryAnswer2}" IsEnabled="{Binding CanRunResetMasterPassword}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding NewMasterPasswordText}" Text="{Binding RecoveryNewMasterPassword}" IsEnabled="{Binding CanRunResetMasterPassword}" />
                                                    <TextBox PasswordChar="*" PlaceholderText="{Binding ConfirmNewMasterPasswordText}" Text="{Binding RecoveryConfirmNewMasterPassword}" IsEnabled="{Binding CanRunResetMasterPassword}" />
                                                    <Button Command="{Binding ResetMasterPasswordWithSecurityQuestionsCommand}" IsEnabled="{Binding CanRunResetMasterPassword}" HorizontalAlignment="Right">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Key" FontSize="18" />
                                                            <TextBlock Text="{Binding ResetMasterPasswordActionText}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.DataManagement}" Description="{Binding L.DataManagementDescription}" IsExpanded="True" IsVisible="{Binding IsSettingsDataSelected}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Save" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.ImportData}" Description="{Binding L.ImportDataDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FilePickerIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="240" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <Button Command="{Binding ImportMonicaJsonFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Folder" FontSize="18" />
                                                            <TextBlock Text="{Binding L.ImportMonicaJson}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding ImportPasswordCsvFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Folder" FontSize="18" />
                                                            <TextBlock Text="{Binding L.ImportPasswordCsv}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding ImportAegisJsonFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Folder" FontSize="18" />
                                                            <TextBlock Text="{Binding L.ImportAegisJson}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding ImportTotpCsvFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Folder" FontSize="18" />
                                                            <TextBlock Text="{Binding L.ImportTotpCsv}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.ExportData}" Description="{Binding L.ExportDataDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FilePickerIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="240" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <Button Command="{Binding SaveMonicaJsonExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Save" FontSize="18" />
                                                            <TextBlock Text="{Binding L.SaveJsonExport}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding SavePasswordCsvExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Save" FontSize="18" />
                                                            <TextBlock Text="{Binding L.SaveCsvExport}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding SaveTotpCsvExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Save" FontSize="18" />
                                                            <TextBlock Text="{Binding L.SaveTotpCsvExport}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding SaveAegisJsonExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Save" FontSize="18" />
                                                            <TextBlock Text="{Binding L.SaveAegisExport}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.WebDav}" Description="{Binding L.RemoteSyncDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <Button Command="{Binding SelectSectionCommand}" CommandParameter="Sync" Margin="16,0,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                                        <TextBlock Text="{Binding L.SyncAndBackup}" />
                                                    </StackPanel>
                                                </Button>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.Desktop}" Description="{Binding L.DesktopSettingsDescription}" IsExpanded="True" IsVisible="{Binding IsSettingsDesktopSelected}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="ContactInfo" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.MinimizeToTray}" Description="{Binding L.MinimizeToTrayDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TrayIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="260" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <ToggleSwitch IsChecked="{Binding MinimizeToTray}" IsEnabled="{Binding CanUseTrayIntegration}" ToolTip.Tip="{Binding TrayIntegrationStatusText}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.QuickSearch}" Description="{Binding L.QuickSearchDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding QuickSearchEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.QuickSearchHotkey}" Description="{Binding L.QuickSearchHotkeyDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding GlobalHotkeyIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="260" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <TextBox Width="220" Text="{Binding QuickSearchHotkey}" IsEnabled="{Binding CanUseGlobalHotkeyIntegration}" ToolTip.Tip="{Binding GlobalHotkeyIntegrationStatusText}" />
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.BrowserIntegration}" Description="{Binding L.BrowserIntegrationDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding BrowserBridgeIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="260" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <ToggleSwitch IsChecked="{Binding BrowserIntegrationEnabled}" IsEnabled="{Binding CanUseBrowserBridgeIntegration}" ToolTip.Tip="{Binding BrowserBridgeIntegrationStatusText}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.BrowserIntegrationPort}" Description="{Binding L.BrowserIntegrationPortDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <NumericUpDown Width="180" Minimum="1024" Maximum="65535" Increment="1" Value="{Binding BrowserIntegrationPort}" IsEnabled="{Binding CanUseBrowserBridgeIntegration}" ToolTip.Tip="{Binding BrowserBridgeIntegrationStatusText}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.CompactPasswordList}" Description="{Binding L.CompactPasswordListDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding CompactPasswordList}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding PlatformIntegrationsTitle}" Description="{Binding PlatformIntegrationSummaryText}" IsExpanded="True" IsVisible="{Binding IsSettingsIntegrationsSelected}" ItemsSource="{Binding PlatformIntegrationCapabilities}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Permissions" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LocalizedPlatformIntegrationCapability">
                                            <fa:FASettingsExpanderItem Content="{Binding Title}" Description="{Binding Description}">
                                                <fa:FASettingsExpanderItem.Footer>
                                                    <StackPanel Spacing="2" Margin="16,0,0,0" MinWidth="160" MaxWidth="360">
                                                        <TextBlock Text="{Binding Status}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding UnsupportedReason}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" IsVisible="{Binding HasUnsupportedReason}" />
                                                    </StackPanel>
                                                </fa:FASettingsExpanderItem.Footer>
                                            </fa:FASettingsExpanderItem>
                                        </DataTemplate>
                                    </fa:FASettingsExpander.ItemTemplate>
                                </fa:FASettingsExpander>

                                <fa:FAInfoBar IsOpen="True" IsVisible="{Binding IsSettingsIntegrationsSelected}" Severity="Informational" Title="{Binding L.DesktopEquivalents}" Message="{Binding L.DesktopEquivalentsMessage}" />
                                <fa:FASettingsExpander Header="{Binding L.FeatureParityMap}" Description="{Binding L.FeatureParityMapDescription}" IsExpanded="True" IsVisible="{Binding IsSettingsIntegrationsSelected}" ItemsSource="{Binding Capabilities}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Sync" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LocalizedPlatformCapability">
                                            <fa:FASettingsExpanderItem Content="{Binding Title}" Description="{Binding Description}">
                                                <fa:FASettingsExpanderItem.Footer>
                                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                        <StackPanel MinWidth="132" Spacing="2">
                                                            <TextBlock Text="{Binding Status}" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding ToggleStatus}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            <TextBlock Text="{Binding UnsupportedReason}" FontSize="12" TextWrapping="Wrap" MaxWidth="280" Foreground="{DynamicResource TextFillColorSecondaryBrush}" IsVisible="{Binding HasUnsupportedReason}" />
                                                        </StackPanel>
                                                        <ToggleSwitch IsChecked="{Binding IsEnabled, Mode=TwoWay}" IsEnabled="{Binding CanToggle}" ToolTip.Tip="{Binding ToggleStatus}" />
                                                    </StackPanel>
                                                </fa:FASettingsExpanderItem.Footer>
                                            </fa:FASettingsExpanderItem>
                                        </DataTemplate>
                                    </fa:FASettingsExpander.ItemTemplate>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding AboutTitle}" Description="{Binding AboutDescription}" IsExpanded="True" IsVisible="{Binding IsSettingsAboutSelected}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="ContactInfo" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="Monica" Description="{Binding AppVersionText}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <Image Source="/Assets/Logo.png" Width="44" Height="44" />
                                                    <StackPanel Spacing="2" MaxWidth="320">
                                                        <TextBlock Text="{Binding AppVersionLabel}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding AppVersionText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding GitHubRepositoryLabel}" Description="{Binding RepositoryUrlText}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ExternalLinksIntegrationStatusText}" FontSize="12" TextWrapping="Wrap" MaxWidth="260" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <Button Command="{Binding OpenGitHubRepositoryCommand}" IsEnabled="{Binding CanOpenExternalLinks}" ToolTip.Tip="{Binding ExternalLinksIntegrationStatusText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Link" FontSize="18" />
                                                            <TextBlock Text="{Binding OpenRepositoryText}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding DangerZoneTitle}" Description="{Binding DangerZoneDescription}" IsExpanded="True" IsVisible="{Binding IsSettingsDangerSelected}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Delete" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding ClearVaultDataTitle}" Description="{Binding ClearVaultDataDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <StackPanel Spacing="8" Margin="16,0,0,0" MaxWidth="520">
                                                    <TextBlock Text="{Binding ClearVaultConfirmationInstructionText}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                                                    <TextBox PlaceholderText="{Binding ClearVaultConfirmationInstructionText}" Text="{Binding DangerZoneConfirmationText}" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                                        <Button Command="{Binding ClearVaultDataCommand}" CommandParameter="Passwords">
                                                            <TextBlock Text="{Binding ClearPasswordsOnlyText}" />
                                                        </Button>
                                                        <Button Command="{Binding ClearVaultDataCommand}" CommandParameter="SecureItems">
                                                            <TextBlock Text="{Binding ClearSecureItemsOnlyText}" />
                                                        </Button>
                                                        <Button Background="{DynamicResource SystemFillColorCriticalBrush}" Command="{Binding ClearVaultDataCommand}" CommandParameter="All">
                                                            <TextBlock Text="{Binding ClearAllVaultDataText}" />
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsDatabaseManagement}}"
                              RowDefinitions="Auto,*"
                              HorizontalAlignment="Stretch"
                              ClipToBounds="True">
                                <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                        <TextBlock Classes="workspacePageTitle" Text="{Binding L.DatabaseManagement}" />
                                        <TextBlock Grid.Row="1" Classes="workspacePageSubtitle" Text="{Binding VaultSourceCountText}" MaxWidth="720" HorizontalAlignment="Left" />
                                        <WrapPanel Grid.Column="1" Grid.RowSpan="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Classes="workspaceCommand" Command="{Binding LoadCommand}" Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                                    <TextBlock Text="{Binding L.Refresh}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspacePrimaryCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx" Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Database" FontSize="18" />
                                                    <TextBlock Text="{Binding L.MdbxVaults}" />
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="14" MinWidth="0">
                                    <Border Classes="databaseSourceRail" ClipToBounds="True">
                                        <Grid RowDefinitions="Auto,*">
                                            <Grid Margin="14,12,14,8" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.RegisteredDatabases}" />
                                                    <TextBlock Text="{Binding VaultSourceCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Classes="workspaceCommand" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}" AutomationProperties.Name="{Binding L.Refresh}" Width="34" Height="34" Padding="0">
                                                    <ic:FluentIcon Icon="ArrowClockwise" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Button>
                                            </Grid>

                                            <Grid Grid.Row="1">
                                                <StackPanel IsVisible="{Binding !HasVaultSources}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                                                    <ic:FluentIcon Icon="Database" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding L.DatabaseSourcesEmptyHint}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                                    <Button Classes="workspaceCommand" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}" HorizontalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="ArrowClockwise" FontSize="16" />
                                                            <TextBlock Text="{Binding L.Refresh}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>

                                            <ListBox Classes="databaseSourceList" ItemsSource="{Binding VaultSources}" SelectedItem="{Binding SelectedVaultSource}" IsVisible="{Binding HasVaultSources}" SelectionMode="Single" Margin="8,0,8,8">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:VaultSourceDisplayItem">
                                                        <Border Classes="databaseSourceRow">
                                                            <Button Classes="databaseSourceButton"
                                                                    Command="{Binding #Root.DataContext.ShowVaultSourceDetailsCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="{Binding DisplayName}">
                                                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="3">
                                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                    <Border Grid.Column="1" Grid.RowSpan="2" Classes="workspaceStatusChip" VerticalAlignment="Top">
                                                                        <TextBlock Text="{Binding Kind}" FontSize="12" />
                                                                    </Border>
                                                                    <TextBlock Grid.Row="1" Text="{Binding LocalPath}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding SyncStatus}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                                </Grid>
                                                            </Button>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <ScrollViewer x:Name="DatabaseManagementScrollViewer" Grid.Column="1" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                                        <StackPanel Spacing="14" HorizontalAlignment="Stretch">
                                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                                                <Button Classes="databasePivotButton" Classes.accent="{Binding IsDatabaseSourceSelected}" Command="{Binding SelectDatabaseManagementPageCommand}" CommandParameter="Source">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Database" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.RegisteredDatabases}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Classes="databasePivotButton" Classes.accent="{Binding IsDatabaseOverviewSelected}" Command="{Binding SelectDatabaseManagementPageCommand}" CommandParameter="Overview">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Info" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.LocalDatabase}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="2" Classes="databasePivotButton" Classes.accent="{Binding IsDatabaseCloudSelected}" Command="{Binding SelectDatabaseManagementPageCommand}" CommandParameter="Cloud">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Cloud" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.CloudAndLocalVaults}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="3" Classes="databasePivotButton" Classes.accent="{Binding IsDatabaseCapabilitiesSelected}" Command="{Binding SelectDatabaseManagementPageCommand}" CommandParameter="Capabilities">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Link" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.FeatureParityMap}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <Border Classes="databaseWorkbench" Padding="20" MinWidth="0" IsVisible="{Binding IsDatabaseSourceSelected}">
                                                <Grid>
                                                    <StackPanel IsVisible="{Binding HasSelectedVaultSource}" Spacing="18">
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                                            <Border Width="54" Height="54" CornerRadius="27" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                                                <ic:FluentIcon Icon="Database" FontSize="24" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding SelectedVaultSource.DisplayName}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding SelectedVaultSource.Kind}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </StackPanel>
                                                        </Grid>
                                                        <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12" MinWidth="0">
                                                            <TextBlock Classes="workspaceDetailLabel" Text="{Binding L.LocalPath}" />
                                                            <TextBlock Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedVaultSource.LocalPath}" MaxLines="2" />
                                                            <TextBlock Grid.Row="1" Classes="workspaceDetailLabel" Text="{Binding L.MdbxRemotePath}" />
                                                            <TextBlock Grid.Row="1" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedVaultSource.RemoteUrl}" MaxLines="2" />
                                                            <TextBlock Grid.Row="2" Classes="workspaceDetailLabel" Text="{Binding L.SyncOverview}" />
                                                            <TextBlock Grid.Row="2" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedVaultSource.SyncStatus}" MaxLines="2" />
                                                        </Grid>
                                                        <WrapPanel Orientation="Horizontal">
                                                            <Button Classes="workspacePrimaryCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx" Margin="0,0,8,8">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <ic:FluentIcon Icon="Database" FontSize="18" />
                                                                    <TextBlock Text="{Binding L.MdbxVaults}" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Sync" Margin="0,0,0,8">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <ic:FluentIcon Icon="ArrowSync" FontSize="16" VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding L.SyncAndBackup}" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </Button>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                    <StackPanel IsVisible="{Binding !HasSelectedVaultSource}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                        <ic:FluentIcon Icon="Database" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                                        <TextBlock Text="{Binding VaultSourceCountText}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Border Classes="databaseWorkbench" Padding="20" IsVisible="{Binding IsDatabaseOverviewSelected}">
                                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                                                <Border Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                                    <StackPanel Spacing="12">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Database" FontSize="20" />
                                                            <TextBlock Text="{Binding L.LocalDatabase}" FontWeight="SemiBold" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding LocalDatabaseSummaryText}" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="2" />
                                                        <TextBlock Text="{Binding L.LocalDatabaseDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="3" />
                                                        <WrapPanel Orientation="Horizontal">
                                                            <Button Classes="workspaceCommand" Command="{Binding LoadCommand}" Margin="0,0,8,8">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                                                    <TextBlock Text="{Binding L.Refresh}" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Passwords" Margin="0,0,0,8">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <ic:FluentIcon Icon="Key" FontSize="18" />
                                                                    <TextBlock Text="{Binding L.Passwords}" />
                                                                </StackPanel>
                                                            </Button>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                                    <StackPanel Spacing="12">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                            <TextBlock Text="{Binding L.ExternalDatabases}" FontWeight="SemiBold" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding L.ExternalDatabasesDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="4" />
                                                        <WrapPanel Orientation="Horizontal">
                                                            <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Sync" Margin="0,0,8,8">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <ic:FluentIcon Icon="Key" FontSize="16" VerticalAlignment="Center" />
                                                                    <TextBlock Text="KDBX" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx" Margin="0,0,8,8">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <ic:FluentIcon Icon="Database" FontSize="16" VerticalAlignment="Center" />
                                                                    <TextBlock Text="MDBX" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Sync" Margin="0,0,0,8">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <ic:FluentIcon Icon="Cloud" FontSize="16" VerticalAlignment="Center" />
                                                                    <TextBlock Text="Bitwarden" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </Button>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>
                                                </Grid>
                                            </Border>

                                            <Border Classes="databaseWorkbench" Padding="20" IsVisible="{Binding IsDatabaseCloudSelected}">
                                                <StackPanel Spacing="14">
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                        <Border Width="44" Height="44" CornerRadius="22" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                                            <ic:FluentIcon Icon="Cloud" FontSize="22" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding L.CloudAndLocalVaults}" FontSize="20" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding L.CloudAndLocalVaultsDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                                                        <Border Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                                            <StackPanel Spacing="10">
                                                                <TextBlock Text="{Binding L.MdbxDatabaseCount}" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding MdbxDatabaseCountText}" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                                <Button Classes="workspacePrimaryCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx" HorizontalAlignment="Left">
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <ic:FluentIcon Icon="Database" FontSize="18" />
                                                                        <TextBlock Text="{Binding L.MdbxVaults}" />
                                                                    </StackPanel>
                                                                </Button>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="1" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                                                <TextBlock Text="{Binding L.MdbxLocalCache}" FontWeight="SemiBold" />
                                                                <ToggleSwitch Grid.Column="1" Grid.RowSpan="2" IsChecked="{Binding MdbxLocalCacheEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" VerticalAlignment="Center" />
                                                                <TextBlock Grid.Row="1" Text="{Binding L.MdbxLocalCacheDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </Grid>
                                                        </Border>
                                                        <Border Grid.Row="1" Grid.ColumnSpan="2" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                                                <TextBlock Text="{Binding L.EnableOneDrive}" FontWeight="SemiBold" />
                                                                <ToggleSwitch Grid.Column="1" Grid.RowSpan="2" IsChecked="{Binding OneDriveEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" VerticalAlignment="Center" />
                                                                <TextBlock Grid.Row="1" Text="{Binding L.EnableOneDriveDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="databaseWorkbench" Padding="20" IsVisible="{Binding IsDatabaseCapabilitiesSelected}">
                                                <StackPanel Spacing="14">
                                                    <TextBlock Text="{Binding L.FeatureParityMap}" FontSize="20" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding L.FeatureParityMapDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <ItemsControl ItemsSource="{Binding Capabilities}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:LocalizedPlatformCapability">
                                                                <Border Margin="0,0,0,10" Padding="14" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                                                        <StackPanel Spacing="4" MinWidth="0">
                                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                            <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" />
                                                                            <TextBlock Text="{Binding UnsupportedReason}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" IsVisible="{Binding HasUnsupportedReason}" />
                                                                        </StackPanel>
                                                                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled, Mode=TwoWay}" IsEnabled="{Binding CanToggle}" ToolTip.Tip="{Binding ToggleStatus}" VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <fa:FASettingsExpander Width="374" Margin="0,0,12,12" Header="{Binding L.ImportData}" Description="{Binding L.ImportDataDescription}" IsExpanded="False">
                                                    <fa:FASettingsExpander.IconSource>
                                                        <fa:FASymbolIconSource Symbol="Folder" />
                                                    </fa:FASettingsExpander.IconSource>
                                                    <StackPanel Spacing="8">
                                                        <TextBox Text="{Binding ImportJsonText}" PlaceholderText="{Binding L.ImportJsonWatermark}" AcceptsReturn="True" MinHeight="100" TextWrapping="Wrap" />
                                                        <Button Command="{Binding ImportDataCommand}" HorizontalAlignment="Left">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                                <TextBlock Text="{Binding L.Import}" />
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                </fa:FASettingsExpander>

                                                <fa:FASettingsExpander Width="374" Margin="0,0,0,12" Header="{Binding L.ExportData}" Description="{Binding L.ExportDataDescription}" IsExpanded="False">
                                                    <fa:FASettingsExpander.IconSource>
                                                        <fa:FASymbolIconSource Symbol="ProtectedDocument" />
                                                    </fa:FASettingsExpander.IconSource>
                                                    <StackPanel Spacing="8">
                                                        <Button Command="{Binding ExportDataCommand}" HorizontalAlignment="Left">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                                                                <TextBlock Text="{Binding L.Export}" />
                                                            </StackPanel>
                                                        </Button>
                                                        <TextBox Text="{Binding ExportPreview}" AcceptsReturn="True" MinHeight="100" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </fa:FASettingsExpander>
                                            </WrapPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsMdbx}}"
                              RowDefinitions="Auto,*"
                              HorizontalAlignment="Stretch"
                              ClipToBounds="True">
                                <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                        <TextBlock Classes="workspacePageTitle" Text="{Binding L.MdbxVaults}" />
                                        <TextBlock Grid.Row="1" Classes="workspacePageSubtitle" Text="{Binding MdbxWorkingCopySummaryText}" MaxWidth="720" HorizontalAlignment="Left" />
                                        <WrapPanel Grid.Column="1" Grid.RowSpan="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Classes="workspacePrimaryCommand" Command="{Binding CreateMdbxVaultCommand}" Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Database" FontSize="18" />
                                                    <TextBlock Text="{Binding L.CreateLocalMdbxVault}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceCommand" Command="{Binding RefreshMdbxVaultsCommand}" Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                                    <TextBlock Text="{Binding L.Refresh}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceCommand" ToolTip.Tip="{Binding L.MoreOptions}" AutomationProperties.Name="{Binding L.MoreOptions}" Width="36" Height="36" Padding="0" Margin="0,0,0,8">
                                                <ic:FluentIcon Icon="MoreHorizontal" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuItem Header="{Binding L.Configure}" Command="{Binding ConfigureMdbxRemoteSourcesCommand}">
                                                            <MenuItem.Icon>
                                                                <ic:FluentIcon Icon="Cloud" FontSize="16" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </WrapPanel>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="14" MinWidth="0">
                                    <Border Classes="mdbxSourceRail" ClipToBounds="True">
                                        <Grid RowDefinitions="Auto,*">
                                            <Grid Margin="14,12,14,8" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.MdbxWorkingCopiesSection}" />
                                                    <TextBlock Text="{Binding MdbxWorkingCopySummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" MaxLines="2" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Classes="workspaceCommand" Command="{Binding CreateMdbxVaultCommand}" ToolTip.Tip="{Binding L.CreateLocalMdbxVault}" AutomationProperties.Name="{Binding L.CreateLocalMdbxVault}" Width="34" Height="34" Padding="0">
                                                    <ic:FluentIcon Icon="Add" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Button>
                                                <Button Grid.Column="2" Classes="workspaceCommand" Command="{Binding RefreshMdbxVaultsCommand}" ToolTip.Tip="{Binding L.Refresh}" AutomationProperties.Name="{Binding L.Refresh}" Width="34" Height="34" Padding="0">
                                                    <ic:FluentIcon Icon="ArrowClockwise" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Button>
                                            </Grid>

                                            <Grid Grid.Row="1">
                                                <StackPanel IsVisible="{Binding !HasMdbxDatabases}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                                                    <ic:FluentIcon Icon="Database" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding L.NoMdbxVaults}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding L.MdbxEmptyHint}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                                    <Button Classes="workspacePrimaryCommand" Command="{Binding CreateMdbxVaultCommand}" ToolTip.Tip="{Binding L.CreateLocalMdbxVault}" HorizontalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Database" FontSize="16" />
                                                            <TextBlock Text="{Binding L.CreateLocalMdbxVault}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Classes="workspaceCommand" Command="{Binding ConfigureMdbxRemoteSourcesCommand}" ToolTip.Tip="{Binding L.Configure}" HorizontalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <ic:FluentIcon Icon="Cloud" FontSize="16" />
                                                            <TextBlock Text="{Binding L.Configure}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                                <ListBox Classes="mdbxWorkingCopyList" ItemsSource="{Binding MdbxDatabaseItems}" SelectedItem="{Binding SelectedMdbxDatabaseItem}" IsVisible="{Binding HasMdbxDatabases}" SelectionMode="Single" Margin="8,0,8,8">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:MdbxDatabaseDisplayItem">
                                                            <Border Classes="mdbxWorkingCopyRow">
                                                                <Button Classes="mdbxWorkingCopyButton"
                                                                        Command="{Binding #Root.DataContext.ShowMdbxDatabaseDetailsCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        ToolTip.Tip="{Binding Name}">
                                                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="3" ColumnSpacing="10">
                                                                        <StackPanel Orientation="Horizontal" Spacing="7" MinWidth="0">
                                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                            <Border Classes="workspaceStatusChip" IsVisible="{Binding IsDefault}">
                                                                                <TextBlock Text="{Binding #Root.DataContext.L.Default}" FontSize="12" />
                                                                            </Border>
                                                                        </StackPanel>
                                                                        <Border Grid.Column="1" Grid.RowSpan="2" Classes="workspaceStatusChip" VerticalAlignment="Top">
                                                                            <TextBlock Text="{Binding Source}" FontSize="12" />
                                                                        </Border>
                                                                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding LocalPath}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                                        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding SyncStatus}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                                    </Grid>
                                                                </Button>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <ScrollViewer x:Name="MdbxWorkspaceScrollViewer" Grid.Column="1" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                                        <StackPanel Spacing="14" HorizontalAlignment="Stretch">
                                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                                                <Button Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxHealthSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Health">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Shield" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.MdbxHealthSection}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxDetailsSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Details">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Database" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.Details}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="2" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxSourcesSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Sources">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Cloud" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.MdbxSourcesSection}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="3" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxRuntimeSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Runtime">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Library" FontSize="16" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.MdbxRuntime}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <Border Classes="mdbxWorkbench" Padding="20" MinWidth="0" IsVisible="{Binding IsMdbxDetailsSelected}">
                                                <Grid>
                                                    <StackPanel IsVisible="{Binding HasSelectedMdbxDatabaseItem}" Spacing="18">
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                                            <Border Width="54" Height="54" CornerRadius="27" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                                                <ic:FluentIcon Icon="Database" FontSize="24" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{Binding SelectedMdbxDatabaseItem.Name}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                    <Border Classes="workspaceStatusChip" IsVisible="{Binding SelectedMdbxDatabaseItem.IsDefault}">
                                                                        <TextBlock Text="{Binding L.Default}" FontSize="12" />
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding SelectedMdbxDatabaseItem.Description}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Grid>
                                                        <WrapPanel Orientation="Horizontal">
                                                            <Border Classes="workspaceStatusChip" Margin="0,0,8,8">
                                                                <TextBlock Text="{Binding SelectedMdbxDatabaseItem.Source}" FontSize="12" FontWeight="SemiBold" />
                                                            </Border>
                                                            <Border Classes="workspaceStatusChip" Margin="0,0,8,8">
                                                                <TextBlock Text="{Binding SelectedMdbxDatabaseItem.WorkingCopyStatus}" FontSize="12" />
                                                            </Border>
                                                            <Border Classes="workspaceStatusChip" Margin="0,0,8,8">
                                                                <TextBlock Text="{Binding SelectedMdbxDatabaseItem.SyncStatus}" FontSize="12" />
                                                            </Border>
                                                        </WrapPanel>
                                                        <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12" MinWidth="0">
                                                            <TextBlock Classes="workspaceDetailLabel" Text="{Binding L.LocalPath}" />
                                                            <TextBlock Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedMdbxDatabaseItem.LocalPath}" MaxLines="2" />
                                                            <TextBlock Grid.Row="1" Classes="workspaceDetailLabel" Text="{Binding L.MdbxRemotePath}" />
                                                            <TextBlock Grid.Row="1" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedMdbxDatabaseItem.RemotePath}" MaxLines="2" />
                                                            <TextBlock Grid.Row="2" Classes="workspaceDetailLabel" Text="{Binding L.MdbxLastSynced}" />
                                                            <TextBlock Grid.Row="2" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedMdbxDatabaseItem.LastSyncedText}" MaxLines="2" />
                                                            <TextBlock Grid.Row="3" Classes="workspaceDetailLabel" Text="{Binding L.MdbxRemotePath}" />
                                                            <TextBlock Grid.Row="3" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedMdbxDatabaseItem.RemoteStatus}" MaxLines="2" />
                                                            <TextBlock Grid.Row="4" Classes="workspaceDetailLabel" Text="{Binding L.MdbxDiagnostics}" />
                                                            <TextBlock Grid.Row="4" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedMdbxDatabaseItem.LastSyncErrorText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="2" />
                                                        </Grid>
                                                        <WrapPanel Orientation="Horizontal" MaxWidth="500">
                                                            <Button Classes="workspacePrimaryCommand" Command="{Binding OpenMdbxDatabaseCommand}" CommandParameter="{Binding SelectedMdbxDatabaseItem}" Margin="0,0,8,8">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="18" />
                                                                    <TextBlock Text="{Binding L.Open}" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Classes="workspaceCommand" Command="{Binding SetDefaultMdbxDatabaseCommand}" CommandParameter="{Binding SelectedMdbxDatabaseItem}" IsEnabled="{Binding !SelectedMdbxDatabaseItem.IsDefault}" Margin="0,0,0,8">
                                                                <TextBlock Text="{Binding L.SetDefault}" />
                                                            </Button>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                    <StackPanel IsVisible="{Binding !HasSelectedMdbxDatabaseItem}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                        <ic:FluentIcon Icon="Database" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.NoMdbxVaults}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock Text="{Binding L.MdbxEmptyHint}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        <Button Classes="workspacePrimaryCommand" Command="{Binding CreateMdbxVaultCommand}" ToolTip.Tip="{Binding L.CreateLocalMdbxVault}" HorizontalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <ic:FluentIcon Icon="Database" FontSize="16" />
                                                                <TextBlock Text="{Binding L.CreateLocalMdbxVault}" />
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Border Classes="mdbxWorkbench" Padding="20" IsVisible="{Binding IsMdbxHealthSelected}">
                                                <StackPanel Spacing="14">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                    <Border Width="44" Height="44" CornerRadius="22" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                                        <ic:FluentIcon Icon="Shield" FontSize="22" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding L.MdbxHealthSection}" FontSize="20" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding MdbxSyncDiagnosticsSummaryText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding MdbxHealthItems}" HorizontalAlignment="Stretch">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SyncHealthDisplayItem">
                                                            <Border Classes="mdbxDiagnosticTile" Width="260" MinHeight="112" Margin="0,0,10,10" Padding="14">
                                                                <StackPanel Spacing="4" HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding Label}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                                    <TextBlock Text="{Binding Value}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="2" />
                                                                    <TextBlock Text="{Binding Detail}" FontSize="12" TextWrapping="Wrap" MaxLines="3" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="mdbxWorkbench" Padding="20" IsVisible="{Binding IsMdbxSourcesSelected}">
                                                <StackPanel Spacing="14">
                                                <TextBlock Text="{Binding L.MdbxSourcesSection}" FontSize="20" FontWeight="SemiBold" />
                                                <StackPanel Spacing="10">
                                                    <Border MinHeight="160" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}" HorizontalAlignment="Stretch">
                                                        <StackPanel Spacing="12">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <ic:FluentIcon Icon="Database" FontSize="20" />
                                                                <TextBlock Text="{Binding L.MdbxLocalSource}" FontWeight="SemiBold" />
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding MdbxLocalCountText}" FontSize="22" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding MdbxLocalSourceStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="3" MaxWidth="340" HorizontalAlignment="Left" />
                                                            <Button Classes="workspacePrimaryCommand" Command="{Binding CreateMdbxVaultCommand}" HorizontalAlignment="Left">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <ic:FluentIcon Icon="Database" FontSize="18" />
                                                                    <TextBlock Text="{Binding L.CreateLocalMdbxVault}" />
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border MinHeight="160" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}" HorizontalAlignment="Stretch">
                                                        <StackPanel Spacing="12">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <ic:FluentIcon Icon="Cloud" FontSize="20" />
                                                                <TextBlock Text="{Binding L.MdbxWebDavSource}" FontWeight="SemiBold" />
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding MdbxWebDavCountText}" FontSize="22" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding MdbxWebDavSourceStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="3" MaxWidth="340" HorizontalAlignment="Left" />
                                                            <WrapPanel Orientation="Horizontal">
                                                                <Button Classes="workspaceCommand" Command="{Binding CreateWebDavMdbxVaultCommand}" Margin="0,0,8,8">
                                                                    <ic:FluentIcon Icon="ArrowUpload" FontSize="18" />
                                                                </Button>
                                                                <Button Classes="workspaceCommand" Command="{Binding ConfigureMdbxRemoteSourcesCommand}" Margin="0,0,0,8">
                                                                    <ic:FluentIcon Icon="Database" FontSize="18" />
                                                                </Button>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border MinHeight="160" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}" HorizontalAlignment="Stretch">
                                                        <StackPanel Spacing="12">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <ic:FluentIcon Icon="Cloud" FontSize="20" />
                                                                <TextBlock Text="{Binding L.MdbxOneDriveSource}" FontWeight="SemiBold" />
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding MdbxOneDriveCountText}" FontSize="22" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding MdbxOneDriveSourceStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="3" MaxWidth="340" HorizontalAlignment="Left" />
                                                            <WrapPanel Orientation="Horizontal">
                                                                <Button Classes="workspaceCommand" Command="{Binding CreateOneDriveMdbxVaultCommand}" Margin="0,0,8,8">
                                                                    <ic:FluentIcon Icon="ArrowUpload" FontSize="18" />
                                                                </Button>
                                                                <Button Classes="workspaceCommand" Command="{Binding ConfigureMdbxRemoteSourcesCommand}" Margin="0,0,0,8">
                                                                    <ic:FluentIcon Icon="Database" FontSize="18" />
                                                                </Button>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="mdbxWorkbench" Padding="20" IsVisible="{Binding IsMdbxRuntimeSelected}">
                                                <StackPanel Spacing="16">
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                        <Border Width="44" Height="44" CornerRadius="22" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                                            <ic:FluentIcon Icon="Library" FontSize="22" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding L.MdbxRuntime}" FontSize="20" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding MdbxRuntimeSummaryText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <Border Classes="mdbxDiagnosticTile" Padding="16">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                            <StackPanel Spacing="4" MinWidth="0">
                                                                <TextBlock Text="{Binding L.MdbxLocalCache}" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding MdbxCachePolicyText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </StackPanel>
                                                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding MdbxLocalCacheEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                        <Border Classes="mdbxDiagnosticTile" Padding="16">
                                                            <StackPanel Spacing="6">
                                                                <TextBlock Text="{Binding L.MdbxSecurity}" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding MdbxSecuritySummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="1" Classes="mdbxDiagnosticTile" Padding="16">
                                                            <StackPanel Spacing="6">
                                                                <TextBlock Text="{Binding L.MdbxDiagnostics}" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding MdbxSyncDiagnosticsSummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                    <Border Classes="mdbxDiagnosticTile" Padding="16">
                                                        <StackPanel Spacing="8">
                                                            <TextBlock Text="{Binding L.MdbxAndroidParity}" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding L.MdbxAndroidParityLocal}" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding L.MdbxAndroidParityRemote}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsSync}}"
                              RowDefinitions="Auto,*"
                              MaxWidth="1080"
                              Width="{Binding Bounds.Width, ElementName=WorkspaceHost}"
                              HorizontalAlignment="Left"
                              ClipToBounds="True">
                            <Border Classes="workspacePageHeader">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                    <TextBlock Classes="workspacePageTitle" Text="{Binding L.SyncAndBackup}" />
                                    <TextBlock Grid.Row="1" Classes="workspacePageSubtitle" Text="{Binding L.SyncSubtitle}" MaxWidth="540" HorizontalAlignment="Left" />
                                    <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Top">
                                        <Button Classes="workspaceCommand" Command="{Binding TestWebDavConnectionCommand}" IsEnabled="{Binding !IsWebDavBusy}" Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="ArrowSync" FontSize="18" />
                                                <TextBlock Text="{Binding L.TestConnection}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="workspacePrimaryCommand" Command="{Binding CreateWebDavBackupCommand}" IsEnabled="{Binding !IsWebDavBusy}" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="ArrowUpload" FontSize="18" />
                                                <TextBlock Text="{Binding L.BackupNow}" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" ColumnDefinitions="320,*" ColumnSpacing="16" MinWidth="0">
                                <Border Classes="workspaceSidebar" Padding="14" ClipToBounds="True">
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Spacing="14">
                                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.SyncOverview}" Margin="2,0,0,0" />
                                            <ItemsControl ItemsSource="{Binding SyncHealthItems}" HorizontalAlignment="Stretch">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:SyncHealthDisplayItem">
                                                        <Border Width="130" MinHeight="96" Margin="0,0,8,8" Padding="10" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="{Binding Label}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding Value}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="2" />
                                                                <TextBlock Text="{Binding Detail}" FontSize="12" TextWrapping="Wrap" MaxLines="2" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Border Padding="14" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                                <StackPanel Spacing="10">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="{Binding L.SyncOverview}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding SyncStatusSummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock Text="{Binding SyncRecoverySummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </StackPanel>
                                                    <WrapPanel Orientation="Horizontal">
                                                        <Button Classes="workspaceCommand" Command="{Binding RestoreLatestWebDavBackupCommand}" IsEnabled="{Binding !IsWebDavBusy}" Margin="0,0,8,8">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <ic:FluentIcon Icon="ArrowDownload" FontSize="18" />
                                                                <TextBlock Text="{Binding L.RestoreLatest}" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="DatabaseManagement" Margin="0,0,0,8">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <ic:FluentIcon Icon="Database" FontSize="18" />
                                                                <TextBlock Text="{Binding L.DatabaseManagement}" />
                                                            </StackPanel>
                                                        </Button>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>

                                            <StackPanel Spacing="8">
                                                <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.SyncAndBackup}" Margin="2,4,0,0" />
                                                <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncConfigurationSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Configuration">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <ic:FluentIcon Icon="ArrowSync" FontSize="17" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.SyncConfiguration}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncBackupSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Backup">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <ic:FluentIcon Icon="Save" FontSize="17" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.BackupHistory}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncSourcesSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Sources">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <ic:FluentIcon Icon="Database" FontSize="17" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.CloudAndLocalVaults}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncImportSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Import">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="17" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.ImportData}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncExportSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Export">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <ic:FluentIcon Icon="ArrowDownload" FontSize="17" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding L.ExportData}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                                    <StackPanel Spacing="14" MaxWidth="720" HorizontalAlignment="Stretch">
                                <fa:FASettingsExpander Header="{Binding L.SyncConfiguration}" Description="{Binding SyncConfigurationSummaryText}" IsExpanded="True" IsVisible="{Binding IsSyncConfigurationSelected}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Sync" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.EnableWebDav}" Description="{Binding L.EnableWebDavDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding WebDavEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.WebDavServerUrl}" Description="{Binding L.WebDavServerUrlDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <TextBox Width="260" Text="{Binding WebDavServerUrl}" PlaceholderText="https://dav.example.com" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.WebDavUsername}" Description="{Binding L.WebDavUsernameDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <TextBox Width="220" Text="{Binding WebDavUsername}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.WebDavPassword}" Description="{Binding L.WebDavPasswordDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <TextBox Width="220" PasswordChar="*" Text="{Binding WebDavPassword}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.WebDavRemotePath}" Description="{Binding L.WebDavRemotePathDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <TextBox Width="220" Text="{Binding WebDavRemotePath}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.SyncOnStartup}" Description="{Binding L.SyncOnStartupDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding WebDavSyncOnStartup}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.SyncAfterChanges}" Description="{Binding L.SyncAfterChangesDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding WebDavSyncAfterChanges}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.ConflictStrategy}" Description="{Binding L.ConflictStrategyDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ComboBox Width="220" ItemsSource="{Binding ConflictStrategyOptions}" SelectedValue="{Binding SyncConflictStrategy}" SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.WebDavBackupOptions}" Description="{Binding WebDavBackupOptionsSummaryText}" IsExpanded="True" IsVisible="{Binding IsSyncBackupSelected}" MaxWidth="660" HorizontalAlignment="Left">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Save" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludePasswords}" Description="{Binding L.WebDavBackupOptionsDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludePasswords}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeTotp}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeTotp}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeNotes}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeNotes}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeCards}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeCards}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeDocuments}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeDocuments}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeImages}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeImages}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.IncludeCategories}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <CheckBox IsChecked="{Binding WebDavBackupIncludeCategories}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.EncryptBackup}" Description="{Binding L.EncryptBackupDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding WebDavBackupEncryptionEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.BackupEncryptionPassword}" Description="{Binding L.BackupEncryptionPasswordDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <TextBox Width="260" PasswordChar="*" Text="{Binding WebDavBackupEncryptionPassword}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <Border Padding="0" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}" IsVisible="{Binding IsSyncBackupSelected}" MaxWidth="660" HorizontalAlignment="Left">
                                    <Grid RowDefinitions="Auto,Auto,*" MinHeight="260">
                                        <Grid Margin="18,16,18,10" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding L.BackupHistory}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding WebDavBackupHistoryCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Command="{Binding LoadWebDavBackupsCommand}" IsEnabled="{Binding !IsLoadingWebDavBackups}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                                    <TextBlock Text="{Binding L.Refresh}" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <Border Grid.Row="1"
                                                Margin="14,0,14,10"
                                                Padding="12"
                                                CornerRadius="8"
                                                Background="{DynamicResource LayerFillColorSubtleBrush}"
                                                IsVisible="{Binding HasSelectedWebDavBackupHistoryItem}">
                                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="12" RowSpacing="4">
                                                <TextBlock Text="{Binding SelectedWebDavBackupHistoryItem.FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <WrapPanel Grid.Row="1" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding SelectedWebDavBackupHistoryItem.DateString}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,12,4" />
                                                    <TextBlock Text="{Binding SelectedWebDavBackupHistoryItem.SizeText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                                </WrapPanel>
                                                <TextBlock Grid.Row="2" Text="{Binding SelectedWebDavBackupHistoryItem.Path}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                                <WrapPanel Grid.Column="1" Grid.RowSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Classes="workspaceCommand" Command="{Binding RestoreWebDavBackupCommand}" CommandParameter="{Binding SelectedWebDavBackupHistoryItem}" ToolTip.Tip="{Binding L.OperationRestore}" Margin="0,0,8,4">
                                                        <ic:FluentIcon Icon="ArrowDownload" FontSize="18" />
                                                    </Button>
                                                    <Button Classes="workspaceCommand" Command="{Binding DeleteWebDavBackupCommand}" CommandParameter="{Binding SelectedWebDavBackupHistoryItem}" ToolTip.Tip="{Binding L.Delete}" Margin="0,0,0,4">
                                                        <ic:FluentIcon Icon="Delete" FontSize="18" />
                                                    </Button>
                                                </WrapPanel>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Row="2">
                                            <TextBlock Text="{Binding L.NoBackupsFound}"
                                                       IsVisible="{Binding !HasWebDavBackupHistory}"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Top"
                                                       Margin="24"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <ListBox Classes="workspaceList" ItemsSource="{Binding WebDavBackupHistory}" SelectedItem="{Binding SelectedWebDavBackupHistoryItem}" IsVisible="{Binding HasWebDavBackupHistory}" SelectionMode="Single" Margin="8,0,8,8">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:WebDavBackupHistoryItem">
                                                        <Border Classes="workspaceListRow compact">
                                                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                                                                <Button Grid.RowSpan="2"
                                                                        Classes="workspaceListRowButton"
                                                                        Command="{Binding #Root.DataContext.ShowWebDavBackupDetailsCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        ToolTip.Tip="{Binding FileName}">
                                                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="5">
                                                                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                                                        <WrapPanel Grid.Row="1" Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding DateString}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,12,4" />
                                                                            <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,12,4" />
                                                                            <TextBlock Text="{Binding Path}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="360" Margin="0,0,0,4" />
                                                                        </WrapPanel>
                                                                    </Grid>
                                                                </Button>
                                                                <WrapPanel Grid.Row="2" Orientation="Horizontal">
                                                                    <Button Classes="workspaceCommand" Command="{Binding #Root.DataContext.RestoreWebDavBackupCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.OperationRestore}" Margin="0,0,8,4">
                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <ic:FluentIcon Icon="ArrowDownload" FontSize="18" />
                                                                            <TextBlock Text="{Binding #Root.DataContext.L.OperationRestore}" />
                                                                        </StackPanel>
                                                                    </Button>
                                                                    <Button Classes="workspaceCommand" Command="{Binding #Root.DataContext.DeleteWebDavBackupCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding #Root.DataContext.L.Delete}" Margin="0,0,0,4">
                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <ic:FluentIcon Icon="Delete" FontSize="18" />
                                                                            <TextBlock Text="{Binding #Root.DataContext.L.Delete}" />
                                                                        </StackPanel>
                                                                    </Button>
                                                                </WrapPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <fa:FASettingsExpander Header="{Binding L.CloudAndLocalVaults}" Description="{Binding L.CloudAndLocalVaultsDescription}" IsExpanded="True" IsVisible="{Binding IsSyncSourcesSelected}" MaxWidth="660" HorizontalAlignment="Left">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Folder" />
                                    </fa:FASettingsExpander.IconSource>
                                    <fa:FASettingsExpander.Items>
                                        <fa:FASettingsExpanderItem Content="{Binding L.EnableOneDrive}" Description="{Binding L.EnableOneDriveDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding OneDriveEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.MdbxLocalCache}" Description="{Binding L.MdbxLocalCacheDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <ToggleSwitch IsChecked="{Binding MdbxLocalCacheEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" />
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>

                                        <fa:FASettingsExpanderItem Content="{Binding L.CreateMdbxMetadata}" Description="{Binding L.CreateMdbxMetadataDescription}">
                                            <fa:FASettingsExpanderItem.Footer>
                                                <Button Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Database" FontSize="20" />
                                                        <TextBlock Text="{Binding L.MdbxVaults}" />
                                                    </StackPanel>
                                                </Button>
                                            </fa:FASettingsExpanderItem.Footer>
                                        </fa:FASettingsExpanderItem>
                                    </fa:FASettingsExpander.Items>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.ImportData}" Description="{Binding L.ImportDataDescription}" IsExpanded="True" IsVisible="{Binding IsSyncImportSelected}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="Folder" />
                                    </fa:FASettingsExpander.IconSource>
                                    <StackPanel Spacing="16">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding L.ImportMonicaJson}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ImportMonicaJsonDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBox Text="{Binding ImportJsonText}" PlaceholderText="{Binding L.ImportJsonWatermark}" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                                            <WrapPanel Orientation="Horizontal">
                                                <Button Classes="workspaceCommand" Command="{Binding ImportMonicaJsonFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportFromFile}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceCommand" Command="{Binding ImportDataCommand}" Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.Import}" />
                                                    </StackPanel>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource CardBorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding L.ImportAegisJson}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ImportAegisJsonDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBox Text="{Binding ImportAegisJsonText}" PlaceholderText="{Binding L.ImportAegisJsonWatermark}" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                                            <WrapPanel Orientation="Horizontal">
                                                <Button Classes="workspaceCommand" Command="{Binding ImportAegisJsonFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportFromFile}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceCommand" Command="{Binding ImportAegisJsonCommand}" Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportAegisJson}" />
                                                    </StackPanel>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource CardBorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding L.ImportTotpCsv}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ImportTotpCsvDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBox Text="{Binding ImportTotpCsvText}" PlaceholderText="{Binding L.ImportTotpCsvWatermark}" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                                            <WrapPanel Orientation="Horizontal">
                                                <Button Classes="workspaceCommand" Command="{Binding ImportTotpCsvFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportFromFile}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceCommand" Command="{Binding ImportTotpCsvCommand}" Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportTotpCsv}" />
                                                    </StackPanel>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource CardBorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding L.ImportNoteCsv}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ImportNoteCsvDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBox Text="{Binding ImportNoteCsvText}" PlaceholderText="{Binding L.ImportNoteCsvWatermark}" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                                            <WrapPanel Orientation="Horizontal">
                                                <Button Classes="workspaceCommand" Command="{Binding ImportNoteCsvFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportFromFile}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceCommand" Command="{Binding ImportNoteCsvCommand}" Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportNoteCsv}" />
                                                    </StackPanel>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource CardBorderBrush}" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding L.ImportPasswordCsv}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ImportPasswordCsvDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBox Text="{Binding ImportCsvText}" PlaceholderText="{Binding L.ImportCsvWatermark}" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                                            <WrapPanel Orientation="Horizontal">
                                                <Button Classes="workspaceCommand" Command="{Binding ImportPasswordCsvFileCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Folder" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportFromFile}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceCommand" Command="{Binding ImportPasswordCsvCommand}" Margin="0,0,8,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ImportPasswordCsv}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="workspaceCommand" Command="{Binding ExportPasswordCsvCommand}" Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                                                        <TextBlock Text="{Binding L.ExportPasswordCsv}" />
                                                    </StackPanel>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </fa:FASettingsExpander>

                                <fa:FASettingsExpander Header="{Binding L.ExportData}" Description="{Binding L.ExportDataDescription}" IsExpanded="True" IsVisible="{Binding IsSyncExportSelected}">
                                    <fa:FASettingsExpander.IconSource>
                                        <fa:FASymbolIconSource Symbol="ProtectedDocument" />
                                    </fa:FASettingsExpander.IconSource>
                                    <StackPanel Spacing="12">
                                        <WrapPanel Orientation="Horizontal">
                                            <Button Classes="workspaceCommand" Command="{Binding SaveMonicaJsonExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}" Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Save" FontSize="20" />
                                                    <TextBlock Text="{Binding L.SaveJsonExport}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceCommand" Command="{Binding SavePasswordCsvExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}" Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Save" FontSize="20" />
                                                    <TextBlock Text="{Binding L.SaveCsvExport}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceCommand" Command="{Binding SaveTotpCsvExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}" Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Save" FontSize="20" />
                                                    <TextBlock Text="{Binding L.SaveTotpCsvExport}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceCommand" Command="{Binding SaveNoteCsvExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}" Margin="0,0,8,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Save" FontSize="20" />
                                                    <TextBlock Text="{Binding L.SaveNoteCsvExport}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="workspaceCommand" Command="{Binding SaveAegisJsonExportCommand}" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="{Binding FilePickerIntegrationStatusText}" Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Save" FontSize="20" />
                                                    <TextBlock Text="{Binding L.SaveAegisExport}" />
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>
                                        <TextBlock Text="{Binding L.ExportPreview}" FontWeight="SemiBold" />
                                        <TextBox Text="{Binding ExportPreview}" AcceptsReturn="True" MinHeight="160" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding L.ExportCsvPreview}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding ExportCsvPreview}" AcceptsReturn="True" MinHeight="160" TextWrapping="Wrap" />
                                        <StackPanel Spacing="8" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding L.ExportTotpCsv}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ExportTotpCsvDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Button Classes="workspaceCommand" Command="{Binding ExportTotpCsvCommand}" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                                                    <TextBlock Text="{Binding L.ExportTotpCsv}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Text="{Binding L.ExportTotpCsvPreview}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding ExportTotpCsvPreview}" AcceptsReturn="True" MinHeight="160" TextWrapping="Wrap" />
                                        <StackPanel Spacing="8" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding L.ExportNoteCsv}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ExportNoteCsvDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Button Classes="workspaceCommand" Command="{Binding ExportNoteCsvCommand}" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                                                    <TextBlock Text="{Binding L.ExportNoteCsv}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Text="{Binding L.ExportNoteCsvPreview}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding ExportNoteCsvPreview}" AcceptsReturn="True" MinHeight="160" TextWrapping="Wrap" />
                                        <StackPanel Spacing="8" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding L.ExportAegisJson}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding L.ExportAegisJsonDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Button Classes="workspaceCommand" Command="{Binding ExportAegisJsonCommand}" HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                                                    <TextBlock Text="{Binding L.ExportAegisJson}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Text="{Binding L.ExportAegisPreview}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding ExportAegisPreview}" AcceptsReturn="True" MinHeight="160" TextWrapping="Wrap" />
                                    </StackPanel>
                                </fa:FASettingsExpander>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsGenerator}}"
                              RowDefinitions="Auto,*"
                              HorizontalAlignment="Stretch"
                              ClipToBounds="True">
                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" MinHeight="56">
                                    <StackPanel MinWidth="0" VerticalAlignment="Center">
                                        <TextBlock Classes="workspacePageTitle" Text="{Binding L.PasswordGenerator}" />
                                        <TextBlock Text="{Binding GeneratedPasswordStrengthText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Classes="workspacePrimaryCommand" Command="{Binding GeneratePasswordCommand}" ToolTip.Tip="{Binding L.Generate}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Sparkle" FontSize="18" />
                                                <TextBlock Text="{Binding L.Generate}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="workspaceCommand" Command="{Binding CopyGeneratedPasswordCommand}" ToolTip.Tip="{Binding L.CopyPassword}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <ic:FluentIcon Icon="Copy" FontSize="16" />
                                                <TextBlock Text="{Binding L.CopyPassword}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="workspaceCommand" ToolTip.Tip="{Binding L.MoreOptions}" AutomationProperties.Name="{Binding L.MoreOptions}" Width="36" Height="36" Padding="0">
                                            <ic:FluentIcon Icon="MoreHorizontal" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuItem Header="{Binding L.SaveAsLogin}" Command="{Binding AddPasswordCommand}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="Key" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding L.Reset}" Command="{Binding ResetGeneratorCommand}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="ArrowCounterclockwise" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" ColumnSpacing="14" MinWidth="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{Binding GeneratorOptionsColumnWidth}" />
                                </Grid.ColumnDefinitions>
                                <Border Classes="generatorResultPanel" Padding="{Binding GeneratorResultPanelPadding}" MinWidth="0">
                                    <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="14">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.GeneratedPasswordLabel}" />
                                            <TextBlock Text="{Binding GeneratorStrategySummaryText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <TextBox Grid.Row="1"
                                                 Classes="generatorPasswordBox"
                                                 MinHeight="{Binding GeneratorPasswordBoxMinHeight}"
                                                 Text="{Binding GeneratedPassword}"
                                                 PlaceholderText="{Binding L.GeneratedPasswordPlaceholder}" />
                                        <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8">
                                            <Button Classes="workspacePrimaryCommand" Command="{Binding CopyGeneratedPasswordCommand}" ToolTip.Tip="{Binding L.CopyPassword}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ic:FluentIcon Icon="Copy" FontSize="18" />
                                                    <TextBlock Text="{Binding L.CopyPassword}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="1" Classes="workspaceCommand" Command="{Binding GeneratePasswordCommand}" ToolTip.Tip="{Binding L.Generate}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <ic:FluentIcon Icon="Sparkle" FontSize="16" />
                                                    <TextBlock Text="{Binding L.Generate}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="2" Classes="workspaceCommand" Command="{Binding AddPasswordCommand}" ToolTip.Tip="{Binding L.SaveAsLogin}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <ic:FluentIcon Icon="Key" FontSize="16" />
                                                    <TextBlock Text="{Binding L.SaveAsLogin}" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                        <Border Grid.Row="3" Padding="12" CornerRadius="8" Background="{DynamicResource LayerFillColorSubtleBrush}">
                                            <Grid RowDefinitions="Auto,Auto">
                                                <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.RecentGeneratedPasswords}" />
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding L.NoGeneratedPasswordHistory}"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           TextWrapping="Wrap"
                                                           IsVisible="{Binding !HasGeneratedPasswordHistory}" />
                                                <ScrollViewer Grid.Row="1"
                                                              MaxHeight="{Binding GeneratorHistoryPanelMaxHeight}"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              IsVisible="{Binding HasGeneratedPasswordHistory}">
                                                    <ItemsControl ItemsSource="{Binding GeneratedPasswordHistory}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:GeneratorHistoryItem">
                                                                <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" Margin="0,8,0,0" MinWidth="0">
                                                                    <TextBlock Text="{Binding Value}" FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Grid.Row="1" Text="{Binding ModeLabel}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding StrengthText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding CreatedAtText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                                    <Button Grid.Column="1"
                                                                            Grid.RowSpan="1"
                                                                            Classes="workspaceCommand"
                                                                            Command="{Binding #Root.DataContext.UseGeneratedPasswordHistoryItemCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip.Tip="{Binding #Root.DataContext.L.UsePassword}"
                                                                            Width="32"
                                                                            Height="32"
                                                                            Padding="0">
                                                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Button>
                                                                    <Button Grid.Column="2"
                                                                            Grid.RowSpan="1"
                                                                            Classes="workspaceCommand"
                                                                            Command="{Binding #Root.DataContext.CopyGeneratedPasswordHistoryItemCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip.Tip="{Binding #Root.DataContext.L.CopyPassword}"
                                                                            Width="32"
                                                                            Height="32"
                                                                            Padding="0">
                                                                        <ic:FluentIcon Icon="Copy" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Classes="generatorOptionsPanel" Padding="{Binding GeneratorOptionsPanelPadding}" MinWidth="0">
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Spacing="{Binding GeneratorOptionsSpacing}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.GeneratorTemplate}" />
                                                <ComboBox ItemsSource="{Binding GeneratorTemplateOptions}"
                                                          SelectedItem="{Binding SelectedGeneratorTemplateOption}"
                                                          HorizontalAlignment="Stretch">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.GeneratorMode}" />
                                                <ComboBox ItemsSource="{Binding GeneratorModeOptions}"
                                                          SelectedItem="{Binding SelectedGeneratorModeOption}"
                                                          HorizontalAlignment="Stretch">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsChoice">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Spacing="4" IsVisible="{Binding ShowGeneratorLengthOptions}">
                                                <TextBlock Text="{Binding GeneratorLengthText}" FontWeight="SemiBold" />
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <Slider Minimum="{Binding GeneratorLengthMinimum}" Maximum="{Binding GeneratorLengthMaximum}" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding GeneratorLength}" VerticalAlignment="Center" />
                                                    <NumericUpDown Grid.Column="1" Width="104" Height="36" Minimum="{Binding GeneratorLengthMinimum}" Maximum="{Binding GeneratorLengthMaximum}" Value="{Binding GeneratorLength}" />
                                                </Grid>
                                            </StackPanel>
                                            <StackPanel Spacing="4" IsVisible="{Binding ShowGeneratorWordCountOptions}">
                                                <TextBlock Text="{Binding GeneratorWordCountText}" FontWeight="SemiBold" />
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <Slider Minimum="2" Maximum="8" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding GeneratorWordCount}" VerticalAlignment="Center" />
                                                    <NumericUpDown Grid.Column="1" Width="104" Height="36" Minimum="2" Maximum="8" Value="{Binding GeneratorWordCount}" />
                                                </Grid>
                                            </StackPanel>
                                            <Border Height="1" Background="{DynamicResource CardBorderBrush}" />
                                            <StackPanel Spacing="{Binding GeneratorCheckboxSpacing}" IsVisible="{Binding ShowGeneratorCharacterOptions}">
                                                <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.PasswordStrength}" />
                                                <CheckBox Content="{Binding L.IncludeUppercase}" IsChecked="{Binding GeneratorIncludeUppercase}" />
                                                <CheckBox Content="{Binding L.IncludeLowercase}" IsChecked="{Binding GeneratorIncludeLowercase}" />
                                                <CheckBox Content="{Binding L.IncludeNumbers}" IsChecked="{Binding GeneratorIncludeNumbers}" />
                                                <CheckBox Content="{Binding L.IncludeSymbols}" IsChecked="{Binding GeneratorIncludeSymbols}" />
                                                <CheckBox Content="{Binding L.ExcludeSimilarCharacters}" IsChecked="{Binding GeneratorExcludeSimilarCharacters}" />
                                            </StackPanel>
                                            <StackPanel Spacing="{Binding GeneratorCheckboxSpacing}" IsVisible="{Binding IsGeneratorPassphraseMode}">
                                                <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.PasswordStrength}" />
                                                <CheckBox Content="{Binding L.IncludeNumbers}" IsChecked="{Binding GeneratorIncludeNumbers}" />
                                                <CheckBox Content="{Binding L.IncludeSymbols}" IsChecked="{Binding GeneratorIncludeSymbols}" />
                                            </StackPanel>
                                            <Border Height="1" Background="{DynamicResource CardBorderBrush}" />
                                            <Border Padding="12" CornerRadius="8" Background="{DynamicResource LayerFillColorSubtleBrush}" IsVisible="{Binding ShowGeneratorStrengthSummaryCard}">
                                                <TextBlock Text="{Binding GeneratedPasswordStrengthText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Classes="notesWorkspace" IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsNotes}}" RowDefinitions="44,*" Background="{DynamicResource LayerFillColorDefaultBrush}">
                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                <Grid Height="44">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border IsVisible="{Binding IsNoteTreePaneVisible}" Padding="14,0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,1,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                            <ic:FluentIcon Icon="Folder" FontSize="17" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding L.SecureNotes}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding NoteCountText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Column="1"
                                          HorizontalAlignment="Left"
                                          Width="{Binding NoteTabStripWidth}"
                                          MaxWidth="680"
                                          ColumnDefinitions="Auto,*"
                                          Background="{DynamicResource LayerFillColorSubtleBrush}">
                                        <Button x:Name="PreviousNoteTabButton"
                                                Click="PreviousNoteTabButton_OnClick"
                                                IsEnabled="False"
                                                ToolTip.Tip="向左滚动标签"
                                                Width="30"
                                                Height="34"
                                                Padding="0"
                                                Margin="8,5,2,0"
                                                VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="ChevronLeft" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>

                                        <ScrollViewer x:Name="NoteTabsScrollViewer"
                                                      Grid.Column="1"
                                                      Height="44"
                                                      MaxHeight="44"
                                                      MinWidth="0"
                                                      Margin="0,0,158,0"
                                                      ClipToBounds="True"
                                                      SizeChanged="NoteTabsScrollViewer_OnSizeChanged"
                                                      ScrollChanged="NoteTabsScrollViewer_OnScrollChanged"
                                                      HorizontalScrollBarVisibility="Hidden"
                                                      VerticalScrollBarVisibility="Hidden">
                                            <ItemsControl ItemsSource="{Binding OpenNoteTabs}"
                                                          Height="40"
                                                          Margin="4,4,4,0"
                                                          HorizontalAlignment="Left">
                                                <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:NoteEditorTab">
                                                        <Border Classes="noteTab"
                                                                Classes.active="{Binding IsSelected}"
                                                                Width="{Binding #Root.DataContext.NoteTabWidth}"
                                                                MinWidth="76"
                                                                MaxWidth="156"
                                                                Height="34"
                                                                Margin="0,4,4,0"
                                                                BorderThickness="1,1,1,0"
                                                                CornerRadius="4,4,0,0">
                                                            <Grid RowDefinitions="3,*">
                                                                <Border IsVisible="{Binding IsSelected}" Background="{DynamicResource AccentFillColorDefaultBrush}" CornerRadius="4,4,0,0" />
                                                                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" MinWidth="0">
                                                                    <Button Classes="noteTabButton"
                                                                            Grid.ColumnSpan="2"
                                                                            Command="{Binding #Root.DataContext.SelectNoteTabCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip.Tip="{Binding Title}">
                                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5" Margin="10,0,30,0" MinWidth="0">
                                                                            <TextBlock Text="{Binding Title}" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                            <TextBlock Grid.Column="1" Text="*" IsVisible="{Binding IsDirty}" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                                                        </Grid>
                                                                    </Button>
                                                                    <Button Grid.Column="1"
                                                                            Click="CloseNoteTabButton_OnClick"
                                                                            IsVisible="{Binding IsSelected}"
                                                                            ToolTip.Tip="关闭标签"
                                                                            Width="24"
                                                                            Height="24"
                                                                            Padding="0"
                                                                            Margin="0,2,5,0"
                                                                            VerticalAlignment="Top">
                                                                        <ic:FluentIcon Icon="Dismiss" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Button>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <StackPanel Grid.Column="1"
                                                    Panel.ZIndex="2"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Background="{DynamicResource LayerFillColorSubtleBrush}">
                                        <Button x:Name="NextNoteTabButton"
                                                Click="NextNoteTabButton_OnClick"
                                                IsEnabled="False"
                                                ToolTip.Tip="向右滚动标签"
                                                Width="30"
                                                Height="34"
                                                Padding="0"
                                                Margin="2,5,4,0"
                                                VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="ChevronRight" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>

                                        <Button Command="{Binding AddNoteCommand}" ToolTip.Tip="{Binding L.NewSecureNote}" Width="34" Height="34" Padding="0" Margin="0,5,4,0" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="Add" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>

                                        <Button Command="{Binding SaveNoteCommand}" ToolTip.Tip="{Binding L.SaveNote}" Width="34" Height="34" Padding="0" Margin="0,5,4,0" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="Save" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>

                                        <Button ToolTip.Tip="{Binding L.MoreOptions}" Width="34" Height="34" Padding="0" Margin="0,5,8,0" VerticalAlignment="Top">
                                            <ic:FluentIcon Icon="MoreHorizontal" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuItem Header="保存全部" Command="{Binding SaveAllNoteTabsCommand}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="Save" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="导入 Markdown" Command="{Binding ImportMarkdownNoteCommand}" IsEnabled="{Binding CanUseFilePicker}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="ArrowUpload" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="导出 Markdown" Command="{Binding ExportCurrentNoteMarkdownCommand}" IsEnabled="{Binding CanUseFilePicker}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="ArrowDownload" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="插入图片" Command="{Binding InsertNoteImageCommand}" IsEnabled="{Binding CanUseFilePicker}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="Image" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="{Binding L.Favorite}" Command="{Binding ToggleNoteFavoriteCommand}">
                                                        <MenuItem.Icon>
                                                            <ic:FluentIcon Icon="Star" FontSize="16" />
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator />
                                                    <MenuItem Header="编辑模式" Click="SetNoteEditModeMenuItem_OnClick" />
                                                    <MenuItem Header="预览模式" Click="SetNotePreviewModeMenuItem_OnClick" />
                                                    <MenuItem Header="分屏模式" Click="SetNoteSplitModeMenuItem_OnClick" />
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" SizeChanged="NoteWorkspaceGrid_OnSizeChanged">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding NoteTreeColumnWidth}" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{Binding NoteInspectorColumnWidth}" />
                                </Grid.ColumnDefinitions>
                                <Border IsVisible="{Binding IsNoteTreePaneVisible}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,1,0" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="12">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Margin="0,0,0,10">
                                            <TextBlock Text="保险库" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Command="{Binding AddNoteCommand}" ToolTip.Tip="{Binding L.NewSecureNote}" Width="32" Height="32" Padding="0">
                                                <ic:FluentIcon Icon="Add" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                            <Button Grid.Column="2" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}" Width="32" Height="32" Padding="0">
                                                <ic:FluentIcon Icon="ArrowSync" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                        </Grid>

                                        <TextBox Grid.Row="1"
                                                 Text="{Binding NoteSearchText}"
                                                 PlaceholderText="搜索笔记、标签、正文"
                                                 Height="32"
                                                 Margin="0,0,0,10" />

                                        <Border Grid.Row="2" Padding="10,8" CornerRadius="6" Background="{DynamicResource LayerFillColorSubtleBrush}" Margin="0,0,0,10">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                <ic:FluentIcon Icon="Home" FontSize="16" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="主页" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding NoteTreeStatusText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel Spacing="10">
                                                <StackPanel IsVisible="{Binding HasFavoriteNoteItems}">
                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" Margin="2,0,0,6">
                                                        <ic:FluentIcon Icon="ChevronDown" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7">
                                                            <ic:FluentIcon Icon="Star" FontSize="14" VerticalAlignment="Center" />
                                                            <TextBlock Text="收藏" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding FavoriteNoteCount}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                    </Grid>

                                                    <ItemsControl ItemsSource="{Binding FavoriteNoteItems}" HorizontalAlignment="Stretch">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:SecureItem">
                                                                <Border Margin="8,0,0,4" Padding="0" CornerRadius="6" MinHeight="48" HorizontalAlignment="Stretch" Background="Transparent">
                                                                    <Grid ColumnDefinitions="*,Auto" MinHeight="48" HorizontalAlignment="Stretch">
                                                                        <Button Classes="noteTreeItemButton"
                                                                                Grid.ColumnSpan="2"
                                                                                Command="{Binding #Root.DataContext.OpenNoteCommand}"
                                                                                CommandParameter="{Binding}"
                                                                                MinHeight="48" />
                                                                        <Grid Margin="10,7" ColumnDefinitions="Auto,*" ColumnSpacing="8" HorizontalAlignment="Stretch" IsHitTestVisible="False">
                                                                            <ic:FluentIcon Icon="Document" FontSize="15" VerticalAlignment="Top" Margin="0,2,0,0" />
                                                                            <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                                                                                <StackPanel Orientation="Horizontal" Spacing="5" MinWidth="0">
                                                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MinWidth="0" />
                                                                                    <TextBlock Text=".md" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                                    <ic:FluentIcon Icon="Star" FontSize="12" IsVisible="{Binding IsFavorite}" />
                                                                                </StackPanel>
                                                                                <TextBlock Text="{Binding Notes}" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                        <Button Grid.Column="1"
                                                                                Command="{Binding #Root.DataContext.DeleteNoteCommand}"
                                                                                CommandParameter="{Binding}"
                                                                                ToolTip.Tip="{Binding #Root.DataContext.L.MoveToRecycleBin}"
                                                                                Width="28"
                                                                                Height="28"
                                                                                Padding="0"
                                                                                Margin="6,4,6,0"
                                                                                VerticalAlignment="Top">
                                                                            <ic:FluentIcon Icon="Delete" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Button>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <StackPanel>
                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" Margin="2,0,0,6">
                                                        <ic:FluentIcon Icon="ChevronDown" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7">
                                                            <ic:FluentIcon Icon="FolderOpen" FontSize="14" VerticalAlignment="Center" />
                                                            <TextBlock Text="标签文件树" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding FilteredNoteItems.Count}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                    </Grid>

                                                    <ItemsControl ItemsSource="{Binding NoteTreeGroups}" HorizontalAlignment="Stretch">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:NoteTreeGroup">
                                                                <StackPanel Margin="8,0,0,8" Spacing="4">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="7" MinHeight="28">
                                                                        <ic:FluentIcon Icon="FolderOpen" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                        <Border Grid.Column="2" Padding="7,2" CornerRadius="9" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Count}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                        </Border>
                                                                    </Grid>

                                                                    <ItemsControl ItemsSource="{Binding Items}" HorizontalAlignment="Stretch">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate x:DataType="models:SecureItem">
                                                                                <Border Margin="12,0,0,4" Padding="0" CornerRadius="6" MinHeight="48" HorizontalAlignment="Stretch" Background="Transparent">
                                                                                    <Grid ColumnDefinitions="*,Auto" MinHeight="48" HorizontalAlignment="Stretch">
                                                                                        <Button Classes="noteTreeItemButton"
                                                                                                Grid.ColumnSpan="2"
                                                                                                Command="{Binding #Root.DataContext.OpenNoteCommand}"
                                                                                                CommandParameter="{Binding}"
                                                                                                MinHeight="48" />
                                                                                        <Grid Margin="10,7" ColumnDefinitions="Auto,*" ColumnSpacing="8" HorizontalAlignment="Stretch" IsHitTestVisible="False">
                                                                                            <ic:FluentIcon Icon="Document" FontSize="15" VerticalAlignment="Top" Margin="0,2,0,0" />
                                                                                            <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                                                                                                <StackPanel Orientation="Horizontal" Spacing="5" MinWidth="0">
                                                                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MinWidth="0" />
                                                                                                    <TextBlock Text=".md" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                                                    <ic:FluentIcon Icon="Star" FontSize="12" IsVisible="{Binding IsFavorite}" />
                                                                                                </StackPanel>
                                                                                                <TextBlock Text="{Binding Notes}" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                                            </StackPanel>
                                                                                        </Grid>
                                                                                        <Button Grid.Column="1"
                                                                                                Command="{Binding #Root.DataContext.DeleteNoteCommand}"
                                                                                                CommandParameter="{Binding}"
                                                                                                ToolTip.Tip="{Binding #Root.DataContext.L.MoveToRecycleBin}"
                                                                                                Width="28"
                                                                                                Height="28"
                                                                                                Padding="0"
                                                                                                Margin="6,4,6,0"
                                                                                                VerticalAlignment="Top">
                                                                                            <ic:FluentIcon Icon="Delete" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                                        </Button>
                                                                                    </Grid>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <TextBlock IsVisible="{Binding HasNoteTreeGroups, Converter={x:Static local:BoolConverters.Not}}"
                                                               Text="没有匹配的笔记"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Margin="22,8,0,0" />
                                                </StackPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,*" Margin="36,24,36,20" MaxWidth="920" MinWidth="0" ClipToBounds="True" HorizontalAlignment="Stretch">
                                    <Grid Margin="0,0,0,16">
                                        <TextBox Text="{Binding NoteTitle}"
                                                 Classes="noteChromeLessTextBox"
                                                 PlaceholderText="{Binding L.NoteTitleWatermark}"
                                                 FontSize="32"
                                                 FontWeight="SemiBold"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Padding="0"
                                                 TextWrapping="Wrap"
                                                 MaxLines="2" />
                                    </Grid>

                                    <Border Grid.Row="1" Classes="noteToolbar" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,12">
                                        <WrapPanel Orientation="Horizontal"
                                                   MinWidth="0"
                                                   MaxWidth="680"
                                                   HorizontalAlignment="Left">
                                                <Button Click="UndoNoteEditorButton_OnClick" ToolTip.Tip="撤销" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="ArrowUndo" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Click="RedoNoteEditorButton_OnClick" ToolTip.Tip="重做" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="ArrowRedo" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Border Width="1" Height="20" Background="{DynamicResource CardBorderBrush}" Margin="4,0,6,0" VerticalAlignment="Center" />
                                                <Button Click="ShowNoteFindButton_OnClick" ToolTip.Tip="查找" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Search" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Click="ShowNoteReplaceButton_OnClick" ToolTip.Tip="查找和替换" Width="32" Height="32" Padding="0"><TextBlock Text="↔" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Border Width="1" Height="20" Background="{DynamicResource CardBorderBrush}" Margin="4,0,6,0" VerticalAlignment="Center" />
                                                <Button Tag="h1" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="一级标题" Width="32" Height="32" Padding="0"><TextBlock Text="H1" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="h2" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="二级标题" Width="32" Height="32" Padding="0"><TextBlock Text="H2" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="h3" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="三级标题" Width="32" Height="32" Padding="0"><TextBlock Text="H3" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="bold" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="粗体" Width="32" Height="32" Padding="0"><TextBlock Text="B" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="italic" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="斜体" Width="32" Height="32" Padding="0"><TextBlock Text="I" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="strike" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="删除线" Width="32" Height="32" Padding="0"><TextBlock Text="S" TextDecorations="Strikethrough" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="inlinecode" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="行内代码" Width="32" Height="32" Padding="0"><TextBlock Text="`" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="quote" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="引用" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="TextQuote" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="code" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="代码块" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Code" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="ul" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="无序列表" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="TextBulletList" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="ol" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="有序列表" Width="32" Height="32" Padding="0"><TextBlock Text="1." FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="todo" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="任务列表" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="CheckboxChecked" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="table" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="表格" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Table" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="link" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="链接" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Link" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Tag="hr" Click="MarkdownToolbarButton_OnClick" ToolTip.Tip="分割线" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Subtract" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Click="InsertNoteImageButton_OnClick" IsEnabled="{Binding CanUseFilePicker}" ToolTip.Tip="插入图片" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Image" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                        </WrapPanel>
                                    </Border>

                                    <Border x:Name="NoteFindPanel" Grid.Row="2" IsVisible="False" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource LayerFillColorSubtleBrush}" Padding="8" Margin="0,0,0,12" ClipToBounds="True">
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled" MinWidth="0" ClipToBounds="True">
                                            <WrapPanel Orientation="Horizontal" ItemHeight="32" MinWidth="0">
                                                <TextBox x:Name="NoteFindTextBox"
                                                         PlaceholderText="查找"
                                                         Width="180"
                                                         MinWidth="140"
                                                         Height="32"
                                                         Margin="0,0,6,6"
                                                         KeyDown="NoteFindTextBox_OnKeyDown"
                                                         TextChanged="NoteFindTextBox_OnTextChanged" />
                                                <TextBox x:Name="NoteReplaceTextBox"
                                                         PlaceholderText="替换为"
                                                         Width="180"
                                                         MinWidth="140"
                                                         Height="32"
                                                         Margin="0,0,6,6"
                                                         KeyDown="NoteReplaceTextBox_OnKeyDown" />
                                                <Button Click="FindPreviousNoteMatchButton_OnClick" ToolTip.Tip="上一个" Width="32" Height="32" Margin="0,0,6,6" Padding="0"><ic:FluentIcon Icon="ChevronLeft" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Click="FindNextNoteMatchButton_OnClick" ToolTip.Tip="下一个" Width="32" Height="32" Margin="0,0,6,6" Padding="0"><ic:FluentIcon Icon="ChevronRight" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                                <Button Click="ReplaceCurrentNoteMatchButton_OnClick" ToolTip.Tip="替换当前匹配" MinWidth="54" Height="32" Margin="0,0,6,6" Padding="10,0"><TextBlock Text="替换" VerticalAlignment="Center" /></Button>
                                                <Button Click="ReplaceAllNoteMatchesButton_OnClick" ToolTip.Tip="替换全部匹配" MinWidth="70" Height="32" Margin="0,0,6,6" Padding="10,0"><TextBlock Text="全部替换" VerticalAlignment="Center" /></Button>
                                                <CheckBox x:Name="NoteFindMatchCaseCheckBox" Content="Aa" ToolTip.Tip="区分大小写" Height="32" Margin="0,0,6,6" VerticalAlignment="Center" Click="NoteFindOptions_OnChanged" />
                                                <TextBlock x:Name="NoteFindStatusText" Text="0/0" MinWidth="44" Height="32" Margin="0,0,6,6" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextAlignment="Center" />
                                                <Button Click="CloseNoteFindPanelButton_OnClick" ToolTip.Tip="关闭查找" Width="32" Height="32" Margin="0,0,0,6" Padding="0"><ic:FluentIcon Icon="Dismiss" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" /></Button>
                                            </WrapPanel>
                                        </ScrollViewer>
                                    </Border>

                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding NoteEditorColumnWidth}" />
                                            <ColumnDefinition Width="{Binding NotePreviewSeparatorColumnWidth}" />
                                            <ColumnDefinition Width="{Binding NotePreviewColumnWidth}" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" IsVisible="{Binding IsNoteEditorPaneVisible}" ColumnDefinitions="44,*">
                                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,1,0" Padding="0,0,8,0" Margin="-48,0,12,0">
                                                <TextBlock Text="{Binding NoteLineNumbersText}" FontFamily="Consolas" FontSize="16" LineHeight="24" TextAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Opacity="0.65" />
                                            </Border>
                                            <TextBox x:Name="NoteContentEditor"
                                                     Classes="noteChromeLessTextBox"
                                                     Grid.Column="1"
                                                     Text="{Binding NoteContent}"
                                                     PlaceholderText="{Binding L.NoteContentWatermark}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalAlignment="Stretch"
                                                     VerticalContentAlignment="Top"
                                                     FontFamily="Consolas"
                                                     FontSize="16"
                                                     LineHeight="24"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Padding="0"
                                                     KeyDown="NoteContentEditor_OnKeyDown"
                                                     KeyUp="NoteContentEditor_OnKeyUp"
                                                     TextChanged="NoteContentEditor_OnTextChanged"
                                                     PointerReleased="NoteContentEditor_OnPointerReleased">
                                                <TextBox.Resources>
                                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBackgroundFocusedPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextControlBorderBrushFocusedPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBackground" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBackgroundPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBackgroundFocused" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBorderBrush" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBorderBrushPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="TextBoxBorderBrushFocused" Color="Transparent" />
                                                    <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                                    <Thickness x:Key="TextBoxBorderThemeThickness">0</Thickness>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </Grid>
                                        <Border Grid.Column="1" IsVisible="{Binding NoteSplitPreviewMode}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,0,0,0" Margin="8,0,8,0" />

                                        <Border Grid.Column="2" IsVisible="{Binding IsNotePreviewPaneVisible}" Padding="{Binding NotePreviewContentPadding}" Background="Transparent">
                                            <Grid RowDefinitions="*,Auto">
                                                <md:MarkdownScrollViewer IsVisible="{Binding NoteIsMarkdown}" Markdown="{Binding NotePreviewMarkdown}" MarkdownStyleName="Standard">
                                                    <md:MarkdownScrollViewer.Styles>
                                                        <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock">
                                                            <Setter Property="FontSize" Value="14" />
                                                            <Setter Property="Margin" Value="0,4" />
                                                            <Setter Property="TextWrapping" Value="Wrap" />
                                                        </Style>
                                                        <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading1">
                                                            <Setter Property="FontSize" Value="28" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                            <Setter Property="TextWrapping" Value="Wrap" />
                                                        </Style>
                                                        <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading2">
                                                            <Setter Property="FontSize" Value="24" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                            <Setter Property="TextWrapping" Value="Wrap" />
                                                        </Style>
                                                        <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading3">
                                                            <Setter Property="FontSize" Value="19" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                            <Setter Property="TextWrapping" Value="Wrap" />
                                                        </Style>
                                                        <Style Selector=".Markdown_Avalonia_MarkdownViewer Grid.List">
                                                            <Setter Property="Margin" Value="22,0,0,0" />
                                                        </Style>
                                                        <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.ListMarker">
                                                            <Setter Property="Margin" Value="0,4,6,4" />
                                                        </Style>
                                                    </md:MarkdownScrollViewer.Styles>
                                                </md:MarkdownScrollViewer>
                                                <ScrollViewer IsVisible="{Binding !NoteIsMarkdown}">
                                                    <TextBlock Text="{Binding NotePlainPreview}" TextWrapping="Wrap" FontSize="16" LineHeight="24" />
                                                </ScrollViewer>
                                                <Border Grid.Row="1" IsVisible="{Binding HasNoteImagePreviewItems}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0" Margin="0,12,0,0" Padding="0,10,0,0">
                                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxHeight="190">
                                                        <ItemsControl ItemsSource="{Binding NoteImagePreviewItems}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:NoteImagePreviewItem">
                                                                    <Border Width="172" Height="158" Margin="0,0,10,0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource CardBackgroundBrush}">
                                                                        <Grid RowDefinitions="*,Auto" Margin="8">
                                                                            <Image Source="{Binding Image}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                            <StackPanel Grid.Row="1" Spacing="1" Margin="0,6,0,0">
                                                                                <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock Text="{Binding SizeText}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <Border Grid.Column="2" IsVisible="{Binding IsNoteInspectorPaneVisible}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,0,0,0" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                    <Grid RowDefinitions="Auto,Auto,Auto,*,*" Margin="14,16" RowSpacing="14">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="视图" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="8" ColumnSpacing="12">
                                                <TextBlock Text="格式" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                <ToggleSwitch Grid.Column="1" IsChecked="{Binding NoteIsMarkdown}" OffContent="{Binding L.PlainText}" OnContent="Markdown" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                <TextBlock Grid.Row="1" Text="模式" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                <ToggleSwitch Grid.Row="1" Grid.Column="1" IsChecked="{Binding NotePreviewMode}" OffContent="{Binding L.Edit}" OnContent="{Binding L.Preview}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                <TextBlock Grid.Row="2" Text="布局" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                <ToggleSwitch Grid.Row="2" Grid.Column="1" IsChecked="{Binding NoteSplitPreviewMode}" OffContent="单栏" OnContent="分屏" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Spacing="8">
                                            <Border Height="1" Background="{DynamicResource CardBorderBrush}" />
                                            <TextBlock Text="信息" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="6" ColumnSpacing="10">
                                                <TextBlock Text="行数" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding NoteLineCount}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                <TextBlock Grid.Row="1" Text="词数" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NoteWordCount}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                <TextBlock Grid.Row="2" Text="字符" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NoteCharacterCount}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                            </Grid>
                                            <TextBlock Text="{Binding NoteEditorStatusText}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Spacing="8">
                                            <Border Height="1" Background="{DynamicResource CardBorderBrush}" />
                                            <TextBlock Text="属性" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="标签" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBox Text="{Binding NoteTagsText}" PlaceholderText="{Binding L.NoteTagsWatermark}" />
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <TextBlock Text="格式" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding NoteFormatText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                            </Grid>
                                        </StackPanel>

                                        <Grid Grid.Row="3" RowDefinitions="Auto,*">
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                                <TextBlock Text="大纲" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Grid.Column="1" Text="{Binding NoteOutlineCount}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </Grid>
                                            <Grid Grid.Row="1">
                                                <TextBlock Text="没有 Markdown 标题" IsVisible="{Binding HasNoteOutlineItems, Converter={x:Static local:BoolConverters.Not}}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                <ScrollViewer IsVisible="{Binding HasNoteOutlineItems}">
                                                    <ItemsControl ItemsSource="{Binding NoteOutlineItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:NoteOutlineItem">
                                                                <Button Click="NoteOutlineItem_OnClick" Padding="0" Margin="{Binding Indent}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" ToolTip.Tip="{Binding Title}">
                                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                                        <TextBlock Text="{Binding LineNumber}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Grid>
                                        </Grid>

                                        <Grid Grid.Row="4" RowDefinitions="Auto,*">
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                                <TextBlock Text="引用" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Grid.Column="1" Text="{Binding NoteReferenceCount}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </Grid>
                                            <Grid Grid.Row="1">
                                                <TextBlock Text="没有链接或图片引用" IsVisible="{Binding HasNoteReferenceItems, Converter={x:Static local:BoolConverters.Not}}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                <ScrollViewer IsVisible="{Binding HasNoteReferenceItems}">
                                                    <ItemsControl ItemsSource="{Binding NoteReferenceItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:NoteReferenceItem">
                                                                <Grid RowDefinitions="Auto,Auto" Margin="0,0,0,8">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="7">
                                                                        <ic:FluentIcon Icon="Link" FontSize="12" VerticalAlignment="Center" IsVisible="{Binding IsImage, Converter={x:Static local:BoolConverters.Not}}" />
                                                                        <ic:FluentIcon Icon="Image" FontSize="12" VerticalAlignment="Center" IsVisible="{Binding IsImage}" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Column="2" Text="{Binding LineNumber}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                                        <Button Grid.Column="3" Command="{Binding #Root.DataContext.OpenNoteReferenceCommand}" CommandParameter="{Binding}" ToolTip.Tip="打开" Width="24" Height="24" Padding="0">
                                                                            <ic:FluentIcon Icon="Open" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Button>
                                                                        <Button Grid.Column="4" Command="{Binding #Root.DataContext.CopyNoteReferenceCommand}" CommandParameter="{Binding}" ToolTip.Tip="复制" Width="24" Height="24" Padding="0">
                                                                            <ic:FluentIcon Icon="Copy" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Button>
                                                                    </Grid>
                                                                    <TextBlock Grid.Row="1" Text="{Binding Target}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="20,1,0,0" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </fa:FANavigationView>

        </Grid>

        <Border Grid.Row="2"
                IsVisible="{Binding IsUnlocked}"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Border Padding="10,0" ClipToBounds="True">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="Monica" FontSize="12" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="&#xE777;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ShellVaultText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ShellSyncText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <TextBlock Grid.Column="3"
                               Text="{Binding ShellPageText}"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ShellPlatformText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Grid.RowSpan="2"
                IsVisible="{Binding IsLoadingVault}"
                Background="{DynamicResource OverlayFillColorDefaultBrush}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ClipToBounds="True">
            <StackPanel Width="360"
                        MaxWidth="360"
                        Margin="24"
                        Spacing="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="正在加载保险库"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="{Binding VaultLoadStageText}"
                           Foreground="#DDFFFFFF"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
                <ProgressBar IsIndeterminate="True" Height="4" />
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="#C8FFFFFF"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
